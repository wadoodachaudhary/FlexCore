@namespace Fx.ControlKit
@using Fx.ControlKit.Dialogs
@using System.IO
@inherits FlexControlBase

@* FilePickerControl — by default this keeps the existing browser-upload behavior:
   a clean "open file" button with a fully transparent native
   <input type="file"> is overlaid on the button content, so a REAL user click opens
   the OS file dialog with NO JavaScript (no JS-eval click, no programmatic trigger).

   Set UseFileBrowser=true for the FlexKit filesystem browser instead. That mode
   opens a DialogControl containing FileBrowserControl and returns a selected path.

   The overlay is styled INLINE rather than via scoped CSS on purpose: the <input> is
   rendered by the framework <InputFile> child component, so a host's (or this control's)
   *.razor.css scope attribute never lands on it — the rule silently doesn't match and the
   browser's default "Choose File / No file chosen" chrome shows at full opacity. Inline
   styles bypass CSS isolation entirely, so the input is reliably invisible.

   Supply ChildContent to use any visual (e.g. a ToolbarButtonControl) as the button;
   when null a default ButtonControl shows Label. Read the picked file(s) via OnChange —
   the payload is the standard InputFileChangeEventArgs, identical to a raw <InputFile>. *@
@if (Visible)
{
    <div class="fx-filepicker @CssClass" style="@Style" id="@Id">
        @if (UseFileBrowser)
        {
            <span class="fx-filepicker-browser-trigger"
                  role="button"
                  tabindex="@TabIndex"
                  aria-disabled="@(!Enabled)"
                  @onclick="OpenBrowserDialogAsync"
                  @onkeydown="OnBrowserTriggerKeyDownAsync">
                @if (ChildContent != null)
                {
                    @ChildContent
                }
                else
                {
                    <ButtonControl Disabled="@(!Enabled)">@(Label ?? "Browse...")</ButtonControl>
                }
            </span>
        }
        else
        {
            @if (ChildContent != null)
            {
                @ChildContent
            }
            else
            {
                <ButtonControl Disabled="@(!Enabled)">@(Label ?? "Browse...")</ButtonControl>
            }

            @if (Enabled)
            {
                <InputFile OnChange="HandleChange"
                           accept="@Accept"
                           multiple="@Multiple"
                           title="@ResolvedTooltip"
                           aria-label="@ResolvedAriaLabel"
                           style="position:absolute; inset:0; width:100%; height:100%; opacity:0; cursor:pointer; font-size:0;" />
            }
        }
    </div>

    @if (UseFileBrowser)
    {
        <DialogControl Visible="@_browserDialogVisible"
                       Header="@ResolvedDialogHeader"
                       Width="@DialogWidth"
                       Height="@DialogHeight"
                       IsModal="true"
                       ShowCloseIcon="true"
                       OnClose="CloseBrowserDialogAsync">
            <ChildContent>
                <FileBrowserControl RootPath="@RootPath"
                                    InitialPath="@InitialPath"
                                    CurrentPath="@CurrentPath"
                                    SelectionMode="@SelectionMode"
                                    Accept="@Accept"
                                    SearchPattern="@SearchPattern"
                                    Height="@BrowserHeight"
                                    OpenFolderOnSingleClick="@OpenFolderOnSingleClick"
                                    ShowHidden="@ShowHidden"
                                    ShowFiles="@ShowFiles"
                                    ShowFolders="@ShowFolders"
                                    SelectedPath="@_pendingSelectedPath"
                                    SelectedPathChanged="OnBrowserSelectedPathChangedAsync"
                                    SelectedItemChanged="OnBrowserSelectedItemChangedAsync"
                                    FileActivated="OnBrowserFileActivatedAsync" />
            </ChildContent>
            <FooterContent>
                <ButtonControl CssClass="fx-dialog-btn fx-primary"
                               Disabled="@string.IsNullOrWhiteSpace(_pendingSelectedPath)"
                               OnClick="ConfirmBrowserSelectionAsync">@ResolvedConfirmLabel</ButtonControl>
                <ButtonControl CssClass="fx-dialog-btn" OnClick="CloseBrowserDialogAsync">Cancel</ButtonControl>
            </FooterContent>
        </DialogControl>
    }
}

<MessageBoxControl @ref="_overwriteMessageBox" />

@code {
    [Parameter] public string? Accept { get; set; }

    [Parameter] public bool Multiple { get; set; }

    [Parameter] public string? Label { get; set; }

    [Parameter] public bool ShowTooltip { get; set; } = true;

    [Parameter] public bool UseFileBrowser { get; set; }

    [Parameter] public int? TabIndex { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public EventCallback<InputFileChangeEventArgs> OnChange { get; set; }

    [Parameter] public string? RootPath { get; set; }

    [Parameter] public string? InitialPath { get; set; }

    [Parameter] public string? CurrentPath { get; set; }

    [Parameter] public string? SelectedPath { get; set; }

    [Parameter] public EventCallback<string?> SelectedPathChanged { get; set; }

    [Parameter] public string? Value { get; set; }

    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    [Parameter] public EventCallback<FileBrowserItem?> SelectedItemChanged { get; set; }

    [Parameter] public EventCallback<string?> FilePicked { get; set; }

    [Parameter] public FileBrowserSelectionMode SelectionMode { get; set; } = FileBrowserSelectionMode.Files;

    [Parameter] public string SearchPattern { get; set; } = "*";
    [Parameter] public string? DialogHeader { get; set; }
    [Parameter] public string DialogWidth { get; set; } = "760px";
    [Parameter] public string DialogHeight { get; set; } = "540px";
    [Parameter] public string BrowserHeight { get; set; } = "390px";
    [Parameter] public string? ConfirmLabel { get; set; }
    [Parameter] public bool OpenFolderOnSingleClick { get; set; } = true;
    [Parameter] public bool ShowFiles { get; set; } = true;
    [Parameter] public bool ShowFolders { get; set; } = true;
    [Parameter] public bool ShowHidden { get; set; }
    [Parameter] public bool ConfirmOverwrite { get; set; }
    [Parameter] public string OverwriteTitle { get; set; } = "Confirm Save As";
    [Parameter] public string OverwriteMessageFormat { get; set; } = "{0} already exists.\nDo you want to replace it?";
    [Parameter] public string? OverwriteMessage { get; set; }
    [Parameter] public string OverwriteIcon { get; set; } = "warning";
    [Parameter] public EventCallback<string?> OverwriteConfirmed { get; set; }
    [Parameter] public EventCallback<string?> OverwriteCancelled { get; set; }

    private bool _browserDialogVisible;
    private string? _pendingSelectedPath;
    private FileBrowserItem? _pendingSelectedItem;
    private MessageBoxControl? _overwriteMessageBox;

    private string? ResolvedTooltip => ShowTooltip ? Title : null;

    private string? ResolvedAriaLabel =>
        !string.IsNullOrWhiteSpace(Title) ? Title :
        !string.IsNullOrWhiteSpace(Label) ? Label :
        null;

    private string ResolvedDialogHeader =>
        !string.IsNullOrWhiteSpace(DialogHeader) ? DialogHeader! :
        !string.IsNullOrWhiteSpace(Title) ? Title! :
        SelectionMode == FileBrowserSelectionMode.Directories ? "Select Folder" : "Select File";

    private string ResolvedConfirmLabel =>
        !string.IsNullOrWhiteSpace(ConfirmLabel) ? ConfirmLabel! :
        SelectionMode == FileBrowserSelectionMode.Files ? "Open" : "Select";

    private async Task HandleChange(InputFileChangeEventArgs e)
    {
        if (OnChange.HasDelegate)
            await OnChange.InvokeAsync(e);
    }

    private Task OpenBrowserDialogAsync()
    {
        if (!Enabled)
            return Task.CompletedTask;

        _pendingSelectedPath = FirstNonBlank(SelectedPath, Value);
        _pendingSelectedItem = null;
        _browserDialogVisible = true;
        return Task.CompletedTask;
    }

    private async Task OnBrowserTriggerKeyDownAsync(KeyboardEventArgs e)
    {
        if (string.Equals(e.Key, "Enter", StringComparison.OrdinalIgnoreCase)
            || string.Equals(e.Key, " ", StringComparison.Ordinal))
            await OpenBrowserDialogAsync();
    }

    private Task OnBrowserSelectedPathChangedAsync(string? path)
    {
        _pendingSelectedPath = path;
        return Task.CompletedTask;
    }

    private Task OnBrowserSelectedItemChangedAsync(FileBrowserItem? item)
    {
        _pendingSelectedItem = item;
        _pendingSelectedPath = item?.FullPath ?? _pendingSelectedPath;
        return Task.CompletedTask;
    }

    private async Task OnBrowserFileActivatedAsync(FileBrowserItem item)
    {
        _pendingSelectedItem = item;
        _pendingSelectedPath = item.FullPath;
        await ConfirmBrowserSelectionAsync();
    }

    private async Task ConfirmBrowserSelectionAsync(MouseEventArgs? _ = null)
    {
        if (string.IsNullOrWhiteSpace(_pendingSelectedPath))
            return;

        if (ConfirmOverwrite && File.Exists(_pendingSelectedPath))
        {
            var result = await ShowOverwritePromptAsync(_pendingSelectedPath);
            if (result != MessageBoxResult.Yes)
            {
                if (OverwriteCancelled.HasDelegate)
                    await OverwriteCancelled.InvokeAsync(_pendingSelectedPath);
                return;
            }

            if (OverwriteConfirmed.HasDelegate)
                await OverwriteConfirmed.InvokeAsync(_pendingSelectedPath);
        }

        SelectedPath = _pendingSelectedPath;
        Value = _pendingSelectedPath;
        _browserDialogVisible = false;

        if (SelectedPathChanged.HasDelegate)
            await SelectedPathChanged.InvokeAsync(_pendingSelectedPath);
        if (ValueChanged.HasDelegate)
            await ValueChanged.InvokeAsync(_pendingSelectedPath);
        if (SelectedItemChanged.HasDelegate)
            await SelectedItemChanged.InvokeAsync(_pendingSelectedItem);
        if (FilePicked.HasDelegate)
            await FilePicked.InvokeAsync(_pendingSelectedPath);
    }

    private Task CloseBrowserDialogAsync()
    {
        _browserDialogVisible = false;
        return Task.CompletedTask;
    }

    private Task<MessageBoxResult> ShowOverwritePromptAsync(string path)
    {
        if (_overwriteMessageBox == null)
            return Task.FromResult(MessageBoxResult.No);

        var message = !string.IsNullOrWhiteSpace(OverwriteMessage)
            ? OverwriteMessage!
            : string.Format(System.Globalization.CultureInfo.CurrentCulture, OverwriteMessageFormat, Path.GetFileName(path));

        return _overwriteMessageBox.ShowAsync(message, OverwriteTitle, MessageBoxButtons.YesNo, OverwriteIcon);
    }

    private static string? FirstNonBlank(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));
}
