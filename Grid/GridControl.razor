@namespace Fx.ControlKit.Grid
@inherits FlexControlBase
@typeparam TValue
@using Fx.ControlKit
@using System.Reflection
@using System.Globalization

<div class="@GridHostCssClass"
     style="@HostStyle"
     @ref="_gridHostElement"
     tabindex="0"
     @onkeydown="HandleKeyDown"
     @oncontextmenu="HandleGridContextMenu"
     @oncontextmenu:preventDefault="@GridContextMenuPreventDefault"
     @oncontextmenu:stopPropagation="@StopContextMenuPropagation"
     @onmouseup="HandleGridMouseUp">

    @if (!string.IsNullOrWhiteSpace(_exportStatusMessage))
    {
        <div class="fx-grid-export-status-pill" role="status" aria-live="polite">
            @_exportStatusMessage
        </div>
    }

    @* ── Toolbar ──────────────────────────────────────────────── *@
    
    @if (ShouldRenderToolbar)
    {
        <div class="fx-grid-toolbar">
            @if (Toolbar is { Count: > 0 })
            {
                @foreach (var item in Toolbar)
                {
                    <button class="fx-toolbar-btn" @onclick="() => OnToolbarClick(item)">@item</button>
                }
            }
            @if (ShowSearchBar)
            {
                <div class="fx-toolbar-search">
                    <input type="text" placeholder="Search..."
                           @bind="SearchText" @bind:event="oninput"
                           @bind:after="ApplySearchDebounced" />
                </div>
            }
        </div>
    }

    
    @if (AllowGrouping)
    {
        <div class="fx-group-drop-area @(_dragOverGroupArea ? "fx-group-drop-hover" : "")"
             @ondragover="HandleGroupAreaDragOver"
             @ondragover:preventDefault="true"
             @ondragleave="HandleGroupAreaDragLeave"
             @ondrop="HandleGroupAreaDrop"
             @oncontextmenu:preventDefault="true"
             @oncontextmenu:stopPropagation="true">
            <div class="fx-group-drop-main">
                @if (ShouldRenderAdvancedViewToggle)
                {
                    <button class="fx-group-advanced-toggle-btn @(AdvancedViewEnabled ? "active" : "")"
                            type="button"
                            title="@AdvancedViewToggleTitle"
                            aria-label="@AdvancedViewToggleTitle"
                            aria-pressed="@AdvancedViewTogglePressed"
                            @onclick="ToggleAdvancedView"
                            @onclick:stopPropagation="true">
                        &#9881;
                    </button>
                }
                @if (_groupDescriptors.Count == 0)
                {
                    <span class="fx-group-drop-hint">Drag a column header here to group by that column</span>
                }
                else
                {
                    @if (ShowGroupExpandCollapse)
                    {
                        <button class="fx-group-expand-collapse-btn" @onclick="ToggleExpandCollapseAll" @onclick:stopPropagation="true"
                                title="@(_allGroupsCollapsed ? "Expand All Groups" : "Collapse All Groups")">
                            @(_allGroupsCollapsed ? "⊞" : "⊟")
                        </button>
                        <button class="fx-group-clear-all-btn"
                                type="button"
                                title="Clear All Grouping"
                                aria-label="Clear all grouping"
                                @onclick="ClearAllGroupsAsync"
                                @onclick:stopPropagation="true">
                            🗑
                        </button>
                    }
                    @foreach (var gd in _groupDescriptors)
                    {
                        
                        var capturedField = gd.Field;
                        <span class="fx-group-chip" draggable="true"
                              @ondragstart="() => StartGroupChipDrag(capturedField)"
             @oncontextmenu="@(e => OpenHeaderContextMenu(e, capturedField))"
             @oncontextmenu:preventDefault="true"
             @oncontextmenu:stopPropagation="@EnableHeaderContextMenu"
             title="Right-click for options">
                            <span class="fx-group-chip-text">@gd.HeaderText</span>
                            <span class="fx-group-chip-remove"
                                  role="button"
                                  tabindex="0"
                                  title="@($"Ungroup by {gd.HeaderText}")"
                                  aria-label="@($"Ungroup by {gd.HeaderText}")"
                                  @onclick="() => RemoveGroup(capturedField)"
                                  @onclick:stopPropagation="true"
                                  @oncontextmenu="@(e => OpenHeaderContextMenu(e, capturedField))"
                                  @oncontextmenu:preventDefault="true"
                                  @oncontextmenu:stopPropagation="@EnableHeaderContextMenu">×</span>
                        </span>
                    }
                }
            </div>
            @if (ShouldRenderExpressionFilterButton)
            {
                <div class="fx-expression-filter-area" @onclick:stopPropagation="true">
                    <button class="fx-expression-filter-btn @((_expressionFilterOpen || HasExpressionFilter) ? "active" : "")"
                            type="button"
                            title="@ExpressionFilterToggleTitle"
                            aria-label="@ExpressionFilterToggleTitle"
                            aria-expanded="@ExpressionFilterToggleExpanded"
                            @onclick="ToggleExpressionFilter">
                        @if (_expressionFilterOpen)
                        {
                            <span aria-hidden="true">×</span>
                        }
                        else
                        {
                            <span aria-hidden="true">&#128269;</span>
                        }
                    </button>
                    @if (_expressionFilterOpen)
                    {
                        <div class="fx-expression-filter-editor">
                            <input class="fx-expression-filter-input"
                                   placeholder="OrderQty > 100 and Price Level like Community"
                                   value="@ExpressionFilterDraft"
                                   @oninput="OnExpressionFilterInput"
                                   @onkeydown="HandleExpressionFilterKeyDown" />
                            <button class="fx-expression-filter-apply"
                                    type="button"
                                    title="Apply filter expression"
                                    @onclick="ApplyExpressionFilterAsync">Apply</button>
                            <button class="fx-expression-filter-clear"
                                    type="button"
                                    title="Clear filter expression"
                                    aria-label="Clear filter expression"
                                    @onclick="ClearExpressionFilterAsync">Clear</button>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(_expressionFilterError))
                    {
                        <span class="fx-expression-filter-error" title="@_expressionFilterError">@_expressionFilterError</span>
                    }
                </div>
            }
        </div>
    }

    
    @if (AllowSelection && ShowSelectionInfoBar && (_selectedItems.Count > 1 || _selectedCells.Count > 0))
    {
        <div class="fx-selection-info-bar">
            @if (_selectedItems.Count > 1)
            {
                <span>@_selectedItems.Count rows selected</span>
                @if (_typeAheadBuffer.Length > 0)
                {
                    <span class="fx-typeahead-display">typing: @_typeAheadBuffer</span>
                }
            }
            @if (_selectedCells.Count > 0)
            {
                <span>@_selectedCells.Count cells selected</span>
            }
            <button class="fx-selection-clear-btn" @onclick="ClearSelectionAsync">Clear Selection</button>
        </div>
    }

    
    <CascadingValue Value="@((IGridOwner)this)" IsFixed="true">
        <div style="display:none">
            @ChildContent
        </div>
    </CascadingValue>

    
    @if (ShouldRenderGridOptionsRail)
    {
        <div class="fx-grid-options-rail" @onclick:stopPropagation="true">
            <div class="fx-grid-options-rail-top">
                @if (ShowGridBackButton)
                {
                    <button type="button"
                            class="fx-grid-option-btn"
                            title="Back to grid"
                            aria-label="Back to grid"
                            @onclick="ReturnToGridView">
                        ↩
                    </button>
                }
                @if (ShowColumnOptionsButton)
                {
                    <button type="button"
                            class="fx-grid-option-btn @(_activeOptionsPanel == GridOptionsPanel.Columns ? "active" : "")"
                            title="Column options"
                            aria-label="Column options"
                            @onclick="() => ToggleOptionsPanel(GridOptionsPanel.Columns)">
                        ▤
                    </button>
                }
                @if (AllowPivoting && ShowPivotPanelButton)
                {
                    <button type="button"
                            class="fx-grid-option-btn @(_activeOptionsPanel == GridOptionsPanel.Pivot || _pivotMode ? "active" : "")"
                            title="Pivot mode"
                            aria-label="Pivot mode"
                            @onclick="() => ToggleOptionsPanel(GridOptionsPanel.Pivot)">
                        ▦
                    </button>
                }
            </div>
            @if (ShowGridThemeToggle)
            {
                <button type="button"
                        class="fx-grid-option-btn fx-grid-theme-btn @(_activeOptionsPanel == GridOptionsPanel.Theme ? "active" : "")"
                        title="Theme"
                        aria-label="Theme"
                        @onclick="ToggleGridDarkMode">
                    Theme
                </button>
            }
        </div>
    }

    @if (ShouldRenderGridOptionsRail && _activeOptionsPanel != GridOptionsPanel.None)
    {
        <aside class="fx-grid-side-panel" @onclick:stopPropagation="true">
            <div class="fx-grid-side-panel-header">
                <span>@ActiveOptionsPanelTitle</span>
                <button type="button"
                        class="fx-grid-side-panel-close"
                        title="Close"
                        aria-label="Close"
                        @onclick="CloseOptionsPanel">×</button>
            </div>

            @if (_activeOptionsPanel == GridOptionsPanel.Columns)
            {
                <div class="fx-grid-side-panel-body">
                    <input class="fx-grid-side-search"
                           placeholder="Search columns..."
                           value="@_columnPanelSearch"
                           @oninput="e => _columnPanelSearch = e.Value?.ToString() ?? string.Empty" />
                    <div class="fx-grid-column-option-list">
                        @foreach (var col in ColumnPanelColumns)
                        {
                            var capturedCol = col;
                            var canToggle = !IsColumnVisible(col) || CanHideColumn(col);
                            <label class="fx-grid-check-row">
                                <input type="checkbox"
                                       checked="@IsColumnVisible(col)"
                                       disabled="@(!canToggle)"
                                       @onchange="async e => await SetColumnPanelVisibleAsync(capturedCol, e.Value is bool b && b)" />
                                <span>@HeaderColumnDisplay(col)</span>
                            </label>
                        }
                    </div>
                    <button type="button"
                            class="fx-grid-panel-action"
                            @onclick="HeaderMenuOpenChooseColumns">
                        Advanced columns...
                    </button>
                </div>
            }
            else if (_activeOptionsPanel == GridOptionsPanel.Pivot)
            {
                <div class="fx-grid-side-panel-body fx-grid-pivot-panel-body">
                    <label class="fx-grid-pivot-toggle">
                        <input type="checkbox"
                               checked="@_pivotMode"
                               @onchange="e => SetPivotMode(e.Value is bool b && b)" />
                        <span>Pivot Mode</span>
                    </label>

                    <input class="fx-grid-side-search"
                           placeholder="Search fields..."
                           value="@_pivotFieldSearch"
                           @oninput="e => _pivotFieldSearch = e.Value?.ToString() ?? string.Empty" />

                    <div class="fx-grid-pivot-field-list">
                        @foreach (var col in PivotPanelColumns)
                        {
                            var field = col.Field;
                            <div class="fx-grid-pivot-field-row">
                                <span class="fx-grid-pivot-field-name">@HeaderColumnDisplay(col)</span>
                                <div class="fx-grid-pivot-field-actions">
                                    <button type="button"
                                            title="Add to row groups"
                                            disabled="@IsPivotFieldInArea(field, PivotFieldArea.Row)"
                                            @onclick="() => AddPivotField(field, PivotFieldArea.Row)">R</button>
                                    <button type="button"
                                            title="Add to column labels"
                                            disabled="@IsPivotFieldInArea(field, PivotFieldArea.Column)"
                                            @onclick="() => AddPivotField(field, PivotFieldArea.Column)">C</button>
                                    <button type="button"
                                            title="Add to values"
                                            disabled="@IsPivotFieldInArea(field, PivotFieldArea.Value)"
                                            @onclick="() => AddPivotField(field, PivotFieldArea.Value)">Σ</button>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="fx-grid-pivot-zones">
                        <section class="fx-grid-pivot-zone">
                            <div class="fx-grid-pivot-zone-title">Row Groups</div>
                            @foreach (var field in _pivotRowFields)
                            {
                                <span class="fx-grid-pivot-chip">
                                    @GetPivotFieldLabel(field)
                                    <button type="button" @onclick="() => RemovePivotField(field, PivotFieldArea.Row)">×</button>
                                </span>
                            }
                            @if (_pivotRowFields.Count == 0)
                            {
                                <div class="fx-grid-panel-empty">No row groups</div>
                            }
                        </section>

                        <section class="fx-grid-pivot-zone">
                            <div class="fx-grid-pivot-zone-title">Values</div>
                            @foreach (var valueField in _pivotValueFields)
                            {
                                <span class="fx-grid-pivot-chip fx-grid-pivot-value-chip">
                                    @valueField.DisplayLabel
                                    <DropDownListControl TValue="AggregateType" TItem="AggregateType"
                                                         DataSource="@PivotAggregateTypes"
                                                         Value="@valueField.Aggregation"
                                                         ValueChanged="aggregate => ChangePivotAggregation(valueField, aggregate)"
                                                         CssClass="fx-pivot-agg-select" />
                                    <input class="fx-grid-pivot-format-input"
                                           value="@valueField.Format"
                                           placeholder="Format"
                                           title=".NET format, e.g. N0, N2, C2. Blank uses plain numbers."
                                           @oninput="e => SetPivotValueFormat(valueField, e)" />
                                    <button type="button" @onclick="() => RemovePivotField(valueField.Field, PivotFieldArea.Value)">×</button>
                                </span>
                            }
                            @if (_pivotValueFields.Count == 0)
                            {
                                <div class="fx-grid-panel-empty">No values</div>
                            }
                        </section>

                        <section class="fx-grid-pivot-zone">
                            <div class="fx-grid-pivot-zone-title">Column Labels</div>
                            @foreach (var field in _pivotColumnFields)
                            {
                                <span class="fx-grid-pivot-chip">
                                    @GetPivotFieldLabel(field)
                                    <button type="button" @onclick="() => RemovePivotField(field, PivotFieldArea.Column)">×</button>
                                </span>
                            }
                            @if (_pivotColumnFields.Count == 0)
                            {
                                <div class="fx-grid-panel-empty">No column labels</div>
                            }
                        </section>
                    </div>
                </div>
            }
            else if (_activeOptionsPanel == GridOptionsPanel.Theme)
            {
                <div class="fx-grid-side-panel-body fx-grid-theme-panel-body">
                    <div class="fx-grid-theme-current">
                        Current theme:
                        <strong>@(GetThemeGalleryItem(_activeGridTheme)?.Name ?? _activeGridTheme.ToString())</strong>
                    </div>
                    @foreach (var group in ThemeGalleryGroups)
                    {
                        <section class="fx-grid-theme-section">
                            <div class="fx-grid-theme-section-title">@group.Key</div>
                            <div class="fx-grid-theme-gallery">
                                @foreach (var item in group)
                                {
                                    <button type="button"
                                            class="fx-grid-theme-tile @(item.Theme == _activeGridTheme ? "selected" : "")"
                                            style="@ThemePreviewStyle(item)"
                                            title="@item.Name"
                                            aria-label="@($"Select {item.Name} theme")"
                                            @onclick="() => SelectGridTheme(item.Theme)">
                                        <span class="fx-grid-theme-preview">
                                            <span></span><span></span><span></span><span></span>
                                        </span>
                                        <span class="fx-grid-theme-name">@item.Name</span>
                                    </button>
                                }
                            </div>
                        </section>
                    }
                </div>
            }
        </aside>
    }

    
    @if (_pivotMode)
    {
        <div class="fx-grid-content fx-grid-pivot-shell"
             style="@(string.IsNullOrEmpty(Height) ? "" : "overflow:auto; flex:1;")">
            <PivotControl TValue="TValue"
                          @ref="_pivotControlRef"
                          DataSource="@FilteredData"
                          RowFields="@_pivotRowFields"
                          ColumnFields="@_pivotColumnFields"
                          ValueFields="@_pivotValueFields"
                          FieldLabels="@PivotFieldLabels"
                          Height="@ResolvedPivotHeight"
                          Width="@Width"
                          ShowGrandTotals="true"
                          ShowSubTotals="true"
                          AllowSorting="@AllowSorting"
                          CssClass="fx-grid-embedded-pivot" />
        </div>
    }
    else if (ShowAsChart && ChartValueFields is { Count: > 0 })
    {
        <div class="fx-grid-content fx-grid-chart-content"
             style="@(string.IsNullOrEmpty(Height) ? "" : "overflow:auto; flex:1;")">
            <Fx.ControlKit.Charts.ChartControl
                DataSource="@PagedData"
                ValueFields="@ChartValueFields"
                ValueLabels="@ChartValueLabels"
                LabelField="@(ChartLabelField ?? VisibleColumns.FirstOrDefault()?.Field)"
                BarColor="@ChartBarColor"
                ShowValues="@ChartShowValues"
                ShowAxisLabels="true" />
        </div>
    }
    else
    {

    
    <div class="fx-grid-content" style="@GridContentStyle">
        <table class="fx-grid-table" style="@GetTableStyle()">

            
            <thead class="fx-grid-header">
                <tr>
                    @if (ShowRowReorderColumn)
                    {
                        <th class="fx-header-cell fx-row-reorder-header-cell" style="@RowReorderColumnStyle"></th>
                    }
                    @if (ShowRowSelectorHandleColumn)
                    {
                        <th class="fx-header-cell fx-row-selector-header-cell" style="@RowSelectorHandleColumnStyle"></th>
                    }
                    @if (ShowCheckboxColumn)
                    {
                        <th class="fx-header-cell fx-checkbox-cell" style="width:50px;">
                            <CheckBoxControl Checked="@AllRowsSelected"
                                             CheckedChanged="@SelectAllCheckedChanged"
                                             TabIndex="-1"
                                             StopClickPropagation="true"
                                             StopMouseDownPropagation="true" />
                        </th>
                    }
                    @if (AllowGrouping && HideGroupedColumns && GroupedLayoutColumns.Count > 0)
                    {
                        @foreach (var gcol in GroupedLayoutColumns)
                        {
                            
                            var capturedGroupField = gcol.Field;
                            <th class="fx-header-cell fx-group-indent" style="@GetGroupedPlaceholderStyle(gcol)"
                                @oncontextmenu="@(e => OpenHeaderContextMenu(e, capturedGroupField))"
                                @oncontextmenu:preventDefault="true"
                                @oncontextmenu:stopPropagation="@EnableHeaderContextMenu"
                                title="Right-click for options">
                                <span class="fx-header-text">@HeaderColumnDisplay(gcol)</span>
                            </th>
                        }
                    }
                    @foreach (var col in VisibleColumns)
                    {
                        var state = GetColumnState(col.Field);
                        var headerDraggable = AllowColumnReorder || (AllowGrouping && col.AllowGrouping);
                        var capturedField = col.Field;
                        var headerLabel = HeaderColumnDisplay(col);
                        
                        <th class="fx-header-cell @(state.SortDirection.HasValue ? "fx-sorted" : "") @(state.FilterActive ? "fx-filtered" : "") @(AllowResizing && col.AllowResizing ? "fx-resizable" : "")"
                            style="@col.GetHeaderStyle(); position:relative;"
                            data-field="@capturedField"
                            @onclick="() => HandleSort(col)"
                            @oncontextmenu="@(e => OpenHeaderContextMenu(e, capturedField))"
                            @oncontextmenu:preventDefault="true"
                            @oncontextmenu:stopPropagation="@EnableHeaderContextMenu"
                            title="@headerLabel"
                            draggable="@(headerDraggable ? "true" : "false")"
                            @ondragstart="(e => StartColumnDrag(capturedField, e))"
                            @ondragend="EndColumnDrag">

                            @if (col.HeaderTemplate != null)
                            {
                                @col.HeaderTemplate
                            }
                            else
                            {
                                <span class="fx-header-text">@headerLabel</span>
                            }

                            @if (AllowSorting && col.AllowSorting && state.SortDirection.HasValue)
                            {
                                <span class="fx-sort-icon">@(state.SortDirection == SortDirection.Ascending ? "▲" : "▼")</span>
                            }

                            @if (state.FilterActive)
                            {
                                <span class="fx-filter-applied-mark" title="Filter applied" aria-label="Filter applied"></span>
                            }

                            @if (AllowFiltering && col.AllowFiltering && ShowHeaderFilterIcon)
                            {
                                <span class="fx-filter-icon @(UseDefaultHeaderFilterIcon ? "fx-filter-icon-default" : "fx-filter-icon-custom") @(state.FilterActive ? "active" : "")"
                                      title="Filter"
                                      aria-label="Filter @headerLabel"
                                      @onclick:stopPropagation="true"
                                      @onclick="e => ToggleFilterPopup(col.Field, e)">
                                    @if (!UseDefaultHeaderFilterIcon)
                                    {
                                        @ResolvedHeaderFilterIcon
                                    }
                                </span>
                            }

                            
                            @if (AllowResizing && col.AllowResizing)
                            {
                                <span class="fx-resize-handle"
                                      draggable="false"
                                      @onmousedown="e => StartResize(col, e)"
                                      @onmousedown:preventDefault="true"
                                      @onmousedown:stopPropagation="true"
                                      @onclick:stopPropagation="true"></span>
                            }

                            @if (AllowColumnReorder)
                            {
                                <span class="fx-header-drop-zone fx-header-drop-zone-left"
                                      @ondragover="e => HandleHeaderDropZoneDragOver(capturedField, insertAfter: false, e)"
                                      @ondragover:preventDefault="true"
                                      @ondragover:stopPropagation="true"
                                      @ondrop="e => HandleHeaderDropZoneDrop(capturedField, insertAfter: false, e)"
                                      @ondrop:preventDefault="true"
                                      @ondrop:stopPropagation="true"></span>
                                <span class="fx-header-drop-zone fx-header-drop-zone-right"
                                      @ondragover="e => HandleHeaderDropZoneDragOver(capturedField, insertAfter: true, e)"
                                      @ondragover:preventDefault="true"
                                      @ondragover:stopPropagation="true"
                                      @ondrop="e => HandleHeaderDropZoneDrop(capturedField, insertAfter: true, e)"
                                      @ondrop:preventDefault="true"
                                      @ondrop:stopPropagation="true"></span>
                            }
                        </th>
                    }
                </tr>

            </thead>

            
            <tbody class="fx-grid-body">
                @if (_isEditing && EditSettingsRef?.Mode == EditMode.Inline && _editingRowIndex == -1 && EditSettingsRef.NewRowPosition == NewRowPosition.Top)
                {
                    @RenderEditRow()
                }

                
                @if (AllowGrouping && _groupDescriptors.Count > 0)
                {
                    @RenderGroupedRows(GroupedData, 0)
                }
                else
                {
                    var rowIdx = 0;
                    @foreach (var item in PagedData)
                    {
                        var currentIdx = rowIdx;
                        var isSelected = _selectedItems.Contains(item);
                        var isCellSelectedRow = IsCellSelectionRow(item, currentIdx);
                        var isEditingThis = _isEditing && EditSettingsRef?.Mode == EditMode.Inline && _editingRowIndex == currentIdx;
                        var rowStyle = GetRowStyle(item, currentIdx, isSelected);
                        var rowCssClass = GetRowCssClass(item, currentIdx);

                        @if (isEditingThis)
                        {
                            @RenderEditRow()
                        }
                        else
                        {
                            <tr @key="item"
                                class="fx-row @(rowIdx % 2 == 1 && EnableAltRow ? "fx-alt-row" : "") @(isSelected && HighlightSelectedRows ? "fx-selected" : "") @(isCellSelectedRow && HighlightSelectedRows ? "fx-cell-row-selected" : "") @(EnableHover ? "fx-hover" : "") @(ShowRowReorderColumn && _rowReorderDragTargetIndex == ResolveRowIndex(item, currentIdx) ? "fx-row-reorder-target" : "") @rowCssClass"
                                @onclick="(MouseEventArgs e) => HandleRowClick(item, currentIdx, e)"
                                @ondblclick="() => HandleRowDblClick(item, currentIdx)"
                                @onmousedown="(MouseEventArgs e) => HandleRowMouseDown(item, currentIdx, e)"
                                @onmouseenter="(MouseEventArgs e) => HandleRowMouseEnter(item, currentIdx, e)"
                                @ondragover="(DragEventArgs e) => HandleRowReorderDragOver(item, currentIdx, e)"
                                @ondragover:preventDefault="true"
                                @ondrop="(DragEventArgs e) => HandleRowReorderDrop(item, currentIdx, e)"
                                @ondrop:preventDefault="true"
                                @ondragend="EndRowReorderDrag"
                                style="@rowStyle">

                                @if (ShowRowReorderColumn)
                                {
                                    <td class="fx-cell fx-row-reorder-cell @(CanStartRowReorder(item) ? "" : "disabled")"
                                        style="@RowReorderColumnStyle"
                                        draggable="@(CanStartRowReorder(item) ? "true" : "false")"
                                        title="Drag to move row"
                                        @onclick:stopPropagation="true"
                                        @onmousedown:stopPropagation="true"
                                        @ondragstart="(DragEventArgs e) => StartRowReorderDrag(item, currentIdx, e)"
                                        @ondragend="EndRowReorderDrag">
                                        <span class="fx-row-reorder-grip" aria-hidden="true"></span>
                                    </td>
                                }

                                @if (ShowRowSelectorHandleColumn)
                                {
                                    @RenderRowSelectorHandleCell(item, currentIdx)
                                }

                                @if (ShowCheckboxColumn)
                                {
                                    <td class="fx-cell fx-checkbox-cell" style="width:50px;">
                                        <input type="checkbox" checked="@isSelected"
                                               @onclick:stopPropagation="true"
                                               @onchange="() => ToggleRowSelection(item, currentIdx)" />
                                    </td>
                                }

                                @RenderDataCells(item, currentIdx, col => col)
                            </tr>
                        }
                        rowIdx++;
                    }
                }

                @if (_isEditing && EditSettingsRef?.Mode == EditMode.Inline && _editingRowIndex == -1 && EditSettingsRef.NewRowPosition == NewRowPosition.Bottom)
                {
                    @RenderEditRow()
                }

                @if (!HasAnyData)
                {
                    <tr>
                        <td colspan="@TotalColumnCount" class="fx-empty-row">
                            No records to display
                        </td>
                    </tr>
                }

            </tbody>

            
            @if (AggregateRows is { Count: > 0 })
            {
                var footerRows = AggregateRows.Where(r => r.ShowInFooter).ToList();
                if (footerRows.Count > 0)
                {
                    var allItems = SortedData.ToList();
                    var footerAggs = ComputeAggregates(allItems);
                    <tfoot class="fx-grid-footer">
                        @foreach (var aggRow in footerRows)
                        {
                            <tr class="fx-aggregate-footer-row">
                                @if (ShowRowReorderColumn)
                                {
                                    <td class="fx-cell fx-aggregate-cell fx-row-reorder-cell disabled" style="@RowReorderColumnStyle"></td>
                                }
                                @if (ShowRowSelectorHandleColumn)
                                {
                                    <td class="fx-cell fx-aggregate-cell fx-row-selector-cell" style="@RowSelectorHandleColumnStyle"></td>
                                }
                                @if (ShowCheckboxColumn)
                                {
                                    <td class="fx-cell fx-aggregate-cell"></td>
                                }
                                @if (AllowGrouping && _groupDescriptors.Count > 0)
                                {
                                    @for (int gi = 0; gi < _groupDescriptors.Count; gi++)
                                    {
                                        <td class="fx-cell fx-group-indent"></td>
                                    }
                                }
                                @foreach (var col in VisibleColumns)
                                {
                                    var aggCol = aggRow.Columns.FirstOrDefault(a => a.Field == col.Field);
                                    <td class="fx-cell fx-aggregate-cell" style="@col.GetCellStyle()">
                                        @if (aggCol != null)
                                        {
                                            var key = $"{aggCol.Field}_{aggCol.Type}";
                                            footerAggs.TryGetValue(key, out var val);
                                            <span class="fx-aggregate-value">@FormatAggregateValue(aggCol, val)</span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tfoot>
                }
            }
        </table>
    </div>
    }   

    
    @if (IsPagingActive)
    {
        <div class="fx-grid-pager">
            <div class="fx-pager-info">
                @(_pageState.TotalRecords) items
            </div>
            <div class="fx-pager-nav">
                <button class="fx-pager-btn" tabindex="-1" disabled="@(_pageState.CurrentPage <= 1)" @onclick="() => GoToPage(1)">⟨⟨</button>
                <button class="fx-pager-btn" tabindex="-1" disabled="@(_pageState.CurrentPage <= 1)" @onclick="() => GoToPage(_pageState.CurrentPage - 1)">⟨</button>

                @foreach (var p in GetPageNumbers())
                {
                    var page = p;
                    <button class="fx-pager-btn @(page == _pageState.CurrentPage ? "fx-pager-active" : "")"
                            tabindex="-1"
                            @onclick="() => GoToPage(page)">@(page)</button>
                }

                <button class="fx-pager-btn" tabindex="-1" disabled="@(_pageState.CurrentPage >= _pageState.TotalPages)" @onclick="() => GoToPage(_pageState.CurrentPage + 1)">⟩</button>
                <button class="fx-pager-btn" tabindex="-1" disabled="@(_pageState.CurrentPage >= _pageState.TotalPages)" @onclick="() => GoToPage(_pageState.TotalPages)">⟩⟩</button>
            </div>
            <div class="fx-pager-size">
                <DropDownListControl TValue="int" TItem="PageSizeChoice"
                                     DataSource="@PageSizeChoices"
                                     TextFieldName="Text"
                                     ValueFieldName="Value"
                                     Value="@_pageState.PageSize"
                                     ValueChanged="HandlePageSizeValueChanged"
                                     TabIndex="-1"
                                     CssClass="fx-pager-size-select" />
            </div>
        </div>
    }

    
    @if (_filterPopupField != null)
    {
        var col = VisibleColumns.FirstOrDefault(c => c.Field == _filterPopupField);
        var filterHeader = col == null ? _filterPopupField : HeaderColumnDisplay(col);
        var isNumericFilter = IsNumericFilterColumn(col);

        <div class="fx-filter-popup-overlay" @onclick="CloseFilterPopup">
            <div class="fx-filter-popup" style="@FilterPopupStyle" @onclick:stopPropagation="true">
                <div class="fx-filter-popup-header">
                    <span>Filter: @filterHeader</span>
                    <button type="button"
                            class="fx-filter-popup-close"
                            title="Close"
                            aria-label="Close filter"
                            @onclick="CloseFilterPopup">x</button>
                </div>

                @if (isNumericFilter)
                {
                    var numericRanges = GetNumericFilterRanges(_filterPopupField);
                    var selectedRangeCount = GetSelectedNumericRangeCount(_filterPopupField, numericRanges);

                    <div class="fx-filter-number-panel">
                        <div class="fx-filter-popup-summary">
                            @GetNumericFilterSummary(_filterPopupField, numericRanges, selectedRangeCount)
                        </div>

                        <div class="fx-filter-number-custom">
                            <div class="fx-filter-number-inputs">
                                <label class="fx-filter-number-field">
                                    <span>Min</span>
                                    <input type="number"
                                           class="fx-filter-number-input"
                                           value="@GetNumericFilterMinText(_filterPopupField)"
                                           @oninput="e => SetNumericFilterMinText(_filterPopupField, e.Value?.ToString())" />
                                </label>
                                <label class="fx-filter-number-field">
                                    <span>Max</span>
                                    <input type="number"
                                           class="fx-filter-number-input"
                                           value="@GetNumericFilterMaxText(_filterPopupField)"
                                           @oninput="e => SetNumericFilterMaxText(_filterPopupField, e.Value?.ToString())" />
                                </label>
                            </div>
                            <button type="button"
                                    class="fx-filter-popup-btn"
                                    @onclick="() => ApplyNumericBoundsFilter(_filterPopupField)">
                                Apply Range
                            </button>
                        </div>

                        <div class="fx-filter-range-list">
                            @foreach (var range in numericRanges)
                            {
                                var capturedRange = range;
                                <label class="fx-filter-checkbox-item fx-filter-range-item">
                                    <input type="checkbox"
                                           checked="@IsNumericRangeChecked(_filterPopupField, capturedRange)"
                                           @onchange="e => SetNumericRangeChecked(_filterPopupField, capturedRange, e.Value is bool b && b)" />
                                    <span>@capturedRange.Label</span>
                                    <em>@capturedRange.CountLabel</em>
                                </label>
                            }
                            @if (numericRanges.Count == 0)
                            {
                                <div class="fx-filter-popup-empty">No numeric values</div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    var candidates = GetColumnFilterValueCandidates(_filterPopupField);
                    var values = candidates.Select(v => v.Value).ToList();
                    var totalValueCount = GetDistinctValues(_filterPopupField).Count;
                    var selectedValueCount = GetSelectedFilterValueCount(_filterPopupField);

                    <div class="fx-filter-condition">
                        <DropDownListControl TValue="TextFilterOperator" TItem="TextFilterOperatorChoice"
                                             DataSource="@TextFilterOperatorChoices"
                                             TextFieldName="Text"
                                             ValueFieldName="Value"
                                             Value="@_filterOperatorDraft"
                                             ValueChanged="OnTextFilterOperatorValueChanged"
                                             CssClass="fx-filter-operator-select" />
                        <input type="text"
                               @ref="_filterConditionInputRef"
                               class="fx-filter-popup-input fx-filter-condition-input"
                               placeholder="Filter value..."
                               value="@_filterTextDraft"
                               @oninput="OnTextFilterInput"
                               @oninput:stopPropagation="true"
                               @onkeydown:stopPropagation="true"
                               @onkeyup:stopPropagation="true"
                               @onclick:stopPropagation="true" />
                    </div>

                    <div class="fx-filter-popup-summary fx-filter-value-summary">
                        @selectedValueCount of @totalValueCount selected
                    </div>

                    <label class="fx-filter-checkbox-item fx-filter-select-all-row">
                        <input type="checkbox"
                               checked="@IsFilterFieldFullySelected(_filterPopupField, values)"
                               @onchange="e => SetFilterFieldSelected(_filterPopupField, e.Value is bool b && b, values)" />
                        <span>(Select All)</span>
                    </label>

                    <div class="fx-filter-checkbox-list">
                        @foreach (var candidate in candidates)
                        {
                            var v = candidate.Value;
                            <label class="fx-filter-checkbox-item">
                                <input type="checkbox"
                                       checked="@IsFilterValueChecked(_filterPopupField, v)"
                                       @onchange="e => SetFilterValueChecked(_filterPopupField, v, e.Value is bool b && b)" />
                                <span>@candidate.DisplayText</span>
                            </label>
                        }
                        @if (values.Count == 0)
                        {
                            <div class="fx-filter-popup-empty">No matching values</div>
                        }
                    </div>
                }

                <div class="fx-filter-popup-actions">
                    <label class="fx-filter-auto-apply">
                        <input type="checkbox"
                               checked="@_filterPopupAutoApply"
                               @onchange="OnFilterPopupAutoApplyChanged" />
                        <span>Auto Apply</span>
                    </label>
                    <div class="fx-filter-popup-action-buttons">
                        <button class="fx-filter-popup-btn" @onclick="() => ClearFilterFromPopup(_filterPopupField)">Clear Filter</button>
                        <button class="fx-filter-popup-btn fx-primary"
                                disabled="@_filterPopupAutoApply"
                                @onclick="() => ApplyFilterPopupAsync(close: true)">Apply</button>
                    </div>
                </div>
            </div>
        </div>
    }

    
    @if (_isEditing && EditSettingsRef?.Mode == EditMode.Dialog)
    {
        <div class="fx-dialog-overlay" @onclick="CancelEdit">
            <div class="fx-dialog" @onclick:stopPropagation="true">
                <div class="fx-dialog-header">
                    @(_editingRowIndex >= 0 ? "Edit Record" : "Add New Record")
                    <button class="fx-dialog-close" @onclick="CancelEdit">×</button>
                </div>
                <div class="fx-dialog-body">
                    @foreach (var col in VisibleColumns.Where(c => c.AllowEditing && !string.IsNullOrEmpty(c.Field) && c.Type != ColumnType.CheckBox && c.Commands == null))
                    {
                        <div class="fx-dialog-field">
                            <label>@col.DisplayHeader</label>
                            @if (col.EditTemplate != null && _editItem != null)
                            {
                                @col.EditTemplate((object)_editItem)
                            }
                            else
                            {
                                <input type="@(col.Type == ColumnType.Number ? "number" : col.Type == ColumnType.Date ? "date" : col.Type == ColumnType.Password ? "password" : "text")"
                                       value="@GetPropertyValue(_editItem, col.Field)"
                                       disabled="@col.IsPrimaryKey"
                                       @onchange="e => SetPropertyValue(_editItem, col.Field, e.Value?.ToString())" />
                            }
                        </div>
                    }
                </div>
                <div class="fx-dialog-footer">
                    <button class="fx-dialog-btn" @onclick="CancelEdit">Cancel</button>
                    <button class="fx-dialog-btn fx-primary" @onclick="SaveEdit">Save</button>
                </div>
            </div>
        </div>
    }

    
    @if (_resizingCol != null || _resizingRowIndex >= 0)
    {
        <div class="fx-resize-overlay @(_resizingRowIndex >= 0 ? "fx-row-resize-overlay" : "")"
             @onmousemove="HandleGridResizeMove"
             @onmouseup="EndGridResize"
             @onmouseleave="EndGridResize"></div>
    }

    
    @if (_showCellContextMenu)
    {
        <div class="fx-grid-cell-context-backdrop"
             @onclick="CloseCellContextMenu"
             @oncontextmenu="CloseCellContextMenu"
             @oncontextmenu:preventDefault="true"></div>
        <div class="fx-grid-cell-context-menu"
             style="left:@(_cellContextMenuX)px;top:@(_cellContextMenuY)px;"
             @onclick:stopPropagation="true">
            <button type="button"
                    class="fx-grid-cell-context-item"
                    disabled="@(!CanApplyCellContextEdit)"
                    @onclick="CellContextCutAsync">
                <span>Cut</span>
                <span class="fx-grid-cell-context-shortcut">Ctrl+X</span>
            </button>
            <button type="button"
                    class="fx-grid-cell-context-item"
                    disabled="@(!CanReadCellContext)"
                    @onclick="CellContextCopyAsync">
                <span>Copy</span>
                <span class="fx-grid-cell-context-shortcut">Ctrl+C</span>
            </button>
            <button type="button"
                    class="fx-grid-cell-context-item"
                    disabled="@(!CanApplyCellContextEdit)"
                    @onclick="CellContextPasteAsync">
                <span>Paste</span>
                <span class="fx-grid-cell-context-shortcut">Ctrl+V</span>
            </button>
            <button type="button"
                    class="fx-grid-cell-context-item"
                    disabled="@(!CanApplyCellContextEdit)"
                    @onclick="CellContextDeleteAsync">
                <span>Delete</span>
                <span class="fx-grid-cell-context-shortcut">Del</span>
            </button>
        </div>
    }

    
    
    @if (_showHeaderContextMenu)
    {
        <div style="position:fixed;inset:0;z-index:999;background:transparent;"
             @onclick="CloseHeaderContextMenu"
             @oncontextmenu="CloseHeaderContextMenu"
             @oncontextmenu:preventDefault="true"></div>
        <div class="fx-grid-header-context-menu"
             style="left:@(_headerContextMenuX)px;top:@(_headerContextMenuY)px;"
             @onclick:stopPropagation="true">

            @if (HeaderContextMenuShowsColumns)
            {
                @foreach (var col in HeaderContextMenuColumns)
                {
                    var capturedCol = col;
                    <button type="button" class="fx-grid-header-context-item"
                            disabled="@(!CanToggleHeaderContextColumn(col))"
                            @onclick="() => ToggleHeaderContextColumnAsync(capturedCol)">
                        <span class="fx-grid-header-context-check">@(IsColumnVisible(col) ? "✓" : "")</span>
                        @HeaderColumnDisplay(col)
                    </button>
                }
            }
            else
            {
                @if (AllowGrouping && (CurrentHeaderColumn?.AllowGrouping ?? false))
                {
                    <button type="button" class="fx-grid-header-context-item"
                            @onclick="HeaderMenuToggleGroup">
                        <span class="fx-grid-header-context-check">@(IsHeaderColumnGrouped ? "✓" : "")</span>
                        Group on this column
                    </button>
                }
                @if (AllowGrouping)
                {
                    <button type="button" class="fx-grid-header-context-item"
                            disabled="@(_groupDescriptors.Count == 0)"
                            @onclick="HeaderMenuExpandAll">
                        <span class="fx-grid-header-context-check"></span>
                        Expand All
                    </button>
                    <button type="button" class="fx-grid-header-context-item"
                            disabled="@(_groupDescriptors.Count == 0)"
                            @onclick="HeaderMenuCollapseAll">
                        <span class="fx-grid-header-context-check"></span>
                        Collapse All
                    </button>
                    <div class="fx-grid-header-context-sep"></div>
                }

                <button type="button" class="fx-grid-header-context-item"
                        disabled="@(!CanHideHeaderColumn)"
                        @onclick="HeaderMenuHideColumn">
                    <span class="fx-grid-header-context-check"></span>
                    Hide this column
                </button>
                <button type="button" class="fx-grid-header-context-item"
                        @onclick="HeaderMenuOpenChooseColumns">
                    <span class="fx-grid-header-context-check"></span>
                    Insert a column...
                </button>
                <button type="button" class="fx-grid-header-context-item"
                        @onclick="HeaderMenuStartRename">
                    <span class="fx-grid-header-context-check"></span>
                    Rename this column...
                </button>
                <div class="fx-grid-header-context-sep"></div>

                <button type="button" class="fx-grid-header-context-item"
                        @onclick="HeaderMenuPrint">
                    <span class="fx-grid-header-context-check"></span>
                    Print...
                </button>
                <button type="button" class="fx-grid-header-context-item"
                        @onclick="HeaderMenuSaveAs">
                    <span class="fx-grid-header-context-check"></span>
                    Save As...
                </button>
            }
        </div>
    }

    @if (_showRenameColumn)
    {
        <div class="fx-grid-rename-overlay"
             @onclick="HeaderMenuCancelRename"
             @oncontextmenu="HeaderMenuCancelRename"
             @oncontextmenu:preventDefault="true"></div>
        <div class="fx-grid-rename-dialog" @onclick:stopPropagation="true">
            <div class="fx-grid-rename-header">
                <span>Rename Column</span>
                <button type="button"
                        class="fx-grid-rename-close"
                        title="Close"
                        aria-label="Close"
                        @onclick="HeaderMenuCancelRename">x</button>
            </div>
            <div class="fx-grid-rename-body">
                <label class="fx-grid-rename-field">
                    <span>Name</span>
                    <input type="text"
                           class="fx-grid-rename-input"
                           value="@_renameColumnDraft"
                           @oninput="@(e => _renameColumnDraft = e.Value?.ToString() ?? "")"
                           @onkeydown="@(async e => { if (e.Key == "Enter") await HeaderMenuCommitRename(); else if (e.Key == "Escape") HeaderMenuCancelRename(); })" />
                </label>
            </div>
            <div class="fx-grid-rename-footer">
                <button type="button" class="fx-grid-rename-ok"
                        @onclick="HeaderMenuCommitRename">OK</button>
                <button type="button" class="fx-grid-rename-cancel"
                        @onclick="HeaderMenuCancelRename">Cancel</button>
            </div>
        </div>
    }

    
    @if (_showPrintOptionsDialog)
    {
        <div class="fx-grid-print-options-overlay"
             @onclick="PrintOptionsCancel"
             @oncontextmenu="PrintOptionsCancel"
             @oncontextmenu:preventDefault="true"></div>
        <div class="fx-grid-print-options-dialog" @onclick:stopPropagation="true">
            <div class="fx-grid-print-options-header">
                <span>Print Grid</span>
                <button type="button" class="fx-grid-print-options-close"
                        title="Close" aria-label="Close"
                        @onclick="PrintOptionsCancel">×</button>
            </div>
            <div class="fx-grid-print-options-body">
                <label class="fx-grid-print-options-field">
                    <span>Orientation</span>
                    <select @bind="_printOrientation">
                        <option value="@GridPdfOrientation.Portrait">Portrait</option>
                        <option value="@GridPdfOrientation.Landscape">Landscape</option>
                    </select>
                </label>
                <label class="fx-grid-print-options-field">
                    <span>Page size</span>
                    <select @bind="_printPageSize">
                        <option value="@GridPdfPageSize.Letter">Letter</option>
                        <option value="@GridPdfPageSize.Legal">Legal</option>
                        <option value="@GridPdfPageSize.A4">A4</option>
                    </select>
                </label>
                <label class="fx-grid-print-options-field">
                    <span>Columns</span>
                    <select @bind="_printColumnLayout">
                        <option value="@GridPdfColumnLayout.WrapText">Wrap text</option>
                        <option value="@GridPdfColumnLayout.ClipText">Clip text</option>
                        <option value="@GridPdfColumnLayout.FitColumnsToPage">Fit columns</option>
                    </select>
                </label>
                <label class="fx-grid-print-options-field">
                    <span>Grid lines</span>
                    <span class="fx-grid-print-options-check">
                        <input type="checkbox" @bind="_printShowGridLines" />
                        <span>On</span>
                    </span>
                </label>
                <label class="fx-grid-print-options-field">
                    <span>Zoom</span>
                    <select @bind="_printZoomMode">
                        <option value="@GridPdfZoomMode.Percent">Zoom %</option>
                        <option value="@GridPdfZoomMode.FitToPage">Fit to page</option>
                    </select>
                </label>
                <label class="fx-grid-print-options-field">
                    <span>Zoom %</span>
                    <input type="number"
                           min="25"
                           max="200"
                           step="5"
                           disabled="@(_printZoomMode == GridPdfZoomMode.FitToPage)"
                           @bind="_printZoomPercent" />
                </label>
            </div>
            <div class="fx-grid-print-options-footer">
                <button type="button" class="fx-grid-print-options-ok"
                        @onclick="PrintOptionsOk">Print</button>
                <button type="button" class="fx-grid-print-options-cancel"
                        @onclick="PrintOptionsCancel">Cancel</button>
            </div>
        </div>
    }

    
    
    @if (_showChooseColumnsDialog)
    {
        <div class="fx-choose-columns-overlay"
             @onclick="ChooseColumnsCancel"
             @oncontextmenu="ChooseColumnsCancel"
             @oncontextmenu:preventDefault="true"></div>
        <div class="fx-choose-columns-dialog" @onclick:stopPropagation="true">
            <div class="fx-choose-columns-header">
                <span>Choose Columns</span>
                <button type="button" class="fx-choose-columns-close"
                        title="Close" aria-label="Close"
                        @onclick="ChooseColumnsCancel">×</button>
            </div>
            <div class="fx-choose-columns-instructions">
                Check the columns that you would like visible in this view. Use
                the Move Up and Move Down buttons to reorder the columns as you
                would like them to appear.
            </div>
            <div class="fx-choose-columns-body">
                <div class="fx-choose-columns-list">
                    @foreach (var row in _chooseColumnsRows)
                    {
                        var capturedRow = row;
                        <div @key="capturedRow.Field"
                             class="fx-choose-columns-row @(row.Field == _chooseColumnsSelectedField ? "selected" : "")"
                             @onclick="() => ChooseColumnsSelect(capturedRow.Field)">
                            <input type="checkbox"
                                   checked="@row.Visible"
                                   disabled="@(!row.CanHide)"
                                   @onchange="e => ChooseColumnsSetVisible(capturedRow, e)"
                                   @onclick:stopPropagation="true" />
                            <span class="fx-choose-columns-label">@row.Header</span>
                        </div>
                    }
                </div>
                <div class="fx-choose-columns-buttons">
                    <button type="button" @onclick="ChooseColumnsMoveUp"
                            disabled="@(_chooseColumnsRows.FindIndex(r => r.Field == _chooseColumnsSelectedField) <= 0)">
                        Move Up
                    </button>
                    <button type="button" @onclick="ChooseColumnsMoveDown"
                            disabled="@(_chooseColumnsRows.FindIndex(r => r.Field == _chooseColumnsSelectedField) < 0
                                        || _chooseColumnsRows.FindIndex(r => r.Field == _chooseColumnsSelectedField) >= _chooseColumnsRows.Count - 1)">
                        Move Down
                    </button>
                    <button type="button" @onclick="ChooseColumnsShow">Show</button>
                    <button type="button" @onclick="ChooseColumnsShowAll">Show All</button>
                    <button type="button" @onclick="ChooseColumnsHide">Hide</button>
                    <button type="button" @onclick="ChooseColumnsHideAll">Hide All</button>
                    <button type="button" class="fx-choose-columns-restore"
                            @onclick="ChooseColumnsRestoreDefault">
                        Restore<br/>Default Layout
                    </button>
                </div>
            </div>
            <div class="fx-choose-columns-footer">
                <button type="button" class="fx-choose-columns-ok"
                        @onclick="ChooseColumnsOk">OK</button>
                <button type="button" class="fx-choose-columns-cancel"
                        @onclick="ChooseColumnsCancel">Cancel</button>
            </div>
        </div>
    }
</div>
