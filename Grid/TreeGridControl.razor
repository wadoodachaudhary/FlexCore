@namespace Fx.ControlKit.Grid
@typeparam TValue

<div class="@TreeGridCssClass"
     style="@(string.IsNullOrEmpty(Height) ? "" : $"height:{Height};") @(string.IsNullOrEmpty(Width) ? "" : $"width:{Width};")"
     tabindex="@TabIndex"
     @onkeydown="HandleKeyDown"
     @onmousemove="HandleColumnResizeMove"
     @onmouseup="EndColumnResize"
     @onmouseleave="EndColumnResize">

    @if (ShouldRenderToolbar)
    {
        <div class="fx-treegrid-toolbar">
            @foreach (var toolbarItem in ResolvedToolbarItems)
            {
                var item = ResolveToolbarItem(toolbarItem);
                if (item.SeparatorBefore)
                {
                    <span class="fx-treegrid-toolbar-separator"></span>
                }
                <span class="fx-treegrid-toolbar-shell">
                    <button type="button"
                            class="@GetToolbarButtonCss(item)"
                            disabled="@item.Disabled"
                            title="@ResolveToolbarTitle(item)"
                            aria-label="@ResolveToolbarAriaLabel(item)"
                            @onclick="() => HandleToolbarItemClickAsync(item, false, null)">
                        @if (!string.IsNullOrWhiteSpace(ResolveToolbarIconSrc(item)))
                        {
                            <img class="fx-treegrid-toolbar-icon" src="@ResolveToolbarIconSrc(item)" alt="@ResolveToolbarIconAlt(item)" />
                        }
                        else if (!string.IsNullOrWhiteSpace(ResolveToolbarGlyph(item)))
                        {
                            <span class="fx-treegrid-toolbar-glyph" aria-hidden="true">@ResolveToolbarGlyph(item)</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.Text))
                        {
                            <span class="fx-treegrid-toolbar-text">@item.Text</span>
                        }
                        @if (HasToolbarMenu(item))
                        {
                            <span class="fx-treegrid-toolbar-menu-arrow" aria-hidden="true">▾</span>
                        }
                    </button>
                    @if (IsToolbarMenuOpen(item, false, null))
                    {
                        <div class="fx-treegrid-toolbar-menu">
                            @foreach (var child in GetVisibleToolbarChildren(item))
                            {
                                var childItem = ResolveToolbarItem(child);
                                <button type="button"
                                        class="fx-treegrid-toolbar-menu-item"
                                        disabled="@childItem.Disabled"
                                        @onclick="() => HandleToolbarMenuItemClickAsync(childItem, false, null)">
                                    @if (!string.IsNullOrWhiteSpace(ResolveToolbarIconSrc(childItem)))
                                    {
                                        <img class="fx-treegrid-toolbar-menu-icon" src="@ResolveToolbarIconSrc(childItem)" alt="@ResolveToolbarIconAlt(childItem)" />
                                    }
                                    else if (!string.IsNullOrWhiteSpace(ResolveToolbarGlyph(childItem)))
                                    {
                                        <span class="fx-treegrid-toolbar-menu-glyph" aria-hidden="true">@ResolveToolbarGlyph(childItem)</span>
                                    }
                                    <span>@ResolveToolbarMenuText(childItem)</span>
                                </button>
                            }
                        </div>
                    }
                </span>
                if (item.SeparatorAfter)
                {
                    <span class="fx-treegrid-toolbar-separator"></span>
                }
            }
        </div>
    }

    @* ── Collect column definitions ─────────────────────────────── *@
    <CascadingValue Value="@((ITreeGridControlOwner)this)" IsFixed="true">
        <div style="display:none">
            @ChildContent
        </div>
    </CascadingValue>

    @if (ShouldRenderColumnOptions && ShowGridOptionsRail)
    {
        <div class="fx-treegrid-options-rail">
            <button type="button"
                    class="fx-treegrid-options-button"
                    title="Columns"
                    aria-label="Columns"
                    @onclick="() => _treeColumnPanelOpen = !_treeColumnPanelOpen">
                ▦
            </button>
        </div>
    }

    @if (ShouldRenderColumnOptions && _treeColumnPanelOpen)
    {
        <div class="fx-treegrid-column-panel">
            <div class="fx-treegrid-column-panel-title">Columns</div>
            <TextBoxControl @bind-Value="_columnPanelSearch"
                            Width="100%"
                            CssClass="fx-treegrid-column-search"
                            Placeholder="Find column" />
            <div class="fx-treegrid-column-list">
                @foreach (var panelColumn in ColumnPanelColumns)
                {
                    <CheckBoxControl Checked="@IsColumnVisible(panelColumn)"
                                     CheckedChanged="@(value => SetColumnVisibleAsync(panelColumn, value))"
                                     Disabled="@(!CanHideColumn(panelColumn))"
                                     Label="@panelColumn.DisplayHeader"
                                     CssClass="fx-treegrid-column-toggle" />
                }
            </div>
        </div>
    }

    
    <div class="fx-treegrid-content">
        <table class="fx-treegrid-table">
            @if (ShowColumnHeaders)
            {
                <thead class="fx-treegrid-header">
                    <tr>
                        @foreach (var col in VisibleColumns)
                        {
                            var headerIconSrc = ResolveHeaderIconSrc(col);
                            <th class="@GetHeaderCellCss(col)"
                                style="@GetHeaderStyle(col)"
                                @onclick="() => HandleHeaderClickAsync(col)">
                                <span class="fx-treegrid-header-content">
                                    <span class="fx-treegrid-header-text">
                                        @if (col.HeaderTemplate is not null)
                                        {
                                            @col.HeaderTemplate
                                        }
                                        else
                                        {
                                            @col.DisplayHeader
                                        }
                                    </span>
                                    @if (col.HeaderIconVisible && !string.IsNullOrWhiteSpace(headerIconSrc))
                                    {
                                        <button class="@GetHeaderIconButtonCss(col)"
                                                type="button"
                                                title="@col.HeaderIconTitle"
                                                aria-label="@(!string.IsNullOrWhiteSpace(col.HeaderIconAlt) ? col.HeaderIconAlt : col.HeaderIconTitle)"
                                                @onclick="() => HandleHeaderIconClickAsync(col)"
                                                @onclick:stopPropagation="true">
                                            <img class="fx-treegrid-header-icon" src="@headerIconSrc" alt="@col.HeaderIconAlt" />
                                        </button>
                                    }
                                    @if (HasHeaderToolbar(col))
                                    {
                                        <span class="fx-treegrid-header-toolbar">
                                            @foreach (var headerToolbarItem in GetHeaderToolbarItems(col))
                                            {
                                                var item = ResolveToolbarItem(headerToolbarItem);
                                                if (item.SeparatorBefore)
                                                {
                                                    <span class="fx-treegrid-header-toolbar-separator"></span>
                                                }
                                                <span class="fx-treegrid-toolbar-shell">
                                                    <button type="button"
                                                            class="@GetHeaderToolbarButtonCss(item)"
                                                            disabled="@item.Disabled"
                                                            title="@ResolveToolbarTitle(item)"
                                                            aria-label="@ResolveToolbarAriaLabel(item)"
                                                            @onclick="() => HandleToolbarItemClickAsync(item, true, col)"
                                                            @onclick:stopPropagation="true">
                                                        @if (!string.IsNullOrWhiteSpace(ResolveToolbarIconSrc(item)))
                                                        {
                                                            <img class="fx-treegrid-header-toolbar-icon" src="@ResolveToolbarIconSrc(item)" alt="@ResolveToolbarIconAlt(item)" />
                                                        }
                                                        else if (!string.IsNullOrWhiteSpace(ResolveToolbarGlyph(item)))
                                                        {
                                                            <span class="fx-treegrid-header-toolbar-glyph" aria-hidden="true">@ResolveToolbarGlyph(item)</span>
                                                        }
                                                        @if (!string.IsNullOrWhiteSpace(item.Text))
                                                        {
                                                            <span class="fx-treegrid-header-toolbar-text">@item.Text</span>
                                                        }
                                                        @if (HasToolbarMenu(item))
                                                        {
                                                            <span class="fx-treegrid-toolbar-menu-arrow" aria-hidden="true">▾</span>
                                                        }
                                                    </button>
                                                    @if (IsToolbarMenuOpen(item, true, col))
                                                    {
                                                        <div class="fx-treegrid-toolbar-menu fx-treegrid-header-toolbar-menu" @onclick:stopPropagation="true">
                                                            @foreach (var child in GetVisibleToolbarChildren(item))
                                                            {
                                                                var childItem = ResolveToolbarItem(child);
                                                                <button type="button"
                                                                        class="fx-treegrid-toolbar-menu-item"
                                                                        disabled="@childItem.Disabled"
                                                                        @onclick="() => HandleToolbarMenuItemClickAsync(childItem, true, col)"
                                                                        @onclick:stopPropagation="true">
                                                                    @if (!string.IsNullOrWhiteSpace(ResolveToolbarIconSrc(childItem)))
                                                                    {
                                                                        <img class="fx-treegrid-toolbar-menu-icon" src="@ResolveToolbarIconSrc(childItem)" alt="@ResolveToolbarIconAlt(childItem)" />
                                                                    }
                                                                    else if (!string.IsNullOrWhiteSpace(ResolveToolbarGlyph(childItem)))
                                                                    {
                                                                        <span class="fx-treegrid-toolbar-menu-glyph" aria-hidden="true">@ResolveToolbarGlyph(childItem)</span>
                                                                    }
                                                                    <span>@ResolveToolbarMenuText(childItem)</span>
                                                                </button>
                                                            }
                                                        </div>
                                                    }
                                                </span>
                                                if (item.SeparatorAfter)
                                                {
                                                    <span class="fx-treegrid-header-toolbar-separator"></span>
                                                }
                                            }
                                        </span>
                                    }
                                    @if (AllowSorting && col.AllowSorting && !string.IsNullOrWhiteSpace(GetSortGlyph(col)))
                                    {
                                        <span class="fx-treegrid-sort-glyph" aria-hidden="true">@GetSortGlyph(col)</span>
                                    }
                                    @if (AllowFiltering && col.AllowFiltering && ShowHeaderFilterIcon && !string.IsNullOrWhiteSpace(col.Field))
                                    {
                                        <button type="button"
                                                class="fx-treegrid-filter-button @(GetColumnState(col).FilterActive ? "active" : "")"
                                                title="Filter"
                                                aria-label="Filter @col.DisplayHeader"
                                                @onclick="() => ToggleFilterPopup(col)"
                                                @onclick:stopPropagation="true">
                                            ⌕
                                        </button>
                                    }
                                </span>
                                @if (IsColumnFilterPopupOpen(col))
                                {
                                    <div class="fx-treegrid-filter-popup" @onclick:stopPropagation="true">
                                        <div class="fx-treegrid-filter-title">@col.DisplayHeader</div>
                                        <TextBoxControl @bind-Value="_filterDraft"
                                                        Width="100%"
                                                        CssClass="fx-treegrid-filter-input"
                                                        Placeholder="Contains" />
                                        <div class="fx-treegrid-filter-actions">
                                            <button type="button" @onclick="() => ApplyFilterAsync(col)">Apply</button>
                                            <button type="button" @onclick="() => ClearFilterAsync(col)">Clear</button>
                                        </div>
                                    </div>
                                }
                                @if (AllowResizing && col.AllowResizing)
                                {
                                    <span class="fx-treegrid-resize-handle"
                                          @onmousedown="e => StartColumnResize(col, e)"
                                          @onmousedown:stopPropagation="true"></span>
                                }
                            </th>
                        }
                    </tr>
                </thead>
            }
            <tbody class="fx-treegrid-body">
                @{ var rowIdx = 0; }
                @foreach (var node in VisibleNodes)
                {
                    var currentIdx = rowIdx;
                    var isSelected = AllowSelection && _selectedItem != null && EqualityComparer<TValue>.Default.Equals(node.Data, _selectedItem);

                    <tr class="fx-treegrid-row @(isSelected ? "fx-treegrid-selected" : "") @(EnableHover ? "fx-treegrid-hover" : "")"
                        style="@(IsCompact ? "height:14px;" : "")"
                        @onclick="() => HandleRowClick(node, currentIdx)"
                        @ondblclick="() => HandleRowDoubleClick(node, currentIdx)">

                        @{ var colIdx = 0; }
                        @foreach (var col in VisibleColumns)
                        {
                            <td class="fx-treegrid-cell" style="@GetCellStyle(col) @(IsCompact ? ";height:14px;padding:0 2px;line-height:14px;" : "")">
                                @if (colIdx == ResolvedTreeColumnIndex)
                                {
                                    
                                    @if (UseDottedTreeLines)
                                    {
                                        @for (var indentLevel = 0; indentLevel < node.Level; indentLevel++)
                                        {
                                            var isElbow = indentLevel == node.Level - 1;
                                            var continues = isElbow
                                                ? !node.IsLastSibling
                                                : node.AncestorLineContinuations.ElementAtOrDefault(indentLevel);

                                            <span class="fx-treegrid-indent-segment @(continues ? "continues" : "") @(isElbow ? "elbow" : "")"
                                                  style="width:@(IndentPerLevel)px; @(IsCompact ? "height:14px;" : "")"></span>
                                        }
                                    }
                                    else
                                    {
                                        <span style="display:inline-block; width:@(node.Level * IndentPerLevel)px; @(IsCompact ? "height:14px;" : "")"></span>
                                    }

                                    
                                    @if (node.HasChildren)
                                    {
                                        @if (ExpandIconTemplate != null)
                                        {
                                            @ExpandIconTemplate(node.IsExpanded)
                                        }
                                        else if (NodeExpandIconStyle == GroupExpandIconStyle.PlusMinus
                                                 || CollapsedGlyph != null || ExpandedGlyph != null)
                                        {
                                            
                                            <span class="fx-treegrid-expand-icon fx-treegrid-expand-icon-plusminus @(node.IsExpanded ? "expanded" : "collapsed")"
                                                  style="@ResolveExpandIconStyle() @(IsCompact ? ";height:10px;width:10px;line-height:10px;margin-right:2px;font-size:9px;" : "")"
                                                  @onclick="() => ToggleNode(node)"
                                                  @onclick:stopPropagation="true">
                                                @(node.IsExpanded ? ResolveExpandedGlyph() : ResolveCollapsedGlyph())
                                            </span>

                                            @if (GetNodeIcon != null)
                                            {
                                                var customIcon = GetNodeIcon(node.Data, node.IsExpanded);
                                                if (!string.IsNullOrEmpty(customIcon))
                                                {
                                                    <span class="fx-treegrid-node-folder" aria-hidden="true" style="@(IsCompact ? "width:14px;height:14px;margin-right:3px;vertical-align:middle;display:inline-flex;align-items:center;justify-content:center;" : "")">
                                                        <img class="fx-treegrid-icon" src="@customIcon" alt="" style="@(IsCompact ? "width:14px;height:14px;vertical-align:top;" : "")" />
                                                    </span>
                                                }
                                            }
                                            else if (UseTreeFolderIcons)
                                            {
                                                <span class="fx-treegrid-node-folder" aria-hidden="true" style="@(IsCompact ? "width:14px;height:14px;margin-right:3px;vertical-align:middle;display:inline-flex;align-items:center;justify-content:center;" : "")">
                                                    @if (UseYellowFolderIcons)
                                                    {
                                                        <img class="fx-treegrid-icon fx-treegrid-folder-image" src="@YellowFolderIconSrc" alt="" style="@(IsCompact ? "width:14px;height:14px;vertical-align:top;" : "")" />
                                                    }
                                                    else
                                                    {
                                                        <span class="fx-treegrid-folder-icon fx-treegrid-folder-icon-parent @(node.IsExpanded ? "open" : "closed")" style="@(IsCompact ? "width:14px;height:14px;flex:0 0 14px;" : "")"></span>
                                                    }
                                                </span>
                                            }
                                        }
                                        else
                                        {
                                            
                                            <span class="fx-treegrid-expand-icon @(node.IsExpanded ? "expanded" : "collapsed")"
                                                  style="@(IsCompact ? "height:14px;line-height:14px;margin-right:2px;" : "")"
                                                  @onclick="() => ToggleNode(node)"
                                                  @onclick:stopPropagation="true">
                                                @if (GetNodeIcon != null)
                                                {
                                                    var customIcon = GetNodeIcon(node.Data, node.IsExpanded);
                                                    if (!string.IsNullOrEmpty(customIcon))
                                                    {
                                                        <img class="fx-treegrid-icon" src="@customIcon" alt="" style="@(IsCompact ? "width:14px;height:14px;vertical-align:middle;" : "")" />
                                                    }
                                                }
                                                else if (UseYellowFolderIcons)
                                                {
                                                    <img class="fx-treegrid-icon fx-treegrid-folder-image" src="@YellowFolderIconSrc" alt="" style="@(IsCompact ? "width:14px;height:14px;vertical-align:middle;" : "")" />
                                                }
                                                else
                                                {
                                                    <img class="fx-treegrid-icon"
                                                         src="@(node.IsExpanded ? TreeOpenFolderIconSrc : TreeClosedFolderIconSrc)"
                                                         alt="" style="@(IsCompact ? "width:14px;height:14px;vertical-align:middle;" : "")" />
                                                }
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        @if (LeafIconTemplate != null)
                                        {
                                            @LeafIconTemplate
                                        }
                                        else if (LeafGlyph != null)
                                        {
                                            <span class="fx-treegrid-expand-icon fx-treegrid-leaf-icon"
                                                  style="@ResolveLeafIconStyle() @(IsCompact ? ";height:10px;width:10px;margin-right:2px;" : "")">@LeafGlyph</span>
                                        }
                                        else if (NodeExpandIconStyle == GroupExpandIconStyle.PlusMinus)
                                        {
                                            
                                            <span class="fx-treegrid-expand-icon fx-treegrid-leaf-icon fx-treegrid-leaf-plusminus"
                                                  style="@ResolveLeafIconStyle() @(IsCompact ? ";height:10px;width:10px;margin-right:2px;" : "")"></span>

                                            @if (ShowLeafNodeIcons && GetNodeIcon != null)
                                            {
                                                var customIcon = GetNodeIcon(node.Data, false);
                                                if (!string.IsNullOrEmpty(customIcon))
                                                {
                                                    <span class="fx-treegrid-node-folder" aria-hidden="true" style="@(IsCompact ? "width:14px;height:14px;margin-right:3px;vertical-align:middle;display:inline-flex;align-items:center;justify-content:center;" : "")">
                                                        <img class="fx-treegrid-icon" src="@customIcon" alt="" style="@(IsCompact ? "width:14px;height:14px;vertical-align:top;" : "")" />
                                                    </span>
                                                }
                                            }
                                            else if (ShowLeafNodeIcons && UseTreeFolderIcons)
                                            {
                                                <span class="fx-treegrid-node-folder" aria-hidden="true" style="@(IsCompact ? "width:14px;height:14px;margin-right:3px;vertical-align:middle;display:inline-flex;align-items:center;justify-content:center;" : "")">
                                                    @if (UseYellowFolderIcons)
                                                    {
                                                        <img class="fx-treegrid-icon fx-treegrid-folder-image" src="@YellowFolderIconSrc" alt="" style="@(IsCompact ? "width:14px;height:14px;vertical-align:top;" : "")" />
                                                    }
                                                    else
                                                    {
                                                        <span class="fx-treegrid-folder-icon fx-treegrid-folder-icon-leaf closed" style="@(IsCompact ? "width:14px;height:14px;flex:0 0 14px;" : "")"></span>
                                                    }
                                                </span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="fx-treegrid-expand-icon fx-treegrid-leaf-icon" style="@(IsCompact ? "height:14px;line-height:14px;margin-right:2px;" : "")">
                                                @if (ShowLeafNodeIcons && GetNodeIcon != null)
                                                {
                                                    var customIcon = GetNodeIcon(node.Data, false);
                                                    if (!string.IsNullOrEmpty(customIcon))
                                                    {
                                                        <img class="fx-treegrid-icon" src="@customIcon" alt="" style="@(IsCompact ? "width:14px;height:14px;vertical-align:middle;" : "")" />
                                                    }
                                                }
                                                else if (ShowLeafNodeIcons && UseYellowFolderIcons)
                                                {
                                                    <img class="fx-treegrid-icon fx-treegrid-folder-image" src="@YellowFolderIconSrc" alt="" style="@(IsCompact ? "width:14px;height:14px;vertical-align:middle;" : "")" />
                                                }
                                                else if (ShowLeafNodeIcons)
                                                {
                                                    <img class="fx-treegrid-icon" src="@TreeClosedFolderIconSrc" alt="" style="@(IsCompact ? "width:14px;height:14px;vertical-align:middle;" : "")" />
                                                }
                                            </span>
                                        }
                                    }

                                    @if (col.Template != null)
                                    {
                                        @col.Template((object)node.Data!)
                                    }
                                    else
                                    {
                                        <span class="fx-treegrid-cell-text @(node.HasChildren ? "fx-treegrid-parent-text" : "")">
                                            @GetCellDisplayValue(node.Data, col)
                                        </span>
                                    }
                                }
                                else
                                {
                                    @if (col.Template != null)
                                    {
                                        @col.Template((object)node.Data!)
                                    }
                                    else
                                    {
                                        @GetCellDisplayValue(node.Data, col)
                                    }
                                }
                            </td>
                            colIdx++;
                        }
                    </tr>
                    rowIdx++;
                }

                @if (!VisibleNodes.Any())
                {
                    <tr>
                        <td colspan="@VisibleColumns.Count" class="fx-treegrid-empty">
                            No records to display
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
