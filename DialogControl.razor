@namespace Fx.ControlKit
@using Microsoft.AspNetCore.Components.Web

@if (Visible)
{
    <div class="@OverlayCssClass"
         @onclick="HandleOverlayClick"
         @onmousemove="HandleOverlayMouseMove"
         @onmouseup="e => HandleOverlayMouseUp(e, true)"
         @onmouseleave="e => HandleOverlayMouseUp(e, false)"
         tabindex="0"
         @onkeydown="HandleKeyDown">
        <div class="@DialogCssClass" style="@DialogStyle" @onclick:stopPropagation="true">
            <div class="fx-dialog-header"
                 @onmousedown="HandleDragStart"
                 @onmousedown:preventDefault="true"
                 @onmousedown:stopPropagation="true"
                 @oncontextmenu="HandleHeaderContextMenu"
                 @oncontextmenu:preventDefault="true"
                 @oncontextmenu:stopPropagation="true">
                @if (ShowWindowIcon)
                {
                    <button class="fx-dialog-window-icon"
                            type="button"
                            title="Window menu"
                            aria-label="Window menu"
                            @onmousedown:preventDefault="true"
                            @onmousedown:stopPropagation="true"
                            @onclick="HandleWindowIconClick"
                            @onclick:stopPropagation="true"></button>
                }
                <span class="fx-dialog-title">@Header</span>
                @if (ShowCloseIcon)
                {
                    <button class="fx-dialog-close"
                            type="button"
                            title="Close"
                            aria-label="Close"
                            @onmousedown:stopPropagation="true"
                            @onclick="HandleClose">×</button>
                }
            </div>
            <div class="fx-dialog-body">
                @ChildContent
            </div>
            @if (FooterContent != null)
            {
                <div class="fx-dialog-footer">
                    @FooterContent
                </div>
            }
            @if (Resizable)
            {
                <span class="fx-dialog-resize-handle fx-dialog-resize-n" @onmousedown='e => HandleResizeStart("n", e)' @onmousedown:preventDefault="true" @onmousedown:stopPropagation="true"></span>
                <span class="fx-dialog-resize-handle fx-dialog-resize-e" @onmousedown='e => HandleResizeStart("e", e)' @onmousedown:preventDefault="true" @onmousedown:stopPropagation="true"></span>
                <span class="fx-dialog-resize-handle fx-dialog-resize-s" @onmousedown='e => HandleResizeStart("s", e)' @onmousedown:preventDefault="true" @onmousedown:stopPropagation="true"></span>
                <span class="fx-dialog-resize-handle fx-dialog-resize-w" @onmousedown='e => HandleResizeStart("w", e)' @onmousedown:preventDefault="true" @onmousedown:stopPropagation="true"></span>
                <span class="fx-dialog-resize-handle fx-dialog-resize-ne" @onmousedown='e => HandleResizeStart("ne", e)' @onmousedown:preventDefault="true" @onmousedown:stopPropagation="true"></span>
                <span class="fx-dialog-resize-handle fx-dialog-resize-se" @onmousedown='e => HandleResizeStart("se", e)' @onmousedown:preventDefault="true" @onmousedown:stopPropagation="true"></span>
                <span class="fx-dialog-resize-handle fx-dialog-resize-sw" @onmousedown='e => HandleResizeStart("sw", e)' @onmousedown:preventDefault="true" @onmousedown:stopPropagation="true"></span>
                <span class="fx-dialog-resize-handle fx-dialog-resize-nw" @onmousedown='e => HandleResizeStart("nw", e)' @onmousedown:preventDefault="true" @onmousedown:stopPropagation="true"></span>
            }
        </div>
        @if (_systemMenuVisible)
        {
            <div class="fx-dialog-system-menu-backdrop"
                 @onclick="CloseSystemMenu"
                 @onclick:stopPropagation="true"
                 @oncontextmenu="CloseSystemMenu"
                 @oncontextmenu:preventDefault="true"
                 @oncontextmenu:stopPropagation="true"></div>
            <div class="fx-dialog-system-menu"
                 style="@SystemMenuStyle"
                 role="menu"
                 @onclick:stopPropagation="true"
                 @oncontextmenu:stopPropagation="true">
                <button type="button" role="menuitem" disabled>Restore</button>
                <button type="button" role="menuitem" @onclick="CloseSystemMenu">Move</button>
                <button type="button" role="menuitem" disabled="@(!Resizable)" @onclick="CloseSystemMenu">Size</button>
                <button type="button" role="menuitem" disabled>Minimize</button>
                <button type="button" role="menuitem" disabled>Maximize</button>
                <span class="fx-dialog-system-menu-separator"></span>
                <button type="button" role="menuitem" class="fx-dialog-system-menu-close" @onclick="HandleSystemMenuClose">
                    <span class="fx-dialog-system-menu-close-label">
                        <span class="fx-dialog-system-menu-close-icon" aria-hidden="true">×</span>
                        <span>Close</span>
                    </span>
                    <span>Alt+F4</span>
                </button>
            </div>
        }
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public string? Header { get; set; }
    [Parameter] public string? Width { get; set; }
    [Parameter] public string? Height { get; set; }
    [Parameter] public bool IsModal { get; set; } = true;
    [Parameter] public bool ShowCloseIcon { get; set; } = true;
    [Parameter] public bool CloseOnEscape { get; set; }
    [Parameter] public bool CloseOnOverlayClick { get; set; }
    [Parameter] public bool Draggable { get; set; } = true;
    [Parameter] public bool ShowSystemMenu { get; set; } = true;
    [Parameter] public bool ShowWindowIcon { get; set; }
    [Parameter] public bool Resizable { get; set; } = true;
    [Parameter] public double MinResizeWidth { get; set; } = 320;
    [Parameter] public double MinResizeHeight { get; set; } = 160;
    [Parameter] public double MaxResizeWidth { get; set; }
    [Parameter] public double MaxResizeHeight { get; set; }
    [Parameter] public string? CssClass { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? FooterContent { get; set; }

    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback Closed { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public EventCallback<string?> WidthChanged { get; set; }
    [Parameter] public EventCallback<string?> HeightChanged { get; set; }

    private bool _isResizing;
    private string? _resizeEdge;
    private double _resizeStartX;
    private double _resizeStartY;
    private double _resizeStartWidth;
    private double _resizeStartHeight;
    private double? _runtimeWidth;
    private double? _runtimeHeight;
    private bool _suppressNextOverlayClick;
    private bool _isDragging;
    private double _dragStartX;
    private double _dragStartY;
    private double _dragStartOffsetX;
    private double _dragStartOffsetY;
    private double _dialogOffsetX;
    private double _dialogOffsetY;
    private bool _systemMenuVisible;
    private double _systemMenuX;
    private double _systemMenuY;

    private string OverlayCssClass
    {
        get
        {
            var cls = "fx-dialog-overlay";
            if (_isResizing || _isDragging)
                cls += " fx-dialog-overlay-resizing";
            if (!IsModal)
                cls += " fx-dialog-overlay-nonmodal";
            return cls;
        }
    }

    private string DialogCssClass
    {
        get
        {
            var parts = new List<string> { "fx-dialog" };
            if (Resizable)
                parts.Add("fx-dialog-resizable");
            if (Draggable)
                parts.Add("fx-dialog-draggable");
            if (_isDragging)
                parts.Add("fx-dialog-dragging");
            if (!string.IsNullOrWhiteSpace(CssClass))
                parts.Add(CssClass);
            return string.Join(" ", parts);
        }
    }

    private string DialogStyle
    {
        get
        {
            var parts = new List<string>();

            if (_runtimeWidth.HasValue)
                parts.Add($"width:{_runtimeWidth.Value:0.##}px");
            else if (!string.IsNullOrWhiteSpace(Width))
                parts.Add($"width:{Width}");

            if (_runtimeHeight.HasValue)
                parts.Add($"height:{_runtimeHeight.Value:0.##}px");
            else if (!string.IsNullOrWhiteSpace(Height))
                parts.Add($"height:{Height}");

            if (_dialogOffsetX != 0 || _dialogOffsetY != 0)
                parts.Add($"transform:translate({_dialogOffsetX:0.##}px,{_dialogOffsetY:0.##}px)");

            return string.Join(";", parts);
        }
    }

    private string SystemMenuStyle =>
        $"left:{_systemMenuX:0.##}px;top:{_systemMenuY:0.##}px";

    private async Task HandleOverlayClick()
    {
        if (_systemMenuVisible)
        {
            _systemMenuVisible = false;
            return;
        }

        if (_suppressNextOverlayClick)
        {
            _suppressNextOverlayClick = false;
            return;
        }

        if (_isResizing)
            return;

        if (!CloseOnOverlayClick)
            return;

        await RequestClose();
    }

    private async Task HandleClose()
    {
        _systemMenuVisible = false;
        await RequestClose();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.AltKey && string.Equals(e.Key, "F4", StringComparison.OrdinalIgnoreCase))
        {
            _systemMenuVisible = false;
            await RequestClose();
            return;
        }

        if (CloseOnEscape && e.Key == "Escape")
        {
            await RequestClose();
        }
    }

    private Task HandleOverlayMouseMove(MouseEventArgs e)
    {
        if (_isDragging)
        {
            _dialogOffsetX = _dragStartOffsetX + e.ClientX - _dragStartX;
            _dialogOffsetY = _dragStartOffsetY + e.ClientY - _dragStartY;
            return Task.CompletedTask;
        }

        return HandleResizeMove(e);
    }

    private async Task HandleOverlayMouseUp(MouseEventArgs e, bool suppressOverlayClick)
    {
        if (_isDragging)
        {
            _isDragging = false;
            if (suppressOverlayClick)
                _suppressNextOverlayClick = true;
            return;
        }

        await HandleResizeEnd(e, suppressOverlayClick);
    }

    private Task HandleDragStart(MouseEventArgs e)
    {
        if (!Draggable || e.Button != 0)
            return Task.CompletedTask;

        _systemMenuVisible = false;
        _isDragging = true;
        _dragStartX = e.ClientX;
        _dragStartY = e.ClientY;
        _dragStartOffsetX = _dialogOffsetX;
        _dragStartOffsetY = _dialogOffsetY;
        return Task.CompletedTask;
    }

    private Task HandleHeaderContextMenu(MouseEventArgs e)
        => OpenSystemMenuAt(e.ClientX, e.ClientY);

    private Task HandleWindowIconClick(MouseEventArgs e)
        => OpenSystemMenuAt(e.ClientX, e.ClientY);

    private Task OpenSystemMenuAt(double x, double y)
    {
        if (!ShowSystemMenu)
            return Task.CompletedTask;

        _systemMenuVisible = true;
        _systemMenuX = x;
        _systemMenuY = y;
        return Task.CompletedTask;
    }

    private Task CloseSystemMenu()
    {
        _systemMenuVisible = false;
        return Task.CompletedTask;
    }

    private async Task HandleSystemMenuClose()
    {
        _systemMenuVisible = false;
        await RequestClose();
    }

    private Task HandleResizeStart(string edge, MouseEventArgs e)
    {
        if (!Resizable)
            return Task.CompletedTask;

        _systemMenuVisible = false;
        _isDragging = false;
        _isResizing = true;
        _resizeEdge = edge;
        _resizeStartX = e.ClientX;
        _resizeStartY = e.ClientY;
        _resizeStartWidth = ResolveCurrentWidth();
        _resizeStartHeight = ResolveCurrentHeight();
        return Task.CompletedTask;
    }

    private Task HandleResizeMove(MouseEventArgs e)
    {
        if (!_isResizing || string.IsNullOrWhiteSpace(_resizeEdge))
            return Task.CompletedTask;

        var dx = e.ClientX - _resizeStartX;
        var dy = e.ClientY - _resizeStartY;
        var width = _resizeStartWidth;
        var height = _resizeStartHeight;

        if (_resizeEdge.Contains('e'))
            width += dx;
        if (_resizeEdge.Contains('w'))
            width -= dx;
        if (_resizeEdge.Contains('s'))
            height += dy;
        if (_resizeEdge.Contains('n'))
            height -= dy;

        _runtimeWidth = ClampResize(width, MinResizeWidth, MaxResizeWidth);
        _runtimeHeight = ClampResize(height, MinResizeHeight, MaxResizeHeight);
        return Task.CompletedTask;
    }

    private async Task HandleResizeEnd(MouseEventArgs e, bool suppressOverlayClick)
    {
        if (!_isResizing) return;
        _isResizing = false;
        _resizeEdge = null;
        if (suppressOverlayClick)
            _suppressNextOverlayClick = true;

        if (_runtimeWidth.HasValue)
        {
            var newWidth = $"{_runtimeWidth.Value:0.##}px";
            Width = newWidth;
            if (WidthChanged.HasDelegate)
                await WidthChanged.InvokeAsync(newWidth);
        }
        if (_runtimeHeight.HasValue)
        {
            var newHeight = $"{_runtimeHeight.Value:0.##}px";
            Height = newHeight;
            if (HeightChanged.HasDelegate)
                await HeightChanged.InvokeAsync(newHeight);
        }
    }

    private bool _lastVisible;

    protected override void OnParametersSet()
    {
        if (Visible && !_lastVisible)
        {
            _runtimeWidth = null;
            _runtimeHeight = null;
            _dialogOffsetX = 0;
            _dialogOffsetY = 0;
            _systemMenuVisible = false;
            _isDragging = false;
            _isResizing = false;
        }
        _lastVisible = Visible;
    }

    private double ResolveCurrentWidth()
    {
        return _runtimeWidth ?? TryParsePixelValue(Width) ?? 640;
    }

    private double ResolveCurrentHeight()
    {
        return _runtimeHeight ?? TryParsePixelValue(Height) ?? 360;
    }

    private static double? TryParsePixelValue(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        var trimmed = value.Trim();
        if (!trimmed.EndsWith("px", StringComparison.OrdinalIgnoreCase))
            return null;

        return double.TryParse(trimmed[..^2], out var pixels) ? pixels : null;
    }

    private static double ClampResize(double value, double minimum, double maximum)
    {
        var clamped = Math.Max(minimum, value);
        if (maximum > 0)
            clamped = Math.Min(maximum, clamped);
        return clamped;
    }

    private async Task RequestClose()
    {
        if (OnClose.HasDelegate)
            await OnClose.InvokeAsync();
        if (Closed.HasDelegate)
            await Closed.InvokeAsync();
        if (VisibleChanged.HasDelegate)
            await VisibleChanged.InvokeAsync(false);
    }
}
