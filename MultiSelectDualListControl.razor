@namespace Fx.ControlKit
@typeparam TItem

@*
    Multi-Select Dual List Control
    -------------------------------
    A two-pane "shuttle" control imitating the VB6 Reports parameter screen:

        [ Available items ]   [ > ]   [ Selected items ]
                              [ >> ]
                              [ <  ]
                              [ << ]

    Buttons:
      >   Move single highlighted item from Available  -> Selected
      >>  Move ALL items from Available -> Selected
      <   Move single highlighted item from Selected   -> Available
      <<  Move ALL items from Selected -> Available

    Public API:
      - SelectedItems  (two-way bindable IList<TItem>)
      - SelectedItemsChanged (EventCallback)
      - GetSelected()  (programmatic accessor)

    Reflection-style field selectors (TextField / ValueField) match the convention
    used by the other FlexCore list controls.
*@

<div class="fx-dual-list @CssClass" style="@RootStyle">
    <div class="fx-dual-pane">
        @if (!string.IsNullOrEmpty(LeftHeader))
        {
            <div class="fx-dual-header">@LeftHeader</div>
        }
        <select class="fx-dual-select"
                multiple
                size="@VisibleRows"
                style="@PaneStyle"
                @onchange="OnLeftSelectionChanged"
                @ondblclick="MoveSelectedRight">
            @foreach (var item in _availableItems)
            {
                var key = ResolveKey(item);
                var label = ResolveLabel(item);
                var sel = _leftHighlighted.Contains(key);
                <option value="@key" selected="@sel">@label</option>
            }
        </select>
        <div class="fx-dual-meta">@_availableItems.Count item(s)</div>
    </div>

    <div class="fx-dual-buttons">
        <button type="button" class="fx-dual-btn"
                title="Move selected"
                disabled="@(_availableItems.Count == 0)"
                @onclick="MoveSelectedRight">&gt;</button>
        <button type="button" class="fx-dual-btn"
                title="Move all"
                disabled="@(_availableItems.Count == 0)"
                @onclick="MoveAllRight">&gt;&gt;</button>
        <button type="button" class="fx-dual-btn"
                title="Remove selected"
                disabled="@(_selectedItems.Count == 0)"
                @onclick="MoveSelectedLeft">&lt;</button>
        <button type="button" class="fx-dual-btn"
                title="Remove all"
                disabled="@(_selectedItems.Count == 0)"
                @onclick="MoveAllLeft">&lt;&lt;</button>
    </div>

    <div class="fx-dual-pane">
        @if (!string.IsNullOrEmpty(RightHeader))
        {
            <div class="fx-dual-header">@RightHeader</div>
        }
        <select class="fx-dual-select"
                multiple
                size="@VisibleRows"
                style="@PaneStyle"
                @onchange="OnRightSelectionChanged"
                @ondblclick="MoveSelectedLeft">
            @foreach (var item in _selectedItems)
            {
                var key = ResolveKey(item);
                var label = ResolveLabel(item);
                var sel = _rightHighlighted.Contains(key);
                <option value="@key" selected="@sel">@label</option>
            }
        </select>
        <div class="fx-dual-meta">@_selectedItems.Count selected</div>
    </div>
</div>

@code {

    [Parameter] public IEnumerable<TItem>? Items { get; set; }

    [Parameter] public IList<TItem> SelectedItems { get; set; } = new List<TItem>();

    [Parameter] public EventCallback<IList<TItem>> SelectedItemsChanged { get; set; }

    [Parameter] public string? TextField { get; set; }

    [Parameter] public string? ValueField { get; set; }

    [Parameter] public Func<TItem, string>? LabelSelector { get; set; }

    [Parameter] public Func<TItem, string>? KeySelector { get; set; }

    [Parameter] public string? LeftHeader { get; set; } = "Available";

    [Parameter] public string? RightHeader { get; set; } = "Selected";

    [Parameter] public int VisibleRows { get; set; } = 10;

    [Parameter] public string? PaneWidth { get; set; }

    [Parameter] public string? Height { get; set; }

    [Parameter] public string? CssClass { get; set; }

    private List<TItem> _availableItems = new();
    private List<TItem> _selectedItems = new();
    private HashSet<string> _leftHighlighted = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _rightHighlighted = new(StringComparer.OrdinalIgnoreCase);

    private object? _lastItemsRef;
    private object? _lastSelectedRef;

    protected override void OnParametersSet()
    {
        var itemsChanged = !ReferenceEquals(Items, _lastItemsRef);
        var selectedChanged = !ReferenceEquals(SelectedItems, _lastSelectedRef);

        if (itemsChanged || selectedChanged)
        {
            var allItems = (Items ?? Enumerable.Empty<TItem>()).ToList();
            var selected = (SelectedItems ?? new List<TItem>()).ToList();

            var selectedKeys = new HashSet<string>(selected.Select(ResolveKey),
                StringComparer.OrdinalIgnoreCase);

            _selectedItems = selected;
            _availableItems = allItems
                .Where(i => !selectedKeys.Contains(ResolveKey(i)))
                .ToList();

            _lastItemsRef = Items;
            _lastSelectedRef = SelectedItems;
        }
    }

    private string ResolveKey(TItem item)
    {
        if (item is null) return string.Empty;
        if (KeySelector != null) return KeySelector(item) ?? string.Empty;
        if (!string.IsNullOrEmpty(ValueField))
            return GetPropertyString(item, ValueField);
        if (!string.IsNullOrEmpty(TextField))
            return GetPropertyString(item, TextField);
        return item.ToString() ?? string.Empty;
    }

    private string ResolveLabel(TItem item)
    {
        if (item is null) return string.Empty;
        if (LabelSelector != null) return LabelSelector(item) ?? string.Empty;
        if (!string.IsNullOrEmpty(TextField))
            return GetPropertyString(item, TextField);
        return item.ToString() ?? string.Empty;
    }

    private static string GetPropertyString(TItem item, string propName)
    {
        if (item is null) return string.Empty;
        var prop = item.GetType().GetProperty(propName);
        if (prop == null) return string.Empty;
        var v = prop.GetValue(item);
        return v?.ToString() ?? string.Empty;
    }

    private string RootStyle =>
        string.IsNullOrEmpty(Height) ? string.Empty : $"height:{Height};";

    private string PaneStyle =>
        string.IsNullOrEmpty(PaneWidth) ? string.Empty : $"width:{PaneWidth};";

    private void OnLeftSelectionChanged(ChangeEventArgs e)
    {
        _leftHighlighted = ExtractKeys(e.Value);
    }

    private void OnRightSelectionChanged(ChangeEventArgs e)
    {
        _rightHighlighted = ExtractKeys(e.Value);
    }

    private static HashSet<string> ExtractKeys(object? raw)
    {
        var set = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        if (raw is string[] arr)
        {
            foreach (var v in arr) if (!string.IsNullOrEmpty(v)) set.Add(v);
        }
        else if (raw is IEnumerable<string> en)
        {
            foreach (var v in en) if (!string.IsNullOrEmpty(v)) set.Add(v);
        }
        else if (raw is string s && !string.IsNullOrEmpty(s))
        {
            set.Add(s);
        }
        return set;
    }

    private async Task MoveSelectedRight()
    {
        if (_leftHighlighted.Count == 0) return;
        var moving = _availableItems.Where(i => _leftHighlighted.Contains(ResolveKey(i))).ToList();
        if (moving.Count == 0) return;

        foreach (var m in moving)
        {
            _availableItems.Remove(m);
            _selectedItems.Add(m);
        }
        _leftHighlighted.Clear();
        await NotifyChanged();
    }

    private async Task MoveAllRight()
    {
        if (_availableItems.Count == 0) return;
        _selectedItems.AddRange(_availableItems);
        _availableItems.Clear();
        _leftHighlighted.Clear();
        await NotifyChanged();
    }

    private async Task MoveSelectedLeft()
    {
        if (_rightHighlighted.Count == 0) return;
        var moving = _selectedItems.Where(i => _rightHighlighted.Contains(ResolveKey(i))).ToList();
        if (moving.Count == 0) return;

        foreach (var m in moving)
        {
            _selectedItems.Remove(m);
            _availableItems.Add(m);
        }
        _rightHighlighted.Clear();
        await NotifyChanged();
    }

    private async Task MoveAllLeft()
    {
        if (_selectedItems.Count == 0) return;
        _availableItems.AddRange(_selectedItems);
        _selectedItems.Clear();
        _rightHighlighted.Clear();
        await NotifyChanged();
    }

    private async Task NotifyChanged()
    {
        var snapshot = _selectedItems.ToList();
        SelectedItems = snapshot;
        _lastSelectedRef = snapshot;
        if (SelectedItemsChanged.HasDelegate)
            await SelectedItemsChanged.InvokeAsync(snapshot);
        StateHasChanged();
    }

    public IReadOnlyList<TItem> GetSelected() => _selectedItems.ToList();

    public IReadOnlyList<TItem> GetAvailable() => _availableItems.ToList();

    public IReadOnlyList<string> GetSelectedKeys() => _selectedItems.Select(ResolveKey).ToList();
}
