@namespace Fx.ControlKit.Editor

@* Editor-flavoured dropdown. Sits alongside the generic DropDownListControl
   but trades its reflection-based TextFieldName/ValueFieldName for a direct
   record-typed <see cref="EditorDropDownOption"/> list. That makes it
   natural to use with in-place option tables (font families, page widths,
   line heights, chapter lists, …) without needing intermediate DTO classes.

   Emits a plain <select> so every GhostWriter-style <option> attribute
   (selected, disabled, value) works. Supports BareStyle — when true, the
   library's .fx-dropdown class is suppressed so the host drives visuals
   entirely via CssClass. *@

<select class="@ResolvedCssClass"
        style="@Style"
        disabled="@(!Enabled)"
        value="@Value"
        @onchange="HandleChangeAsync">
    @if (!string.IsNullOrWhiteSpace(Placeholder))
    {
        <option value="" disabled selected="@string.IsNullOrEmpty(Value)">@Placeholder</option>
    }
    @if (Options is not null)
    {
        foreach (var opt in Options)
        {
            <option value="@opt.Value" selected="@(string.Equals(opt.Value, Value, StringComparison.Ordinal))">@opt.Label</option>
        }
    }
</select>

@code {
    public sealed record EditorDropDownOption(string Value, string Label);

    [Parameter] public IEnumerable<EditorDropDownOption>? Options { get; set; }

    [Parameter] public string? Value { get; set; }

    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public string? Style { get; set; }

    [Parameter] public bool Enabled { get; set; } = true;

    [Parameter] public bool BareStyle { get; set; }

    private string ResolvedCssClass
    {
        get
        {
            var c = (CssClass ?? string.Empty).Trim();
            if (BareStyle) return c;
            return string.IsNullOrEmpty(c) ? "fx-dropdown" : $"fx-dropdown {c}";
        }
    }

    private async Task HandleChangeAsync(ChangeEventArgs e)
    {
        var next = e.Value?.ToString() ?? string.Empty;
        Value = next;
        if (ValueChanged.HasDelegate) await ValueChanged.InvokeAsync(next);
    }
}
