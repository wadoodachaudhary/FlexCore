@namespace Fx.ControlKit

@* A button inside a RibbonGroup. *@

<button class="fx-ribbon-button @(Large ? "fx-ribbon-button-large" : "") @(Disabled ? "disabled" : "") @CssClass"
        type="button"
        disabled="@Disabled"
        title="@(string.IsNullOrWhiteSpace(Tooltip) ? Text : Tooltip)"
        @onclick="OnClick">
    @if (!string.IsNullOrWhiteSpace(Icon))
    {
        <span class="fx-ribbon-button-icon">@Icon</span>
    }
    <span class="fx-ribbon-button-text">@Text</span>
</button>

@code {
    [Parameter] public string Text { get; set; } = "";

    [Parameter] public string Icon { get; set; } = "";

    [Parameter] public string Tooltip { get; set; } = "";

    [Parameter] public bool Large { get; set; }

    [Parameter] public bool Disabled { get; set; }

    [Parameter] public string CssClass { get; set; } = "";

    [Parameter] public EventCallback OnClick { get; set; }
}
