@namespace Fx.ControlKit.Mdi
@using Microsoft.AspNetCore.Components

@*
   Fx.ControlKit.Mdi.MdiHost — tab-strip MDI shell that hosts a list of
   child Blazor components (one per open "window") and renders only the
   active one as visible. Inactive panes stay mounted with display:none
   so each child preserves its in-memory state (form fields, grid scroll
   position, edits-in-progress) across tab switches.

   This is a "dumb" presentation control — it doesn't decide WHEN a
   window opens or closes. The consumer (e.g. HomeFront's FMain) owns
   the Windows list, raises OpenOrFocus calls itself, and reacts to the
   OnActivate / OnCloseRequested events the host emits. MdiPane captures
   each child component instance so the consumer can call optional close
   guards before it removes a tab.

   Per-window SetPageTitle: each pane is wrapped in a CascadingValue
   exposing a Name="SetPageTitle" Action<string?>. A child component
   that does `[CascadingParameter(Name="SetPageTitle")] Action<string?>?
   SetPageTitle` and calls SetPageTitle("…") will update ITS own tab's
   title — the closure captures the right MdiWindow instance per pane.

   Why the visible-pane CSS toggle instead of @if:
     @if would unmount inactive panes → kills grid state, edits, drafts.
     display:none keeps the Blazor component instance alive; Blazor
     doesn't re-render an inactive subtree because its parameters don't
     change. Trade-off: a tab with a 500-row grid keeps consuming memory
     while hidden. Acceptable for typical session sizes (~5-15 tabs);
     LRU eviction is a Phase-4 concern.
*@

@{
    var homeActive = ActiveWindowId == null
        || !Windows.Any(w => string.Equals(w.Id, ActiveWindowId, StringComparison.Ordinal));
}

<div class="fx-mdi">
    <div class="fx-mdi-tabs">
        @if (HomeTab != null)
        {
            
            <div class="fx-mdi-tab fx-mdi-tab-home @(homeActive ? "active" : "")"
                 @onclick="OnHomeClick"
                 title="Home">
                @HomeTab
            </div>
        }
        @foreach (var w in Windows)
        {
            var win = w;  // capture per-iteration for the close-button closure
            <div class="fx-mdi-tab @(string.Equals(win.Id, ActiveWindowId, StringComparison.Ordinal) ? "active" : "")"
                 @onclick="() => OnTabClick(win.Id)"
                 title="@win.Title">
                <span class="fx-mdi-tab-title">@win.Title</span>
                <button class="fx-mdi-tab-close"
                        type="button"
                        title="Close"
                        @onclick:stopPropagation="true"
                        @onclick="() => OnCloseClick(win.Id)">×</button>
            </div>
        }
    </div>
    <div class="fx-mdi-panes">
        @foreach (var w in Windows)
        {
            var win = w;  // capture for the per-tab SetPageTitle closure
            var paneVisible = string.Equals(win.Id, ActiveWindowId, StringComparison.Ordinal);
            
            <CascadingValue Name="SetPageTitle"
                            Value="@(BuildTitleSetter(win))"
                            IsFixed="true">
                <div class="fx-mdi-pane" style="@(paneVisible ? "" : "display:none;")">
                    <MdiPane @key="win.Id" Window="win"
                             OnError="@(w => OnWindowError.InvokeAsync(w))"
                             OnCloseRequested="@(w => OnCloseRequested.InvokeAsync(w.Id))" />
                </div>
            </CascadingValue>
        }
        
        @if (homeActive && EmptyState != null)
        {
            <div class="fx-mdi-empty">@EmptyState</div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<MdiWindow> Windows { get; set; } = Array.Empty<MdiWindow>();

    [Parameter] public string? ActiveWindowId { get; set; }

    [Parameter] public EventCallback<string> OnActivate { get; set; }

    [Parameter] public EventCallback<string> OnCloseRequested { get; set; }

    [Parameter] public EventCallback<MdiWindow> OnWindowError { get; set; }

    [Parameter] public RenderFragment? EmptyState { get; set; }

    [Parameter] public RenderFragment? HomeTab { get; set; }

    [Parameter] public EventCallback OnHomeRequested { get; set; }

    private async Task OnTabClick(string id)
    {
        if (string.Equals(id, ActiveWindowId, StringComparison.Ordinal)) return;
        if (OnActivate.HasDelegate)
            await OnActivate.InvokeAsync(id);
    }

    private async Task OnCloseClick(string id)
    {
        if (OnCloseRequested.HasDelegate)
            await OnCloseRequested.InvokeAsync(id);
    }

    private async Task OnHomeClick()
    {
        var alreadyHome = ActiveWindowId == null
            || !Windows.Any(w => string.Equals(w.Id, ActiveWindowId, StringComparison.Ordinal));
        if (alreadyHome) return;
        if (OnHomeRequested.HasDelegate)
            await OnHomeRequested.InvokeAsync();
    }

    private Action<string?> BuildTitleSetter(MdiWindow w) => title =>
    {
        var newTitle = title ?? "";
        if (string.Equals(w.Title, newTitle, StringComparison.Ordinal)) return;
        w.Title = newTitle;
        InvokeAsync(StateHasChanged);
    };
}
