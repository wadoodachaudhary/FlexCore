@namespace Fx.ControlKit

@if (DropDownContent is null)
{
    @* Default button — unchanged from before (existing consumers are unaffected). *@
    <button class="@ResolvedCssClass"
            @ref="_buttonElement"
            type="@ButtonType"
            disabled="@Disabled"
            title="@Title"
            tabindex="@TabIndex"
            style="@Style"
            @onclick="OnClick"
            @onclick:stopPropagation="StopPropagation"
            @onmousedown:preventDefault="PreventMouseDownDefault">
        @if (!string.IsNullOrWhiteSpace(IconCss))
        {
            <span class="@IconCss"></span>
        }
        @ChildContent
    </button>
}
else
{
    
    <span class="fx-button-dd-host">
        <button class="@ResolvedCssClass"
                @ref="_buttonElement"
                type="@ButtonType"
                disabled="@Disabled"
                title="@Title"
                tabindex="@TabIndex"
                style="@Style"
                aria-haspopup="true"
                aria-expanded="@_ddOpen"
                @onclick="HandleDropdownClick"
                @onclick:stopPropagation="StopPropagation"
                @onmousedown:preventDefault="PreventMouseDownDefault">
            @if (!string.IsNullOrWhiteSpace(IconCss))
            {
                <span class="@IconCss"></span>
            }
            @ChildContent
        </button>
        @if (_ddOpen && !Disabled)
        {
            <button type="button" class="fx-button-dd-backdrop" tabindex="-1"
                    aria-label="Close" @onclick="CloseDropDown"></button>
            <div class="fx-button-dd-panel @DropDownCssClass" @onclick:stopPropagation="true">
                @DropDownContent
            </div>
        }
    </span>
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string ButtonType { get; set; } = "button";
    [Parameter] public string? IconCss { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public int? TabIndex { get; set; }
    [Parameter] public bool AutoFocus { get; set; }
    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }

    [Parameter] public bool BareStyle { get; set; }

    [Parameter] public bool StopPropagation { get; set; }

    [Parameter] public bool PreventMouseDownDefault { get; set; }

    [Parameter] public RenderFragment? DropDownContent { get; set; }

    [Parameter] public string? DropDownCssClass { get; set; }

    private bool _ddOpen;
    private ElementReference _buttonElement;
    private bool _autoFocusApplied;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!AutoFocus || _autoFocusApplied || Disabled)
            return;

        _autoFocusApplied = true;
        try { await _buttonElement.FocusAsync(preventScroll: true); }
        catch {  }
    }

    private async Task HandleDropdownClick(MouseEventArgs e)
    {
        if (Disabled) return;
        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync(e);   // still fire OnClick so hosts can react
        _ddOpen = !_ddOpen;
    }

    public void CloseDropDown()
    {
        if (_ddOpen)
        {
            _ddOpen = false;
            StateHasChanged();
        }
    }

    private string ResolvedCssClass
    {
        get
        {
            var trimmed = (CssClass ?? string.Empty).Trim();
            return BareStyle
                ? trimmed
                : string.IsNullOrEmpty(trimmed) ? "fx-button" : $"fx-button {trimmed}";
        }
    }
}
