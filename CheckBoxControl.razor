@namespace Fx.ControlKit

<label class="fx-checkbox @(Indeterminate ? "fx-checkbox-indeterminate" : "") @CssClass" style="@(Disabled ? "opacity:0.6;cursor:default;" : "")">
    <input type="checkbox"
           checked="@Checked"
           aria-checked="@(Indeterminate ? "mixed" : Checked ? "true" : "false")"
           disabled="@Disabled"
           tabindex="@TabIndex"
           @onmousedown="OnMouseDown"
           @onfocus="OnFocus"
           @onkeydown="OnKeyDown"
           @onclick:stopPropagation="StopClickPropagation"
           @onmousedown:stopPropagation="StopMouseDownPropagation"
           @onkeydown:stopPropagation="StopKeyDownPropagation"
           @onkeydown:preventDefault="PreventKeyDownDefault"
           @onchange="OnCheckedChanged" />
    @if (!string.IsNullOrEmpty(Label))
    {
        <span class="fx-checkbox-label">@Label</span>
    }
</label>

@code {
    [Parameter] public bool Checked { get; set; }
    [Parameter] public EventCallback<bool> CheckedChanged { get; set; }
    [Parameter] public bool Indeterminate { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public int? TabIndex { get; set; }
    [Parameter] public EventCallback<MouseEventArgs> OnMouseDown { get; set; }
    [Parameter] public EventCallback<FocusEventArgs> OnFocus { get; set; }
    [Parameter] public EventCallback<KeyboardEventArgs> OnKeyDown { get; set; }
    [Parameter] public bool StopClickPropagation { get; set; }
    [Parameter] public bool StopMouseDownPropagation { get; set; }
    [Parameter] public bool StopKeyDownPropagation { get; set; }
    [Parameter] public bool PreventKeyDownDefault { get; set; }

    private async Task OnCheckedChanged(ChangeEventArgs e)
    {
        var newVal = e.Value is bool b ? b : false;
        Checked = newVal;
        if (CheckedChanged.HasDelegate)
            await CheckedChanged.InvokeAsync(newVal);
    }
}
