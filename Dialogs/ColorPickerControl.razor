@namespace Fx.ControlKit.Dialogs
@using System.Globalization

@*
    ColorPickerControl — a plain colour swatch button (no text, no arrow). Clicking it opens
    a dropdown palette (Windows basic colours) + a hex box for a custom colour. No JS.
    DropUp / DropAlignRight let a host near a screen edge keep the popup on-screen — the
    panel is absolutely positioned, so a scrollable container would otherwise clip it.
    API (Value / ValueChanged / CssClass) is unchanged.
*@

<div class="fx-colorpicker @CssClass">
    <button type="button" class="fx-colorpicker-button" disabled="@(!Enabled)"
            style="background:@Value;" title="@Value" @onclick="ToggleOpen"></button>

    @if (_isOpen && Enabled)
    {
        <button type="button" class="fx-colorpicker-backdrop" tabindex="-1"
                aria-label="Close colour picker" @onclick="Close"></button>
        <div class="fx-colorpicker-panel @(DropUp ? "drop-up" : "") @(DropAlignRight ? "align-right" : "")"
             @onclick:stopPropagation="true">
            <div class="fx-colorpicker-palette">
                @foreach (var color in _palette)
                {
                    <button type="button"
                            class="fx-colorpicker-cell @(string.Equals(color, Value, StringComparison.OrdinalIgnoreCase) ? "selected" : "")"
                            style="background:@color;"
                            title="@color"
                            @onclick="() => SelectColor(color)"></button>
                }
            </div>
            <div class="fx-colorpicker-custom">
                <label class="fx-colorpicker-label">Hex:</label>
                <input type="text" class="fx-colorpicker-input" value="@Value" maxlength="7"
                       @onchange="HandleInputChange" />
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string Value { get; set; } = "#2563eb";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public bool Enabled { get; set; } = true;

    /// <summary>Open the popup above the swatch (for hosts near the bottom of a scroll area).</summary>
    [Parameter] public bool DropUp { get; set; }
    /// <summary>Right-align the popup to the swatch (for hosts near the right edge).</summary>
    [Parameter] public bool DropAlignRight { get; set; }

    private bool _isOpen;

    private void ToggleOpen() { if (Enabled) _isOpen = !_isOpen; }
    private void Close() => _isOpen = false;

    // Windows "Basic colors" palette (8 × 6), matching the VB6 Color dialog.
    private static readonly string[] _palette =
    {
        "#FF8080", "#FFFF80", "#80FF80", "#00FF80", "#80FFFF", "#0080FF", "#FF80C0", "#FF80FF",
        "#FF0000", "#FFFF00", "#80FF00", "#00FF40", "#00FFFF", "#0080C0", "#8080C0", "#FF00FF",
        "#804040", "#FF8040", "#00FF00", "#008080", "#004080", "#8080FF", "#800040", "#FF0080",
        "#800000", "#FF8000", "#008000", "#008040", "#0000FF", "#0000A0", "#800080", "#8000FF",
        "#400000", "#804000", "#004000", "#004040", "#000080", "#000040", "#400040", "#400080",
        "#000000", "#808000", "#808040", "#808080", "#408080", "#C0C0C0", "#A0A0A4", "#FFFFFF",
    };

    private async Task SelectColor(string color)
    {
        Value = color;
        _isOpen = false;
        if (ValueChanged.HasDelegate)
            await ValueChanged.InvokeAsync(color);
    }

    private async Task HandleInputChange(ChangeEventArgs e)
    {
        var input = e.Value?.ToString()?.Trim() ?? "";
        if (!input.StartsWith('#'))
            input = "#" + input;
        if (input.Length == 7 || input.Length == 4)
        {
            Value = input;
            if (ValueChanged.HasDelegate)
                await ValueChanged.InvokeAsync(input);
        }
    }
}
