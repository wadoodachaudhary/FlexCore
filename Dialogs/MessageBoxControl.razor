@namespace Fx.ControlKit.Dialogs

@*
    MessageBoxControl — standard message box dialog.
    Show via setting Visible=true or calling ShowAsync().
*@

@if (Visible)
{
    <div class="@OverlayClass" @onclick="HandleOverlayClick">
        <div class="@MessageBoxClass" role="dialog" aria-modal="true" aria-labelledby="@TitleId" @onclick:stopPropagation="true">
            <div class="fx-msgbox-header">
                <span id="@TitleId">@Title</span>
                <button type="button" class="fx-msgbox-close" aria-label="Close" @onclick="Close">&times;</button>
            </div>
            <div class="fx-msgbox-body">
                @if (HasIcon)
                {
                    @if (!string.IsNullOrWhiteSpace(IconImageSrc))
                    {
                        <img class="@IconClass" src="@IconImageSrc" alt="" aria-hidden="true" />
                    }
                    else
                    {
                        <span class="@IconClass" aria-hidden="true"></span>
                    }
                }
                <div class="fx-msgbox-message">@Message</div>
            </div>
            <div class="fx-msgbox-footer">
                @switch (Buttons)
                {
                    case MessageBoxButtons.Ok:
                        <button type="button" class="fx-msgbox-btn fx-msgbox-btn-primary" @onclick="() => CloseWith(MessageBoxResult.Ok)">OK</button>
                        break;
                    case MessageBoxButtons.OkCancel:
                        <button type="button" class="fx-msgbox-btn fx-msgbox-btn-primary" @onclick="() => CloseWith(MessageBoxResult.Ok)">OK</button>
                        <button type="button" class="fx-msgbox-btn" @onclick="() => CloseWith(MessageBoxResult.Cancel)">Cancel</button>
                        break;
                    case MessageBoxButtons.YesNo:
                        <button type="button" class="fx-msgbox-btn fx-msgbox-btn-primary" @onclick="() => CloseWith(MessageBoxResult.Yes)">Yes</button>
                        <button type="button" class="fx-msgbox-btn" @onclick="() => CloseWith(MessageBoxResult.No)">No</button>
                        break;
                    case MessageBoxButtons.YesNoCancel:
                        <button type="button" class="fx-msgbox-btn fx-msgbox-btn-primary" @onclick="() => CloseWith(MessageBoxResult.Yes)">Yes</button>
                        <button type="button" class="fx-msgbox-btn" @onclick="() => CloseWith(MessageBoxResult.No)">No</button>
                        <button type="button" class="fx-msgbox-btn" @onclick="() => CloseWith(MessageBoxResult.Cancel)">Cancel</button>
                        break;
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public string Title { get; set; } = "Message";
    [Parameter] public string? Message { get; set; }
    [Parameter] public string? IconCss { get; set; }
    [Parameter] public MessageBoxButtons Buttons { get; set; } = MessageBoxButtons.Ok;
    [Parameter] public MessageBoxLook Look { get; set; } = MessageBoxLook.VB6;
    [Parameter] public EventCallback<MessageBoxResult> OnResult { get; set; }
    [Parameter] public string? CssClass { get; set; }

    private TaskCompletionSource<MessageBoxResult>? _tcs;
    private MessageBoxLook? _activeLook;
    private readonly string TitleId = $"fx-msgbox-title-{Guid.NewGuid():N}";
    private MessageBoxLook EffectiveLook => _activeLook ?? Look;
    private string LookCssSuffix => EffectiveLook == MessageBoxLook.DotNet ? "dotnet" : "vb6";
    private string OverlayClass => $"fx-msgbox-overlay fx-msgbox-overlay-{LookCssSuffix}";
    private string MessageBoxClass => $"fx-msgbox fx-msgbox-{LookCssSuffix}{(string.IsNullOrWhiteSpace(CssClass) ? "" : $" {CssClass}")}";
    private string? EffectiveIconCss => ResolveEffectiveIconCss();
    private bool HasIcon => !string.IsNullOrWhiteSpace(EffectiveIconCss);
    private string StaticAssetRoot => $"_content/{typeof(MessageBoxControl).Assembly.GetName().Name}";
    private string? IconImageSrc => ResolveIconImageSrc(EffectiveIconCss);
    private string IconClass => string.IsNullOrWhiteSpace(EffectiveIconCss)
        ? "fx-msgbox-icon"
        : $"fx-msgbox-icon {ResolveIconCss(EffectiveIconCss)}{(string.IsNullOrWhiteSpace(IconImageSrc) ? "" : " fx-msgbox-icon-image")}";

    public Task<MessageBoxResult> ShowAsync(string message, string title = "Message",
        MessageBoxButtons buttons = MessageBoxButtons.Ok, string? icon = null, MessageBoxLook? look = null)
    {
        Message = message;
        Title = title;
        Buttons = buttons;
        IconCss = icon;
        _activeLook = look;
        Visible = true;
        _tcs = new TaskCompletionSource<MessageBoxResult>();
        StateHasChanged();
        return _tcs.Task;
    }

    private async Task CloseWith(MessageBoxResult result)
    {
        Visible = false;
        _activeLook = null;
        if (VisibleChanged.HasDelegate)
            await VisibleChanged.InvokeAsync(false);
        if (OnResult.HasDelegate)
            await OnResult.InvokeAsync(result);
        _tcs?.TrySetResult(result);
    }

    private Task Close() => CloseWith(MessageBoxResult.Cancel);
    private Task HandleOverlayClick() => Close();

    private string? ResolveEffectiveIconCss()
    {
        if (string.Equals(IconCss?.Trim(), "none", StringComparison.OrdinalIgnoreCase))
            return null;

        if (!string.IsNullOrWhiteSpace(IconCss))
            return IconCss;

        return EffectiveLook == MessageBoxLook.VB6 && Buttons != MessageBoxButtons.Ok
            ? "question"
            : null;
    }

    private string? ResolveIconImageSrc(string? icon)
    {
        if (string.IsNullOrWhiteSpace(icon))
            return null;

        return ResolveIconCss(icon) == "fx-msgbox-icon-question"
            ? $"{StaticAssetRoot}/images/32/question.ico"
            : null;
    }

    private static string ResolveIconCss(string icon)
    {
        var value = icon.Trim();
        return value.ToLowerInvariant() switch
        {
            "warning" or "exclamation" or "vbexclamation" => "fx-msgbox-icon-warning",
            "info" or "information" or "vbinformation" => "fx-msgbox-icon-info",
            "error" or "critical" or "vbcritical" => "fx-msgbox-icon-error",
            "question" or "vbquestion" => "fx-msgbox-icon-question",
            _ => value
        };
    }
}
