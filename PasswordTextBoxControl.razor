@namespace Fx.ControlKit
@using Microsoft.AspNetCore.Components.Web
@implements IDisposable

<div class="fx-password-editor">
    <input class="@InputCssClass"
           value="@DisplayValue"
           @oninput="OnNativeInput"
           @onchange="OnNativeChange"
           @onfocus="OnInputFocus"
           @ref="_inputElement"
           @onclick:stopPropagation="true"
           @onmousedown:stopPropagation="true"
           @onkeydown:stopPropagation="true"
           @attributes="MergedAttributes" />
    <button type="button"
            class="fx-password-toggle"
            aria-label="@ToggleLabel"
            title="@ToggleLabel"
            aria-pressed="@_showPlain"
            @onclick="TogglePlainText"
            @onclick:stopPropagation="true"
            @onmousedown:preventDefault="true"
            @onmousedown:stopPropagation="true">
        @if (_showPlain)
        {
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M3 3l18 18" />
                <path d="M10.7 10.7a2 2 0 0 0 2.6 2.6" />
                <path d="M9.9 4.2A10.6 10.6 0 0 1 12 4c5 0 8.5 4.1 10 8-0.5 1.3-1.3 2.6-2.3 3.7" />
                <path d="M6.5 6.5C4.4 7.9 2.9 10.1 2 12c1.5 3.9 5 8 10 8 1.8 0 3.4-0.5 4.8-1.3" />
            </svg>
        }
        else
        {
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M2 12s3.5-8 10-8 10 8 10 8-3.5 8-10 8S2 12 2 12z" />
                <circle cx="12" cy="12" r="3" />
            </svg>
        }
    </button>
</div>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public bool Enabled { get; set; } = true;
    [Parameter] public int? MaxLength { get; set; }
    [Parameter] public bool UpdateOnInput { get; set; }
    [Parameter] public Action<ElementReference>? ElementReferenceCaptured { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? AdditionalAttributes { get; set; }

    private const int TransientRevealMilliseconds = 1000;
    private ElementReference _inputElement;
    private bool _showPlain;
    private int _transientRevealIndex = -1;
    private CancellationTokenSource? _transientRevealCts;

    protected override void OnParametersSet()
    {
        if (_transientRevealIndex >= (Value?.Length ?? 0))
            _transientRevealIndex = -1;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        ElementReferenceCaptured?.Invoke(_inputElement);
    }

    private string ToggleLabel => _showPlain ? "Hide password" : "Show password";

    private string InputCssClass
    {
        get
        {
            var classes = new List<string> { "fx-password-input" };
            if (!string.IsNullOrWhiteSpace(CssClass))
                classes.Add(CssClass);
            if (AdditionalAttributes != null
                && AdditionalAttributes.TryGetValue("class", out var extraClass)
                && !string.IsNullOrWhiteSpace(extraClass?.ToString()))
            {
                classes.Add(extraClass.ToString()!);
            }
            return string.Join(" ", classes);
        }
    }

    private IReadOnlyDictionary<string, object> MergedAttributes
    {
        get
        {
            var merged = new Dictionary<string, object>(StringComparer.OrdinalIgnoreCase);
            if (AdditionalAttributes != null)
            {
                foreach (var kv in AdditionalAttributes)
                {
                    if (!string.Equals(kv.Key, "class", StringComparison.OrdinalIgnoreCase))
                        merged[kv.Key] = kv.Value;
                }
            }

            merged["type"] = "text";
            merged["autocomplete"] = "off";
            merged["spellcheck"] = "false";
            if (MaxLength.HasValue && !merged.ContainsKey("maxlength"))
                merged["maxlength"] = MaxLength.Value;
            if (!Enabled && !merged.ContainsKey("disabled"))
                merged["disabled"] = "disabled";

            return merged;
        }
    }

    private string DisplayValue => BuildDisplayValue(Value ?? string.Empty);

    private string BuildDisplayValue(string plain)
    {
        if (_showPlain || string.IsNullOrEmpty(plain))
            return plain;

        var chars = Enumerable.Repeat('*', plain.Length).ToArray();
        if (_transientRevealIndex >= 0 && _transientRevealIndex < plain.Length)
            chars[_transientRevealIndex] = plain[_transientRevealIndex];
        return new string(chars);
    }

    private async Task OnNativeInput(ChangeEventArgs e)
    {
        var incoming = e.Value?.ToString() ?? string.Empty;
        var oldPlain = Value ?? string.Empty;
        var oldDisplay = BuildDisplayValue(oldPlain);
        var newPlain = _showPlain ? incoming : DerivePlainValue(oldPlain, oldDisplay, incoming);
        newPlain = ApplyMaxLength(newPlain);

        var revealIndex = ResolveRevealIndex(oldDisplay, incoming, newPlain);
        Value = newPlain;

        if (!_showPlain && revealIndex >= 0)
            StartTransientReveal(revealIndex);
        else if (_showPlain)
            ClearTransientReveal();

        if (UpdateOnInput && ValueChanged.HasDelegate)
            await ValueChanged.InvokeAsync(Value);
    }

    private Task OnNativeChange(ChangeEventArgs e) =>
        UpdateOnInput ? Task.CompletedTask : NotifyValueChangedAsync();

    private Task OnInputFocus() => Task.CompletedTask;

    private async Task NotifyValueChangedAsync()
    {
        if (ValueChanged.HasDelegate)
            await ValueChanged.InvokeAsync(Value);
    }

    private static string DerivePlainValue(string oldPlain, string oldDisplay, string incoming)
    {
        var prefix = 0;
        var prefixLimit = Math.Min(oldDisplay.Length, incoming.Length);
        while (prefix < prefixLimit && oldDisplay[prefix] == incoming[prefix])
            prefix++;

        var suffix = 0;
        var maxSuffix = Math.Min(oldDisplay.Length - prefix, incoming.Length - prefix);
        while (suffix < maxSuffix
            && oldDisplay[oldDisplay.Length - 1 - suffix] == incoming[incoming.Length - 1 - suffix])
        {
            suffix++;
        }

        var insertedLength = incoming.Length - prefix - suffix;
        var inserted = insertedLength > 0 ? incoming.Substring(prefix, insertedLength) : string.Empty;
        var oldSuffixStart = Math.Max(prefix, oldPlain.Length - suffix);
        return oldPlain[..prefix] + inserted + oldPlain[oldSuffixStart..];
    }

    private string ApplyMaxLength(string value)
    {
        if (MaxLength is > 0 && value.Length > MaxLength.Value)
            return value[..MaxLength.Value];
        return value;
    }

    private static int ResolveRevealIndex(string oldDisplay, string incoming, string newPlain)
    {
        var prefix = 0;
        var prefixLimit = Math.Min(oldDisplay.Length, incoming.Length);
        while (prefix < prefixLimit && oldDisplay[prefix] == incoming[prefix])
            prefix++;

        var suffix = 0;
        var maxSuffix = Math.Min(oldDisplay.Length - prefix, incoming.Length - prefix);
        while (suffix < maxSuffix
            && oldDisplay[oldDisplay.Length - 1 - suffix] == incoming[incoming.Length - 1 - suffix])
        {
            suffix++;
        }

        var insertedLength = incoming.Length - prefix - suffix;
        if (insertedLength <= 0 || newPlain.Length == 0)
            return -1;

        return Math.Min(prefix + insertedLength - 1, newPlain.Length - 1);
    }

    private void TogglePlainText()
    {
        _showPlain = !_showPlain;
        ClearTransientReveal();
    }

    private void StartTransientReveal(int index)
    {
        _transientRevealIndex = index;
        _transientRevealCts?.Cancel();
        _transientRevealCts?.Dispose();

        var cts = new CancellationTokenSource();
        _transientRevealCts = cts;
        _ = ClearTransientRevealAfterDelayAsync(cts);
    }

    private async Task ClearTransientRevealAfterDelayAsync(CancellationTokenSource cts)
    {
        try
        {
            await Task.Delay(TransientRevealMilliseconds, cts.Token);
            if (!cts.IsCancellationRequested)
            {
                _transientRevealIndex = -1;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (TaskCanceledException)
        {
        }
    }

    private void ClearTransientReveal()
    {
        _transientRevealIndex = -1;
        _transientRevealCts?.Cancel();
    }

    public void Dispose()
    {
        _transientRevealCts?.Cancel();
        _transientRevealCts?.Dispose();
    }
}
