@namespace Fx.ControlKit
@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

@if (Visible)
{
    <div class="fx-context-menu-backdrop"
         style="z-index:@(ZIndex - 1);"
         @onclick="CloseAsync"
         @oncontextmenu="CloseAsync"
         @oncontextmenu:preventDefault="true"></div>
    <CascadingValue Value="this" IsFixed="true">
        <div class="@RootCssClass"
             style="@PositionStyle"
             @ref="_menuElement"
             role="menu"
             @onclick:stopPropagation="true"
             @oncontextmenu:stopPropagation="true">
            @ChildContent
        </div>
    </CascadingValue>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public double X { get; set; }
    [Parameter] public double Y { get; set; }
    [Parameter] public int ZIndex { get; set; } = 10000;
    [Parameter] public int MinWidth { get; set; } = 160;
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private ElementReference _menuElement;
    private IJSObjectReference? _contextMenuJsModule;

    private string RootCssClass =>
        string.IsNullOrWhiteSpace(CssClass)
            ? "fx-context-menu"
            : $"fx-context-menu {CssClass.Trim()}";

    private string PositionStyle =>
        $"left:{X}px;top:{Y}px;min-width:{MinWidth}px;z-index:{ZIndex};{Style}";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!Visible)
            return;

        var module = await GetContextMenuJsModuleAsync();
        if (module != null)
            await module.InvokeVoidAsync("positionContextMenu", _menuElement, X, Y, MinWidth, ZIndex);
    }

    public async Task CloseAsync()
    {
        if (VisibleChanged.HasDelegate)
            await VisibleChanged.InvokeAsync(false);

        if (OnClose.HasDelegate)
            await OnClose.InvokeAsync();
    }

    internal Task RequestCloseAsync() => CloseAsync();

    private async ValueTask<IJSObjectReference?> GetContextMenuJsModuleAsync()
    {
        try
        {
            return _contextMenuJsModule ??= await JSRuntime.InvokeAsync<IJSObjectReference>(
                "import", $"./_content/{typeof(ContextMenuControl).Assembly.GetName().Name}/context-menu-control.js");
        }
        catch
        {
            return null;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_contextMenuJsModule != null)
        {
            try { await _contextMenuJsModule.DisposeAsync(); }
            catch { }
            _contextMenuJsModule = null;
        }
    }
}
