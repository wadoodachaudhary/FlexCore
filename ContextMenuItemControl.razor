@namespace Fx.ControlKit

<div class="@WrapperCssClass" role="presentation">
    <button class="@RootCssClass"
            type="button"
            role="menuitem"
            aria-haspopup="@(HasSubmenu ? "menu" : null)"
            disabled="@Disabled"
            title="@Title"
            @onclick="HandleClick">
        @if (!string.IsNullOrWhiteSpace(Icon))
        {
            <span class="fx-context-menu-item-icon">@Icon</span>
        }
        <span class="fx-context-menu-item-text">@Text</span>
        @if (HasSubmenu)
        {
            <span class="fx-context-menu-item-arrow" aria-hidden="true">&#9654;</span>
        }
    </button>
    @if (HasSubmenu && !Disabled)
    {
        <div class="fx-context-submenu" role="menu">
            @ChildContent
        </div>
    }
</div>

@code {
    [CascadingParameter] public ContextMenuControl? ParentMenu { get; set; }

    [Parameter] public string Text { get; set; } = string.Empty;
    [Parameter] public string? Icon { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool CloseOnClick { get; set; } = true;
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool HasSubmenu => ChildContent is not null;

    private string WrapperCssClass =>
        HasSubmenu
            ? "fx-context-menu-item-host has-submenu"
            : "fx-context-menu-item-host";

    private string RootCssClass =>
        string.IsNullOrWhiteSpace(CssClass)
            ? "fx-context-menu-item"
            : $"fx-context-menu-item {CssClass.Trim()}";

    private async Task HandleClick()
    {
        if (Disabled)
            return;

        if (HasSubmenu && !OnClick.HasDelegate)
            return;

        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync();

        if (!HasSubmenu && CloseOnClick && ParentMenu is not null)
            await ParentMenu.RequestCloseAsync();
    }
}
