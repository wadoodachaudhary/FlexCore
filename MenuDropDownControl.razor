@namespace Fx.ControlKit

<div class="fx-menu-dropdown" @onclick:stopPropagation="true">
    <button class="fx-menu-trigger @(IsOpen ? "active" : "") @(Disabled ? "disabled" : "")"
            type="button"
            disabled="@Disabled"
            role="menuitem"
            aria-haspopup="true"
            aria-expanded="@IsOpen"
            @onclick="OnTriggerClicked"
            @onmouseover="OnMouseOver">
        @Label
    </button>

    @if (IsOpen)
    {
        <CascadingValue Value="this" IsFixed="true">
            <div class="fx-menu-panel" role="menu">
                @ChildContent
            </div>
        </CascadingValue>
    }
</div>

@code {
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [CascadingParameter] public MenuBarControl? Parent { get; set; }

    internal bool IsOpen => Parent?.ActiveMenu == this;

    internal void RequestClose()
    {
        Parent?.CloseAll();
    }

    private void OnTriggerClicked()
    {
        if (Disabled)
        {
            return;
        }

        Parent?.Toggle(this);
    }

    private void OnMouseOver()
    {
        if (Disabled)
        {
            return;
        }

        Parent?.Activate(this);
    }
}
