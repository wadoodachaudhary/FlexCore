@namespace Fx.ControlKit
@typeparam TValue

<input type="@InputType"
       class="fx-numeric @CssClass"
       style="@(string.IsNullOrEmpty(Width) ? "" : $"width:{Width};")"
       value="@FormattedValue"
       disabled="@(!Enabled)"
       step="@StepValue"
       min="@(Min.HasValue ? Min.Value.ToString() : null)"
       max="@(Max.HasValue ? Max.Value.ToString() : null)"
       maxlength="@MaxLength"
       inputmode="@InputMode"
       placeholder="@Placeholder"
       @onchange="OnValueChanged" />

@code {
    [Parameter] public TValue? Value { get; set; }
    [Parameter] public EventCallback<TValue?> ValueChanged { get; set; }
    [Parameter] public string? Format { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? Width { get; set; }
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public bool Enabled { get; set; } = true;
    [Parameter] public decimal? Min { get; set; }
    [Parameter] public decimal? Max { get; set; }
    [Parameter] public decimal Step { get; set; } = 1;
    [Parameter] public int? MaxLength { get; set; }

    [Parameter] public EventCallback<NumericChangeEventArgs<TValue>> ValueChange { get; set; }

    private string StepValue => Step == 1 ? "any" : Step.ToString(System.Globalization.CultureInfo.InvariantCulture);
    private string InputType => MaxLength is > 0 ? "text" : "number";
    private string InputMode => Min is < 0 ? "decimal" : Step == 1 ? "numeric" : "decimal";

    private string FormattedValue
    {
        get
        {
            if (Value == null) return "";
            if (Value is IFormattable formattable && !string.IsNullOrEmpty(Format))
            {
                var fmt = Format.Replace("C", "F").Replace("N", "F");
                return formattable.ToString(fmt, System.Globalization.CultureInfo.InvariantCulture);
            }
            return Value.ToString() ?? "";
        }
    }

    private async Task OnValueChanged(ChangeEventArgs e)
    {
        var strVal = NormalizeInput(e.Value?.ToString() ?? "");
        TValue? newValue = default;
        try
        {
            if (typeof(TValue) == typeof(decimal))
                newValue = (TValue)(object)ParseDecimalOrBoundary(strVal);
            else if (typeof(TValue) == typeof(int))
                newValue = (TValue)(object)(int.TryParse(strVal, out var i) ? i : ParseIntBoundary(strVal));
            else if (typeof(TValue) == typeof(double))
                newValue = (TValue)(object)(double.TryParse(strVal, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var dbl) ? dbl : ParseDoubleBoundary(strVal));
            else if (typeof(TValue) == typeof(float))
                newValue = (TValue)(object)(float.TryParse(strVal, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var f) ? f : ParseFloatBoundary(strVal));
            else
                newValue = (TValue)Convert.ChangeType(strVal, typeof(TValue));
        }
        catch
        {
            newValue = default;
        }

        if (newValue != null && Min.HasValue && TryConvertToDecimal(newValue, out var minDecVal))
        {
            if (minDecVal < Min.Value)
                newValue = ConvertDecimalToValue(Min.Value, newValue);
        }
        if (newValue != null && Max.HasValue && TryConvertToDecimal(newValue, out var maxDecVal))
        {
            if (maxDecVal > Max.Value)
                newValue = ConvertDecimalToValue(Max.Value, newValue);
        }

        Value = newValue;
        if (ValueChanged.HasDelegate)
            await ValueChanged.InvokeAsync(newValue);

        if (ValueChange.HasDelegate)
            await ValueChange.InvokeAsync(new NumericChangeEventArgs<TValue> { Value = newValue });
    }

	    public class NumericChangeEventArgs<T>
	    {
	        public T? Value { get; set; }
	    }

    private static string NormalizeInput(string value) =>
        value.Trim()
             .Replace("%", "", StringComparison.Ordinal)
             .Replace(" ", "", StringComparison.Ordinal);

    private static decimal ParseDecimalOrBoundary(string value)
    {
        if (decimal.TryParse(value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var d))
            return d;

        if (LooksNumeric(value, out var negative))
            return negative ? decimal.MinValue : decimal.MaxValue;

        return 0m;
    }

    private static int ParseIntBoundary(string value)
    {
        if (LooksNumeric(value, out var negative))
            return negative ? int.MinValue : int.MaxValue;
        return 0;
    }

    private static double ParseDoubleBoundary(string value)
    {
        if (LooksNumeric(value, out var negative))
            return negative ? double.NegativeInfinity : double.PositiveInfinity;
        return 0d;
    }

    private static float ParseFloatBoundary(string value)
    {
        if (LooksNumeric(value, out var negative))
            return negative ? float.NegativeInfinity : float.PositiveInfinity;
        return 0f;
    }

    private static bool LooksNumeric(string value, out bool negative)
    {
        negative = false;
        var s = value.Trim();
        if (s.Length == 0)
            return false;

        if (s[0] == '-' || s[0] == '+')
        {
            negative = s[0] == '-';
            s = s[1..];
        }

        var hasDigit = false;
        var hasDecimal = false;
        foreach (var ch in s)
        {
            if (char.IsDigit(ch))
            {
                hasDigit = true;
                continue;
            }

            if (ch == ',' || ch == '_')
                continue;

            if (ch == '.' && !hasDecimal)
            {
                hasDecimal = true;
                continue;
            }

            return false;
        }

        return hasDigit;
    }

    private static bool TryConvertToDecimal(TValue value, out decimal result)
    {
        result = 0m;
        try
        {
            switch (value)
            {
                case decimal d:
                    result = d;
                    return true;
                case double d:
                    if (double.IsNaN(d))
                        return false;
                    if (double.IsPositiveInfinity(d) || d > (double)decimal.MaxValue)
                    {
                        result = decimal.MaxValue;
                        return true;
                    }
                    if (double.IsNegativeInfinity(d) || d < (double)decimal.MinValue)
                    {
                        result = decimal.MinValue;
                        return true;
                    }
                    result = (decimal)d;
                    return true;
                case float f:
                    if (float.IsNaN(f))
                        return false;
                    if (float.IsPositiveInfinity(f) || f > (float)decimal.MaxValue)
                    {
                        result = decimal.MaxValue;
                        return true;
                    }
                    if (float.IsNegativeInfinity(f) || f < (float)decimal.MinValue)
                    {
                        result = decimal.MinValue;
                        return true;
                    }
                    result = (decimal)f;
                    return true;
                default:
                    result = Convert.ToDecimal(value, System.Globalization.CultureInfo.InvariantCulture);
                    return true;
            }
        }
        catch
        {
            return false;
        }
    }

    private static TValue? ConvertDecimalToValue(decimal value, TValue? fallback)
    {
        try
        {
            var targetType = Nullable.GetUnderlyingType(typeof(TValue)) ?? typeof(TValue);
            return (TValue)Convert.ChangeType(value, targetType, System.Globalization.CultureInfo.InvariantCulture);
        }
        catch
        {
            return fallback;
        }
    }
}
