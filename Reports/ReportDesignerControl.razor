    private static ReportDesignerToolbarItem Button(string command, string iconCss, string tooltip, bool hasDropDown = false) =>
        new(command, iconCss, tooltip, HasDropDown: hasDropDown);

    private static ReportDesignerToolbarItem Sep() =>
        new("", "", "", ReportDesignerToolbarItemKind.Separator);

    private string ToolbarButtonCss(ReportDesignerToolbarItem item)
    {
        var active = IsToolbarCommandActive(item.Command) ? " active" : "";
        var pending = IsToolbarCommandImplemented(item.Command) ? "" : " fx-rd-tool-pending";
        var filePicker = item.Kind == ReportDesignerToolbarItemKind.FileOpen ? " fx-rd-file-picker" : "";
        return $"fx-rd-icon-btn{filePicker} {item.IconCss}{active}{pending}";
    }

    private static string ToolbarIconCss(ReportDesignerToolbarItem item) =>
        $"fx-rd-icon {item.IconCss}";

    private bool IsToolbarItemDisabled(ReportDesignerToolbarItem item)
    {
        if (item.Kind != ReportDesignerToolbarItemKind.Button)
            return false;

        if (!IsToolbarCommandImplemented(item.Command))
            return true;

        return item.Command switch
        {
            "preview" => !PreviewRequested.HasDelegate,
            "reload" => !CanReload,
            "copy" or "cut" or "delete" => _selectedElement is null,
            "paste" => _clipboardElement is null,
            "formatPainter" => _selectedElement is null && _formatPainterElement is null,
            "undo" => _undoStack.Count <= 1,
            "redo" => _redoStack.Count == 0,
            "field" => !_document.Fields.Any(),
            "fontGrow" or "fontShrink" => _selectedElement is null,
            "bold" or "italic" or "underline" or
            "align-left" or "align-center" or "align-right" or "align-justified" or
            "fontcolor" or "fill" or "suppress" or
            "indentIncrease" or "indentDecrease" or "textFormat" or "format" or
            "lockFormat" or "lockSize" or
            "currency" or "thousands" or "percent" or "decimalIncrease" or "decimalDecrease" or
            "nudge-left" or "nudge-right" or "nudge-up" or "nudge-down" => _selectedElement is null,
            _ => false
        };
    }

    private bool IsToolbarCommandActive(string command)
    {
        return command switch
        {
            "bold" => _selectedElement?.Bold == true,
            "italic" => _selectedElement?.Italic == true,
            "underline" => _selectedElement?.Underline == true,
            "align-left" => _selectedElement is not null && string.Equals(NormalizeAlignment(_selectedElement.HorizontalAlignment), "Left", StringComparison.OrdinalIgnoreCase),
            "align-center" => _selectedElement is not null && string.Equals(NormalizeAlignment(_selectedElement.HorizontalAlignment), "Center", StringComparison.OrdinalIgnoreCase),
            "align-right" => _selectedElement is not null && string.Equals(NormalizeAlignment(_selectedElement.HorizontalAlignment), "Right", StringComparison.OrdinalIgnoreCase),
            "align-justified" => _selectedElement is not null && string.Equals(NormalizeAlignment(_selectedElement.HorizontalAlignment), "Justified", StringComparison.OrdinalIgnoreCase),
            "suppress" => _selectedElement?.IsSuppressed == true,
            "lockFormat" => _selectedElement?.LockFormat == true,
            "lockSize" => _selectedElement?.LockSizePosition == true,
            "formatPainter" => _formatPainterElement is not null,
            "design" => IsDesignDocumentActive,
            "code" => IsCodeDocumentActive,
            "fieldExplorer" => IsFieldExplorerActive,
            "reportExplorer" => !IsFieldExplorerActive,
            _ => false
        };
    }

    private static bool IsToolbarCommandImplemented(string command)
    {
        return command is
            "new" or "save" or "export" or "preview" or "reload" or "code" or "design" or
            "print" or "browseData" or "find" or
            "copy" or "cut" or "paste" or "delete" or "formatPainter" or "undo" or "redo" or
            "database" or "record" or "group" or "groupsort" or "section" or "sort" or
            "formula" or "parameter" or "summary" or "page" or
            "visualLinking" or "highlightExpert" or "runningTotal" or
            "wizard" or "text" or "field" or "line" or "box" or "subreport" or
            "bold" or "italic" or "underline" or
            "fontGrow" or "fontShrink" or
            "align-left" or "align-center" or "align-right" or "align-justified" or
            "indentIncrease" or "indentDecrease" or "textFormat" or "format" or
            "fontcolor" or "fill" or "suppress" or "lockFormat" or "lockSize" or
