    private async Task OpenFileAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file.Name.EndsWith(".rpt", StringComparison.OrdinalIgnoreCase))
        {
            await OpenRptFileAsync(file);
            return;
        }

        await using var stream = file.OpenReadStream(MaxXmlBytes);
        using var reader = new StreamReader(stream);
        var xml = await reader.ReadToEndAsync();
        await LoadXmlAsync(xml, file.Name);
    }

    private async Task OpenRptFileAsync(IBrowserFile file)
    {
        if (OperatingSystem.IsBrowser())
        {
            _status = "Crystal RPT conversion requires server-side .NET.";
            return;
        }

        var tempDirectory = Path.Combine(Path.GetTempPath(), $"fx-rpt-{Guid.NewGuid():N}");
        Directory.CreateDirectory(tempDirectory);
        try
        {
            var tempRptPath = Path.Combine(tempDirectory, Path.GetFileName(file.Name));
            await using (var source = file.OpenReadStream(MaxRptBytes))
            await using (var target = File.Create(tempRptPath))
            {
                await source.CopyToAsync(target);
            }

            var xmlPath = await ConvertRptPathAsync(tempRptPath);
            if (string.IsNullOrWhiteSpace(xmlPath))
                return;

            var xml = await File.ReadAllTextAsync(xmlPath);
            await LoadXmlAsync(xml, Path.ChangeExtension(file.Name, ".xml"), xmlPath);
        }
        finally
        {
            try
            {
                if (Directory.Exists(tempDirectory))
                    Directory.Delete(tempDirectory, recursive: true);
            }
            catch
            {
            }
        }
    }

    private async Task<string?> ConvertRptPathAsync(string rptPath)
    {
        if (OperatingSystem.IsBrowser())
        {
            _status = "Crystal RPT conversion requires server-side .NET.";
            return null;
        }

        try
        {
            var outputPath = GetDefaultXmlOutputPath(rptPath);
            var result = await CrystalRptToXml.ConvertAsync(
                rptPath,
                outputPath,
                new CrystalRptConversionOptions(ExtractSubreports: true));

            _status = $"Converted {Path.GetFileName(rptPath)}.";
            return result.ReportXmlPath;
        }
        catch (Exception ex)
        {
            _status = $"Could not convert RPT: {ex.Message}";
            return null;
        }
    }

    private static string GetDefaultXmlOutputPath(string rptPath)
    {
        var dir = Path.GetDirectoryName(rptPath) ?? "";
        var baseName = Path.GetFileNameWithoutExtension(rptPath);
        if (!string.IsNullOrEmpty(dir) &&
            Path.GetFileName(dir).Equals("rpt", StringComparison.OrdinalIgnoreCase))
        {
            return Path.Combine(Path.GetDirectoryName(dir) ?? "", "xml", baseName + ".xml");
        }

        return Path.Combine(dir, baseName + ".xml");
    }

