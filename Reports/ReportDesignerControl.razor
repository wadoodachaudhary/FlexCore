    private List<TreeNode> BuildFieldExplorerNodes()
    {
        var databaseFields = NewExplorerNode("Database Fields", "fx-explorer-icon-database", isExpanded: true);
        foreach (var tableGroup in GetDatabaseFieldGroups())
        {
            var table = NewExplorerNode(tableGroup.Key, "fx-explorer-icon-table", isExpanded: IsTableExpandedByDefault(tableGroup));
            foreach (var field in tableGroup)
                table.Children.Add(NewExplorerNode(field.Name, GetFieldIconCss(field), tag: field));
            databaseFields.Children.Add(table);
        }

        var formulaFields = NewExplorerNode("Formula Fields", "fx-explorer-icon-formula", isExpanded: _document.Fields.Any(field => field.IsFormula));
        foreach (var formula in _document.Fields.Where(field => field.IsFormula))
            formulaFields.Children.Add(NewExplorerNode(formula.Name, GetFieldIconCss(formula), tag: formula));

        var parameterFields = NewExplorerNode("Parameter Fields", "fx-explorer-icon-parameter", isExpanded: true);
        foreach (var parameter in _document.Parameters)
            parameterFields.Children.Add(NewExplorerNode(parameter.Name, "fx-explorer-icon-key", tag: parameter, isDisabled: true));
        if (!_document.Parameters.Any())
            parameterFields.Children.Add(NewExplorerNode("No parameter fields.", "fx-explorer-icon-field", isDisabled: true));

        var groupNameFields = NewExplorerNode("Group Name Fields", "fx-explorer-icon-group", isExpanded: true);
        foreach (var group in _document.Groups.Select((value, index) => new { value, index }))
            groupNameFields.Children.Add(NewExplorerNode(GetGroupExplorerLabel(group.value, group.index + 1), "fx-explorer-icon-field used", tag: group.value, isDisabled: true));

        var specialFields = NewExplorerNode("Special Fields", "fx-explorer-icon-special");
        foreach (var fieldName in SpecialFieldNames)
            specialFields.Children.Add(NewExplorerNode(fieldName, "fx-explorer-icon-field", isDisabled: true));

        return
        [
            databaseFields,
            formulaFields,
            NewExplorerNode("SQL Expression Fields", "fx-explorer-icon-sql", isExpanded: true),
            parameterFields,
            NewExplorerNode("Running Total Fields", "fx-explorer-icon-total", isExpanded: true),
            groupNameFields,
            specialFields
        ];
    }

    private List<TreeNode> BuildReportExplorerNodes()
    {
        var root = NewExplorerNode(GetReportFileName(), "fx-explorer-icon-report", isExpanded: true);
        foreach (var section in _document.Sections)
        {
            var sectionNode = NewExplorerNode(
                GetReportSectionExplorerLabel(section),
                GetSectionIconCss(section),
                tag: section,
                isExpanded: true);

            foreach (var element in section.Elements)
            {
                sectionNode.Children.Add(NewExplorerNode(
                    GetElementExplorerLabel(element),
                    GetElementIconCss(element),
                    tag: new ReportDesignerElementSelection { Section = section, Element = element }));
            }

            root.Children.Add(sectionNode);
        }

        return [root];
    }

    private static TreeNode NewExplorerNode(
        string text,
        string iconCss,
        object? tag = null,
        bool isExpanded = false,
        bool isDisabled = false)
    {
        return new TreeNode
        {
            Text = text,
            IconCss = iconCss,
            Tag = tag,
            IsExpanded = isExpanded,
            IsDisabled = isDisabled
        };
    }

    private void UpdateExplorerSelection()
    {
        foreach (var node in FlattenNodes(_fieldExplorerNodes.Concat(_reportExplorerNodes)))
            node.IsSelected = false;

        if (IsFieldExplorerActive)
        {
            _selectedExplorerNode = null;
            return;
        }

        if (_selectedElement is not null)
        {
            _selectedExplorerNode = FlattenNodes(_reportExplorerNodes)
                .FirstOrDefault(node => node.Tag is ReportDesignerElementSelection selection &&
                                        ReferenceEquals(selection.Element, _selectedElement));

            if (_selectedExplorerNode is not null)
            {
                _selectedExplorerNode.IsSelected = true;
                return;
            }
        }

        if (_selectedSection is null)
        {
            _selectedExplorerNode = null;
            return;
        }

        _selectedExplorerNode = FlattenNodes(_reportExplorerNodes)
            .FirstOrDefault(node => ReferenceEquals(node.Tag, _selectedSection));

        if (_selectedExplorerNode is not null)
            _selectedExplorerNode.IsSelected = true;
    }

    private static IEnumerable<TreeNode> FlattenNodes(IEnumerable<TreeNode> nodes)
    {
        foreach (var node in nodes)
        {
            yield return node;
            foreach (var child in FlattenNodes(node.Children))
                yield return child;
        }
    }

    private string GetPageStyle()
    {
        var width = Math.Clamp(ReportDesignerMetrics.TwipsToPixels(_document.Page.ContentWidthTwips), 480, 1600) + SectionRailWidthPx;
        return $"width:{width}px;";
    }

    private string GetRulerStyle()
    {
        var width = Math.Clamp(ReportDesignerMetrics.TwipsToPixels(_document.Page.ContentWidthTwips), 480, 1600);
        return $"width:{width}px;";
    }

    private string GetSectionStyle(ReportDesignerSection section)
    {
        var height = Math.Max(24, ReportDesignerMetrics.TwipsToPixels(section.HeightTwips));
        return $"height:{height}px;background:{CssColor(section.BackgroundColor, "#ffffff")};";
    }

    private string GetElementStyle(ReportDesignerElement element)
    {
        var left = ReportDesignerMetrics.TwipsToPixels(element.LeftTwips);
        var top = ReportDesignerMetrics.TwipsToPixels(element.TopTwips) + 3;
        var width = Math.Max(12, ReportDesignerMetrics.TwipsToPixels(element.WidthTwips));
        var height = Math.Max(12, ReportDesignerMetrics.TwipsToPixels(element.HeightTwips));
        var fontSize = element.FontSize <= 0 ? 10m : element.FontSize;
        var indent = ReportDesignerMetrics.TwipsToPixels(element.IndentTwips);
        var align = element.HorizontalAlignment switch
        {
            "Right" => "right",
            "HorizontalCenter" => "center",
            "Center" => "center",
            "Justified" => "justify",
            _ => "left"
        };

        return $"left:{left}px;top:{top}px;width:{width}px;height:{height}px;color:{CssColor(element.TextColor, "#000")};background:{CssColor(element.BackgroundColor, "transparent")};font-family:'{element.FontFamily}',Arial,sans-serif;font-size:{fontSize.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)}pt;font-weight:{(element.Bold ? "700" : "400")};font-style:{(element.Italic ? "italic" : "normal")};text-decoration:{(element.Underline ? "underline" : "none")};text-align:{align};padding-left:{indent}px;";
    }

    private string GetElementClass(ReportDesignerElement element)
    {
        var selected = ReferenceEquals(element, _selectedElement) ? "selected" : "";
        var kind = element.Kind.Equals("Subreport", StringComparison.OrdinalIgnoreCase) ? "subreport" : element.Kind.Equals("Field", StringComparison.OrdinalIgnoreCase) ? "field" : "text";
        var suppressed = element.IsSuppressed ? "suppressed" : "";
        return $"{selected} {kind} {suppressed}";
    }

    private string GetElementTitle(ReportDesignerElement element)
    {
        return string.IsNullOrWhiteSpace(element.Binding)
            ? $"{element.Kind}: {element.Name}"
            : $"{element.Kind}: {element.Name}\n{element.Binding}";
    }

    private static string CssColor(string value, string fallback)
    {
        return string.IsNullOrWhiteSpace(value) ? fallback : value;
    }

    private IEnumerable<IGrouping<string, ReportDesignerField>> GetDatabaseFieldGroups()
    {
        return _document.Fields
            .Where(field => !field.IsFormula && !string.IsNullOrWhiteSpace(field.Table))
            .GroupBy(field => field.Table)
            .OrderBy(group => group.Key, StringComparer.OrdinalIgnoreCase);
    }

    private IReadOnlyList<ReportDesignerDataTable> GetWizardDataSources()
    {
        if (AvailableDataSources is { Count: > 0 })
            return AvailableDataSources;

        if (_document.DataSources.Count > 0)
            return _document.DataSources;

        return _document.Fields
            .Where(field => !field.IsFormula && !string.IsNullOrWhiteSpace(field.Table))
            .GroupBy(field => field.Table)
            .OrderBy(group => group.Key, StringComparer.OrdinalIgnoreCase)
            .Select(group => new ReportDesignerDataTable
            {
                Name = group.Key,
                Fields = group.Select(field => new ReportDesignerField
                {
                    Name = field.Name,
                    Table = field.Table,
                    LongName = field.LongName,
                    Formula = field.Formula,
                    Type = field.Type,
                    IsFormula = field.IsFormula
                }).ToList()
            })
            .ToList();
    }

    private static bool IsTableExpandedByDefault(IGrouping<string, ReportDesignerField> tableGroup)
    {
        return tableGroup.Count() <= 20;
    }

    private string GetFieldIconCss(ReportDesignerField field)
    {
        return IsFieldUsed(field) ? "fx-explorer-icon-field used" : "fx-explorer-icon-field";
    }

    private bool IsFieldUsed(ReportDesignerField field)
    {
        var candidates = new[]
        {
            field.Formula,
            field.DisplayName,
            field.Name,
            string.IsNullOrWhiteSpace(field.Table) ? "" : $"{{{field.Table}.{field.Name}}}",
            string.IsNullOrWhiteSpace(field.Name) ? "" : $"{{{field.Name}}}"
        }
        .Where(value => !string.IsNullOrWhiteSpace(value))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .ToArray();

        return _document.Elements.Any(element =>
            candidates.Any(candidate =>
                element.Binding.Contains(candidate, StringComparison.OrdinalIgnoreCase) ||
                element.Text.Contains(candidate, StringComparison.OrdinalIgnoreCase)));
    }

    private static string GetGroupExplorerLabel(ReportDesignerGroup group, int index)
    {
        var condition = CleanCrystalFormula(group.Condition);
        var suffix = group.SortDirection.StartsWith("Desc", StringComparison.OrdinalIgnoreCase) ? " - D" : " - A";
        return string.IsNullOrWhiteSpace(condition)
            ? $"Group #{index}{suffix}"
            : $"Group #{index}: {condition}{suffix}";
    }

    private string GetReportSectionExplorerLabel(ReportDesignerSection section)
    {
        var label = SectionDisplayName(section.Kind);
        if (section.Kind.Equals("GroupHeader", StringComparison.OrdinalIgnoreCase) ||
            section.Kind.Equals("GroupFooter", StringComparison.OrdinalIgnoreCase))
        {
            var groupNumber = GetSectionGroupNumber(section);
            var group = groupNumber > 0 && groupNumber <= _document.Groups.Count
                ? _document.Groups[groupNumber - 1]
                : null;
            var condition = CleanCrystalFormula(group?.Condition ?? "");
            var suffix = group is null || group.SortDirection.StartsWith("Asc", StringComparison.OrdinalIgnoreCase) ? " - A" : " - D";
            label = string.IsNullOrWhiteSpace(condition)
                ? $"{label} #{groupNumber}"
                : $"{label} #{groupNumber}: {condition}{suffix}";
        }

        if (section.IsSuppressed)
            label += "    suppressed";

        return label;
    }

    private int GetSectionGroupNumber(ReportDesignerSection section)
    {
        var sameKind = _document.Sections
            .Where(candidate => candidate.Kind.Equals(section.Kind, StringComparison.OrdinalIgnoreCase))
            .ToList();
        var index = sameKind.FindIndex(candidate => ReferenceEquals(candidate, section));
        return index < 0 ? 1 : index + 1;
    }

    private static string GetSectionIconCss(ReportDesignerSection section)
    {
        if (section.Kind.StartsWith("Group", StringComparison.OrdinalIgnoreCase))
            return "fx-explorer-icon-group-section";

        return "fx-explorer-icon-section";
    }

    private static string GetElementIconCss(ReportDesignerElement element)
    {
        if (element.Kind.Contains("Text", StringComparison.OrdinalIgnoreCase) ||
            element.Kind.Contains("Heading", StringComparison.OrdinalIgnoreCase))
            return "fx-explorer-icon-text-object";

        if (element.Kind.Contains("Line", StringComparison.OrdinalIgnoreCase))
            return "fx-explorer-icon-line-object";

        if (element.Kind.Contains("Subreport", StringComparison.OrdinalIgnoreCase))
            return "fx-explorer-icon-subreport";

        return "fx-explorer-icon-field-object";
    }

    private static string GetElementExplorerLabel(ReportDesignerElement element)
    {
        var value = !string.IsNullOrWhiteSpace(element.Text)
            ? element.Text
            : !string.IsNullOrWhiteSpace(element.Binding)
                ? CleanCrystalFormula(element.Binding)
                : !string.IsNullOrWhiteSpace(element.SubreportName)
                    ? element.SubreportName
                    : element.DisplayText;

        return string.IsNullOrWhiteSpace(value) || string.Equals(value, element.Name, StringComparison.OrdinalIgnoreCase)
            ? element.Name
            : $"{element.Name}: {value}";
    }

    private static string CleanCrystalFormula(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "";

        var cleaned = value.Trim();
        if (cleaned.StartsWith("{", StringComparison.Ordinal) &&
            cleaned.EndsWith("}", StringComparison.Ordinal) &&
            cleaned.Length > 2)
        {
            cleaned = cleaned[1..^1];
        }

        if (cleaned.StartsWith("@", StringComparison.Ordinal))
            cleaned = cleaned[1..];

        return cleaned;
    }

    private ReportDesignerField ResolveDesignerField(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return new ReportDesignerField();

        var cleaned = CleanCrystalFormula(value);
        return _document.Fields
                   .Concat(_expertSelectedTables.SelectMany(table => table.Fields))
                   .Concat(_expertFormulaFields)
                   .FirstOrDefault(field =>
                       string.Equals(field.DisplayName, cleaned, StringComparison.OrdinalIgnoreCase) ||
                       string.Equals(field.Name, cleaned, StringComparison.OrdinalIgnoreCase)) is { } field
            ? CloneField(field)
            : SplitFieldName(cleaned);
    }

    private static ReportDesignerField SplitFieldName(string value)
    {
        var parts = value.Split('.', 2, StringSplitOptions.TrimEntries);
        return parts.Length == 2
            ? new ReportDesignerField { Table = parts[0], Name = parts[1] }
            : new ReportDesignerField { Name = value };
    }

