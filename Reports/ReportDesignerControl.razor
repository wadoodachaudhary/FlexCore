    private static string AdjustFormatDecimals(string format, int delta)
    {
        if (string.IsNullOrWhiteSpace(format))
            format = "N2";

        var prefix = char.IsLetter(format[0]) ? format[0].ToString().ToUpperInvariant() : "N";
        var digits = new string(format.Skip(1).Where(char.IsDigit).ToArray());
        var decimals = int.TryParse(digits, out var parsed) ? parsed : 2;
        return $"{prefix}{Math.Clamp(decimals + delta, 0, 8)}";
    }

