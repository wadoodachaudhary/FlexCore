    private void PushUndoSnapshot()
    {
        if (_restoringHistory)
            return;

        var xml = GetCurrentXml();
        if (_undoStack.Count == 0 || !string.Equals(_undoStack[^1], xml, StringComparison.Ordinal))
        {
            _undoStack.Add(xml);
            if (_undoStack.Count > 50)
                _undoStack.RemoveAt(0);
        }

        _redoStack.Clear();
    }

    private void ResetHistory()
    {
        _undoStack.Clear();
        _redoStack.Clear();
        _undoStack.Add(GetCurrentXml());
    }

