    protected override async Task OnParametersSetAsync()
    {
        if (Document is not null && !ReferenceEquals(Document, _lastDocument))
        {
            SetDocument(Document);
            _lastDocument = Document;
            return;
        }

        if (!string.IsNullOrWhiteSpace(XmlContent) && !string.Equals(XmlContent, _lastXmlContent, StringComparison.Ordinal))
        {
            await LoadXmlAsync(XmlContent!, XmlPath ?? "Report.xml");
            _lastXmlContent = XmlContent;
            return;
        }

        if (!string.IsNullOrWhiteSpace(XmlPath) && !string.Equals(XmlPath, _lastXmlPath, StringComparison.Ordinal))
        {
            await LoadPathAsync(XmlPath!);
            _lastXmlPath = XmlPath;
        }
    }

    public async Task LoadPathAsync(string xmlPath)
    {
        if (!File.Exists(xmlPath))
        {
            _status = $"Report file not found: {xmlPath}";
            return;
        }

        if (xmlPath.EndsWith(".rpt", StringComparison.OrdinalIgnoreCase))
        {
            var convertedPath = await ConvertRptPathAsync(xmlPath);
            if (!string.IsNullOrWhiteSpace(convertedPath))
                await LoadPathAsync(convertedPath);
            return;
        }

        var xml = await File.ReadAllTextAsync(xmlPath);
        await LoadXmlAsync(xml, Path.GetFileName(xmlPath), xmlPath);
    }

    public async Task LoadXmlAsync(string xml, string sourceName = "Report.xml", string? sourcePath = null)
    {
        try
        {
            SetDocument(ReportDesignerXmlSerializer.FromXml(xml, sourceName, sourcePath));
            _status = _document.StatusMessage;
            _lastXmlContent = xml;
            _lastXmlPath = sourcePath;
            await NotifyDocumentChangedAsync(markDirty: false);
        }
        catch (Exception ex)
        {
            _status = $"Could not load report XML: {ex.Message}";
        }
    }

    public string ExportXml()
    {
        var xml = ReportDesignerXmlSerializer.ToXml(_document);
        _document.IsDirty = false;
        _status = "XML generated.";
        return xml;
    }

    private async Task ExportXmlAsync()
    {
        var xml = ExportXml();
        if (XmlChanged.HasDelegate)
            await XmlChanged.InvokeAsync(xml);

        await NotifyDocumentChangedAsync(markDirty: false);
    }

    private async Task PreviewAsync()
    {
        if (PreviewRequested.HasDelegate)
            await PreviewRequested.InvokeAsync(_document);
    }

    private async Task PrintAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("window.print");
            _status = "Print requested.";
        }
        catch
        {
            _status = "Print is not available in this host.";
        }
    }

    private async Task ReloadAsync()
    {
        if (Document is not null)
        {
            SetDocument(Document);
            return;
        }

        if (!string.IsNullOrWhiteSpace(XmlContent))
        {
            await LoadXmlAsync(XmlContent!, XmlPath ?? "Report.xml");
            return;
        }

        if (!string.IsNullOrWhiteSpace(XmlPath))
            await LoadPathAsync(XmlPath!);
    }

    private Task OpenExpertAsync(string expert)
    {
        _activeExpert = expert;
        _activeExpertItemIndex = 0;
        _expertSelectedTables = _document.DataSources.Select(CloneTable).ToList();
        _expertFilters = _document.Filters.Select(CloneFilter).ToList();
        _expertGroups = _document.Groups.Select(CloneGroup).ToList();
        _expertGroupFields = _document.Groups
            .Select(group => ResolveDesignerField(group.Condition))
            .Where(field => !string.IsNullOrWhiteSpace(field.DisplayName))
            .Select(CloneField)
            .ToList();
        _expertSorts = _document.Sorts.Select(CloneSort).ToList();
        _expertSortFields = _expertSorts.Select(sort => CloneField(sort.Field)).ToList();
        _expertSummaries = _document.Summaries.Select(CloneSummary).ToList();
        _expertSummaryFields = _expertSummaries.Select(summary => CloneField(summary.Field)).ToList();
        _expertFormulaFields = _document.Fields.Where(field => field.IsFormula).Select(CloneField).ToList();
        _expertParameters = _document.Parameters.Select(CloneParameter).ToList();
        _expertSections = _document.Sections.Select(CloneSectionForExpert).ToList();
        _expertLinks = _document.Links.Select(CloneLink).ToList();
        _expertSql = string.IsNullOrWhiteSpace(_document.CustomSql) ? BuildExpertSql() : _document.CustomSql;
        _expertSqlEditedByUser = !string.IsNullOrWhiteSpace(_document.CustomSql);
        _expertSqlValidationMessage = "";
        _expertSqlValidationSucceeded = null;
        _expertPage = ClonePage(_document.Page);
        _expertHighlightRule = _selectedElement?.HighlightRule.Clone() ?? new ReportDesignerHighlightRule
        {
            FieldName = _selectedElement is null ? "" : CleanCrystalFormula(_selectedElement.Binding),
            Operator = FilterOperators[0],
            Value = "",
            FontStyle = "Default",
            TextColor = _selectedElement?.TextColor ?? "#000000",
            BackgroundColor = _selectedElement?.BackgroundColor ?? "transparent",
            BorderStyle = "Default border style"
        };
        _expertTitle = _document.Title;
        _findResultText = "";
        return Task.CompletedTask;
    }

    private Task CloseExpertAsync()
    {
        _activeExpert = null;
        return Task.CompletedTask;
    }

    private async Task ApplyExpertAsync()
    {
        switch (_activeExpert)
        {
            case DatabaseExpert:
                ApplyDatabaseExpert();
                break;
            case RecordExpert:
                _document.Filters = _expertFilters.Select(CloneFilter).ToList();
                break;
            case GroupExpert:
                ApplyGroupExpert();
                break;
            case GroupSortExpert:
                _document.Groups = _expertGroups.Select(CloneGroup).ToList();
                break;
            case SectionExpert:
                ApplySectionExpert();
                break;
            case SortExpert:
                _document.Sorts = _expertSorts.Select(CloneSort).ToList();
                break;
            case FormulaExpert:
                ApplyFormulaExpert();
                break;
            case ParameterExpert:
                _document.Parameters = _expertParameters.Select(CloneParameter).ToList();
                break;
            case SummaryExpert:
                _document.Summaries = _expertSummaries.Select(CloneSummary).ToList();
                break;
            case PageExpert:
                _document.Page = ClonePage(_expertPage);
                _document.Title = _expertTitle;
                break;
            case TextFormatExpert:
                ApplyTextFormatExpert();
                break;
            case HighlightingExpert:
                ApplyHighlightingExpert();
                break;
            case VisualLinkingExpert:
                _document.Links = _expertLinks.Select(CloneLink).ToList();
                _document.CustomSql = string.IsNullOrWhiteSpace(_expertSql) ? BuildExpertSql() : _expertSql;
                break;
            case RunningTotalExpert:
                _document.Summaries = _expertSummaries.Select(CloneSummary).ToList();
                break;
        }

        RebuildExplorerNodes();
        _activeExpert = null;
        await MarkDirtyAsync();
    }

