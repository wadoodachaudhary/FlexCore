            return _document.SourceName;

        if (!string.IsNullOrWhiteSpace(_document.SourcePath))
            return Path.GetFileName(_document.SourcePath);

        return string.IsNullOrWhiteSpace(_document.Title) ? "Report.rpt" : $"{_document.Title}.rpt";
    }

    private static string SectionDisplayName(string kind)
    {
        return kind switch
        {
            "ReportHeader" => "Report Header",
            "PageHeader" => "Page Header",
            "GroupHeader" => "Group Header",
            "Detail" => "Details",
            "GroupFooter" => "Group Footer",
            "ReportFooter" => "Report Footer",
            "PageFooter" => "Page Footer",
            _ => kind
        };
    }

