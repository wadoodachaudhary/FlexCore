@namespace Fx.ControlKit.Reports

@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.JSInterop

@inject IServiceProvider Services
@inject IJSRuntime JSRuntime

<div class="fx-rd">
    <ToolbarControl CssClass="fx-rd-toolbar crystal">
        @foreach (var toolbarRow in DesignerToolbarRows)
        {
            <div class="@($"fx-rd-toolbar-row{(toolbarRow.Compact ? " compact" : string.Empty)}")">
                @foreach (var item in toolbarRow.Items)
                {
                    @switch (item.Kind)
                    {
                        case ReportDesignerToolbarItemKind.Separator:
                            <span class="fx-rd-separator"></span>
                            break;
                        case ReportDesignerToolbarItemKind.FontFamily:
                            <span class="fx-rd-tool-host wide" title="@item.Tooltip" aria-label="@item.Tooltip">
                                <DropDownListControl TValue="string" TItem="string" DataSource="@FontFamilies" Value="@SelectedFontFamily" ValueChanged="OnFontFamilyChanged" Width="150px" CssClass="fx-rd-toolbar-dd" />
                            </span>
                            break;
                        case ReportDesignerToolbarItemKind.FontSize:
                            <span class="fx-rd-tool-host wide" title="@item.Tooltip" aria-label="@item.Tooltip">
                                <DropDownListControl TValue="decimal" TItem="decimal" DataSource="@FontSizes" Value="@SelectedFontSize" ValueChanged="OnFontSizeChanged" Width="62px" CssClass="fx-rd-toolbar-dd" />
                            </span>
                            break;
                        case ReportDesignerToolbarItemKind.FileOpen:
                            if (AllowFileOpen)
                            {
                                <label class="@ToolbarButtonCss(item)" title="@item.Tooltip" aria-label="@item.Tooltip">
                                    <span class="@ToolbarIconCss(item)" title="@item.Tooltip" aria-hidden="true"></span>
                                    @if (item.HasDropDown)
                                    {
                                        <span class="fx-rd-drop-cue" aria-hidden="true"></span>
                                    }
                                    <InputFile OnChange="OpenFileAsync" accept=".xml,.rpt,text/xml,application/xml" />
                                </label>
                            }
                            break;
                        default:
                            <span class="fx-rd-tool-host" title="@item.Tooltip" aria-label="@item.Tooltip">
                                <ToolbarButtonControl CssClass="@ToolbarButtonCss(item)"
                                                      Title="@item.Tooltip"
                                                      Disabled="@IsToolbarItemDisabled(item)"
                                                      OnClick="@(() => ExecuteToolbarCommandAsync(item.Command))">
                                    <span class="@ToolbarIconCss(item)" title="@item.Tooltip" aria-hidden="true"></span>
                                    @if (item.HasDropDown)
                                    {
                                        <span class="fx-rd-drop-cue" aria-hidden="true"></span>
                                    }
                                </ToolbarButtonControl>
                            </span>
                            break;
                    }
                }
                @if (toolbarRow.ShowStatus)
                {
                    <span class="fx-rd-status @(_document.IsDirty ? "dirty" : "")">@StatusText</span>
                }
            </div>
        }
    </ToolbarControl>

    <div class="fx-rd-shell">
        <main class="fx-rd-stage-wrap">
            <div class="fx-rd-document-tabs">
                <button type="button" class="@(IsDesignDocumentActive ? "active" : "")" @onclick="() => ShowDocumentTab(DesignDocumentTab)">Design</button>
                <button type="button" @onclick="PreviewAsync" disabled="@(!PreviewRequested.HasDelegate)">Preview</button>
                <button type="button" class="@(IsCodeDocumentActive ? "active" : "")" @onclick="() => ShowDocumentTab(CodeDocumentTab)">Code</button>
                <div class="fx-rd-document-title">
                    <strong>@_document.Title</strong>
                    <span>@_document.SourceName</span>
                </div>
            </div>

            <div class="fx-rd-workbench">
                @if (IsCodeDocumentActive)
                {
                    <XmlViewerControl Xml="@CurrentXml"
                                      Title="XML"
                                      OutlineTitle="Report XML"
                                      CssClass="fx-rd-xml-viewer"
                                      Style="flex:1;min-height:0;"
                                      AutoExpandDepth="2" />
                }
                else
                {
                    <ReportDesignerCanvasControl Document="@_document"
                                                 SelectedSection="@_selectedSection"
                                                 SelectedElement="@_selectedElement"
                                                 SectionSelected="SelectSection"
                                                 ElementSelected="SelectElement"
                                                 SectionResized="OnSectionResizedAsync" />
                }
            </div>
        </main>

        <aside class="fx-rd-dock">
            <ExplorerControl Title="@ActiveExplorerTitle"
                             Nodes="@ActiveExplorerNodes"
                             SelectedNode="@_selectedExplorerNode"
                             SelectedNodeChanged="OnExplorerSelectedNodeChanged"
                             OnNodeClick="OnExplorerNodeClickAsync"
                             CssClass="fx-rd-explorer"
                             TreeCssClass="fx-rd-explorer-tree"
                             UseVb6TreeStyle="true"
                             FolderStyle="TreeFolderStyle.None"
                             TreeIndentPixels="20">
                <ToolbarContent>
                    <ToolbarButtonControl CssClass="fx-rd-explorer-tool fx-rd-explorer-tool-insert" Label="" OnClick="AddFieldElement" Disabled="@(!IsFieldExplorerActive || !_document.Fields.Any())" />
                    <ToolbarButtonControl CssClass="fx-rd-explorer-tool fx-rd-explorer-tool-refresh" Label="" OnClick="ReloadAsync" Disabled="@(!CanReload)" />
                    <ToolbarButtonControl CssClass="fx-rd-explorer-tool fx-rd-explorer-tool-formula" Label="" Disabled="true" />
                    <ToolbarButtonControl CssClass="fx-rd-explorer-tool fx-rd-explorer-tool-line" Label="" Disabled="@(_selectedElement is null)" />
                    <ToolbarButtonControl CssClass="fx-rd-explorer-tool fx-rd-explorer-tool-delete" Label="" OnClick="RemoveSelected" Disabled="@(_selectedElement is null)" />
                </ToolbarContent>
                <FooterContent>
                    <ReportDesignerPropertiesControl Document="@_document"
                                                     SelectedSection="@_selectedSection"
                                                     SelectedElement="@_selectedElement"
                                                     Changed="MarkDirtyAsync" />
                    <div class="fx-rd-dock-tabs">
                        <button type="button" class="@(IsFieldExplorerActive ? "active" : "")" @onclick="() => ShowExplorerTab(FieldExplorerTab)">Field Explorer</button>
                        <button type="button" class="@(!IsFieldExplorerActive ? "active" : "")" @onclick="() => ShowExplorerTab(ReportExplorerTab)">Report Explorer</button>
                    </div>
                </FooterContent>
            </ExplorerControl>
        </aside>
    </div>

    <ReportCreationWizardControl Visible="@_showNewReportWizard"
                                 VisibleChanged="OnNewReportWizardVisibleChanged"
                                 DataSources="@WizardDataSources"
                                 Finished="CreateReportFromWizardAsync" />

    <DialogControl Visible="@IsExpertOpen"
                   Header="@ActiveExpertTitle"
                   Width="@ActiveExpertWidth"
                   Height="@ActiveExpertHeight"
                   CssClass="fx-rd-expert-dialog"
                   CloseOnEscape="true"
                   OnClose="CloseExpertAsync">
        <ChildContent>
            @RenderExpertContent()
        </ChildContent>
        <FooterContent>
            <div class="fx-rd-expert-footer">
                <ButtonControl CssClass="fx-rd-expert-primary" OnClick="@(_ => ApplyExpertAsync())">OK</ButtonControl>
                <ButtonControl OnClick="@(_ => CloseExpertAsync())">Cancel</ButtonControl>
                <ButtonControl Disabled="true">Help</ButtonControl>
            </div>
        </FooterContent>
    </DialogControl>
</div>

