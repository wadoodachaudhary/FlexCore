    private IReadOnlyList<ReportDesignerDataTable> ExpertDataSources => GetWizardDataSources();

    private ReportDesignerFilter? ActiveExpertFilter => GetActiveExpertItem(_expertFilters);
    private ReportDesignerGroup? ActiveExpertGroup => GetActiveExpertItem(_expertGroups);
    private ReportDesignerSort? ActiveExpertSort => GetActiveExpertItem(_expertSorts);
    private ReportDesignerField? ActiveExpertFormula => GetActiveExpertItem(_expertFormulaFields);
    private ReportDesignerParameter? ActiveExpertParameter => GetActiveExpertItem(_expertParameters);
    private ReportDesignerSummary? ActiveExpertSummary => GetActiveExpertItem(_expertSummaries);
    private ReportDesignerSection? ActiveExpertSection => GetActiveExpertItem(_expertSections);
    private ReportDesignerDataLink? ActiveExpertLink => GetActiveExpertItem(_expertLinks);

    private T? GetActiveExpertItem<T>(IReadOnlyList<T> items) where T : class
    {
        if (items.Count == 0)
            return null;

        _activeExpertItemIndex = Math.Clamp(_activeExpertItemIndex, 0, items.Count - 1);
        return items[_activeExpertItemIndex];
    }

    private Task OnExpertSelectedTablesChanged(IList<ReportDesignerDataTable> tables)
    {
        _expertSelectedTables = tables.Select(CloneTable).ToList();
        TrimExpertLinksToSelectedTables();
        UpdateExpertSqlFromDesigner();
        return Task.CompletedTask;
    }

    private Task OnExpertGroupFieldsChanged(IList<ReportDesignerField> fields)
    {
        _expertGroupFields = fields.Select(CloneField).ToList();
        _expertGroups = _expertGroupFields
            .Select((field, index) =>
            {
                var existing = _expertGroups.FirstOrDefault(group =>
                    string.Equals(CleanCrystalFormula(group.Condition), field.DisplayName, StringComparison.OrdinalIgnoreCase));
                return new ReportDesignerGroup
                {
                    Name = $"Group #{index + 1}: {field.DisplayName}",
                    Condition = $"{{{field.DisplayName}}}",
                    SortDirection = existing?.SortDirection ?? "Ascending"
                };
            })
            .ToList();
        ClampActiveExpertIndex(_expertGroups.Count);
        return Task.CompletedTask;
    }

    private Task OnExpertSortFieldsChanged(IList<ReportDesignerField> fields)
    {
        _expertSortFields = fields.Select(CloneField).ToList();
        _expertSorts = _expertSortFields
            .Select(field =>
            {
                var existing = _expertSorts.FirstOrDefault(sort =>
                    string.Equals(sort.Field.DisplayName, field.DisplayName, StringComparison.OrdinalIgnoreCase));
                return new ReportDesignerSort
                {
                    Field = CloneField(field),
                    Direction = existing?.Direction ?? "Ascending"
                };
            })
            .ToList();
        ClampActiveExpertIndex(_expertSorts.Count);
        return Task.CompletedTask;
    }

    private Task OnExpertSummaryFieldsChanged(IList<ReportDesignerField> fields)
    {
        _expertSummaryFields = fields.Select(CloneField).ToList();
        _expertSummaries = _expertSummaryFields
            .Select(field =>
            {
                var existing = _expertSummaries.FirstOrDefault(summary =>
                    string.Equals(summary.Field.DisplayName, field.DisplayName, StringComparison.OrdinalIgnoreCase));
                return new ReportDesignerSummary
                {
                    Field = CloneField(field),
                    Operation = existing?.Operation ?? "Sum",
                    GroupName = existing?.GroupName ?? ""
                };
            })
            .ToList();
        ClampActiveExpertIndex(_expertSummaries.Count);
        return Task.CompletedTask;
    }

    private void ClampActiveExpertIndex(int count)
    {
        _activeExpertItemIndex = count == 0 ? 0 : Math.Clamp(_activeExpertItemIndex, 0, count - 1);
    }

    private Task AddExpertFilter()
    {
        var field = AllDesignerFields.FirstOrDefault() ?? new ReportDesignerField { Name = "Field" };
        _expertFilters.Add(new ReportDesignerFilter
        {
            Field = CloneField(field),
            Operator = FilterOperators[0],
            Value = ""
        });
        _activeExpertItemIndex = _expertFilters.Count - 1;
        return Task.CompletedTask;
    }

    private Task DeleteActiveExpertFilter()
    {
        if (ActiveExpertFilter is null)
            return Task.CompletedTask;

        _expertFilters.RemoveAt(_activeExpertItemIndex);
        ClampActiveExpertIndex(_expertFilters.Count);
        return Task.CompletedTask;
    }

    private Task AddExpertFormula()
    {
        var number = _expertFormulaFields.Count + 1;
        _expertFormulaFields.Add(new ReportDesignerField
        {
            Name = $"Formula{number}",
            Formula = $"@Formula{number}",
            Type = "Formula",
            IsFormula = true
        });
        _activeExpertItemIndex = _expertFormulaFields.Count - 1;
        return Task.CompletedTask;
    }

    private Task DeleteActiveExpertFormula()
    {
        if (ActiveExpertFormula is null)
            return Task.CompletedTask;

        _expertFormulaFields.RemoveAt(_activeExpertItemIndex);
        ClampActiveExpertIndex(_expertFormulaFields.Count);
        return Task.CompletedTask;
    }

    private Task AddExpertParameter()
    {
        var number = _expertParameters.Count + 1;
        _expertParameters.Add(new ReportDesignerParameter
        {
            Name = $"Parameter{number}",
            Prompt = $"Parameter {number}",
            Type = "String",
            Required = true
        });
        _activeExpertItemIndex = _expertParameters.Count - 1;
        return Task.CompletedTask;
    }

    private Task DeleteActiveExpertParameter()
    {
        if (ActiveExpertParameter is null)
            return Task.CompletedTask;

        _expertParameters.RemoveAt(_activeExpertItemIndex);
        ClampActiveExpertIndex(_expertParameters.Count);
        return Task.CompletedTask;
    }

    private Task AddExpertLink()
    {
        var first = ExpertLinkTables.FirstOrDefault();
        var second = ExpertLinkTables.Skip(1).FirstOrDefault() ?? first;
        if (first == null || second == null)
            return Task.CompletedTask;

        _expertLinks.Add(new ReportDesignerDataLink
        {
            LeftTable = first.Name,
            LeftField = GetExpertFieldNames(first.Name).FirstOrDefault() ?? "",
            RightTable = second.Name,
            RightField = GetExpertFieldNames(second.Name).FirstOrDefault() ?? "",
            JoinType = JoinTypeChoices[0]
        });
        _activeExpertItemIndex = _expertLinks.Count - 1;
        UpdateExpertSqlFromDesigner();
        return Task.CompletedTask;
    }

    private Task DeleteActiveExpertLink()
    {
        if (ActiveExpertLink is null)
            return Task.CompletedTask;

        _expertLinks.RemoveAt(_activeExpertItemIndex);
        ClampActiveExpertIndex(_expertLinks.Count);
        UpdateExpertSqlFromDesigner();
        return Task.CompletedTask;
    }

    private Task AutoLinkExpertTables()
    {
        _expertLinks.Clear();
        if (ExpertLinkTables.Count < 2)
            return Task.CompletedTask;

        var joined = ExpertLinkTables[0];
        foreach (var table in ExpertLinkTables.Skip(1))
        {
            var match = FindLikelyExpertJoin(joined, table)
                ?? (joined.Fields.FirstOrDefault(), table.Fields.FirstOrDefault());
            if (match.Item1 == null || match.Item2 == null)
                continue;

            _expertLinks.Add(new ReportDesignerDataLink
            {
                LeftTable = joined.Name,
                LeftField = match.Item1.Name,
                RightTable = table.Name,
                RightField = match.Item2.Name,
                JoinType = JoinTypeChoices[0]
            });
        }

        _activeExpertItemIndex = _expertLinks.Count == 0 ? 0 : _expertLinks.Count - 1;
        UpdateExpertSqlFromDesigner();
        return Task.CompletedTask;
    }

    private (ReportDesignerField?, ReportDesignerField?)? FindLikelyExpertJoin(ReportDesignerDataTable left, ReportDesignerDataTable right)
    {
        foreach (var leftField in left.Fields)
        {
            var rightField = right.Fields.FirstOrDefault(candidate =>
                string.Equals(candidate.Name, leftField.Name, StringComparison.OrdinalIgnoreCase));
            if (rightField != null)
                return (leftField, rightField);
        }

        var leftId = left.Fields.FirstOrDefault(field => field.Name.EndsWith("ID", StringComparison.OrdinalIgnoreCase));
        if (leftId != null)
        {
            var rightId = right.Fields.FirstOrDefault(field =>
                string.Equals(field.Name, leftId.Name, StringComparison.OrdinalIgnoreCase) ||
                string.Equals(field.Name, $"{left.Name}ID", StringComparison.OrdinalIgnoreCase));
            if (rightId != null)
                return (leftId, rightId);
        }

        return null;
    }

    private Task OnExpertLinkTableChanged(ReportDesignerDataLink link, bool leftSide, string? value)
    {
        var tableName = value ?? "";
        if (leftSide)
        {
            link.LeftTable = tableName;
            link.LeftField = GetExpertFieldNames(tableName).FirstOrDefault() ?? "";
        }
        else
        {
            link.RightTable = tableName;
            link.RightField = GetExpertFieldNames(tableName).FirstOrDefault() ?? "";
        }

        UpdateExpertSqlFromDesigner();
        return Task.CompletedTask;
    }

    private Task OnExpertLinkFieldChanged(ReportDesignerDataLink link, bool leftSide, string? value)
    {
        if (leftSide)
            link.LeftField = value ?? "";
        else
            link.RightField = value ?? "";

        UpdateExpertSqlFromDesigner();
        return Task.CompletedTask;
    }

    private Task OnExpertLinkJoinTypeChanged(ReportDesignerDataLink link, string? value)
    {
        link.JoinType = value ?? JoinTypeChoices[0];
        UpdateExpertSqlFromDesigner();
        return Task.CompletedTask;
    }

    private IReadOnlyList<string> GetExpertFieldNames(string tableName)
    {
        return ReportDesignerSqlBuilder.GetFieldNamesForTable(tableName, ExpertLinkTables, AllDesignerFields);
    }

    private Task RegenerateExpertSql()
    {
        _expertSql = BuildExpertSql();
        _expertSqlEditedByUser = false;
        _expertSqlValidationMessage = "";
        _expertSqlValidationSucceeded = null;
        return Task.CompletedTask;
    }

    private void OnExpertSqlEdited()
    {
        _expertSqlEditedByUser = true;
        _expertSqlValidationMessage = "";
        _expertSqlValidationSucceeded = null;
    }

    private async Task ValidateExpertSqlAsync()
    {
        if (string.IsNullOrWhiteSpace(_expertSql))
        {
            _expertSqlValidationMessage = "No SQL to validate.";
            _expertSqlValidationSucceeded = false;
            return;
        }

        var executor = Services.GetService<IReportDataExecutor>();
        if (executor == null)
        {
            _expertSqlValidationMessage = "No SQL validator is registered.";
            _expertSqlValidationSucceeded = false;
            return;
        }

        try
        {
            var table = executor.Execute(_expertSql, null);
            _expertSqlValidationMessage = $"SQL valid. Returned {table.Rows.Count} rows and {table.Columns.Count} columns.";
            _expertSqlValidationSucceeded = true;
        }
        catch (Exception ex)
        {
            _expertSqlValidationMessage = $"SQL validation failed: {ex.Message}";
            _expertSqlValidationSucceeded = false;
        }

        await Task.CompletedTask;
    }

    private void UpdateExpertSqlFromDesigner()
    {
        if (_expertSqlEditedByUser)
            return;

        _expertSql = BuildExpertSql();
        _expertSqlValidationMessage = "";
        _expertSqlValidationSucceeded = null;
    }

    private string BuildExpertSql()
    {
        return ReportDesignerSqlBuilder.BuildSql(ExpertLinkTables, AllDesignerFields, _expertLinks, _expertFilters);
    }

    private void TrimExpertLinksToSelectedTables()
    {
        var tableNames = _expertSelectedTables
            .Select(table => table.Name)
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        if (tableNames.Count == 0)
        {
            _expertLinks.Clear();
            _activeExpertItemIndex = 0;
            return;
        }

        _expertLinks = _expertLinks
            .Where(link => tableNames.Contains(link.LeftTable) && tableNames.Contains(link.RightTable))
            .ToList();
        ClampActiveExpertIndex(_expertLinks.Count);
    }

    private Task EnableHighlightRule()
    {
        _expertHighlightRule.Enabled = true;
        if (string.IsNullOrWhiteSpace(_expertHighlightRule.FieldName))
            _expertHighlightRule.FieldName = "this field";
        return Task.CompletedTask;
    }

    private Task RemoveHighlightRule()
    {
        _expertHighlightRule = new ReportDesignerHighlightRule();
        return Task.CompletedTask;
    }

    private void ApplyTextFormatExpert()
    {
    }

    private void ApplyHighlightingExpert()
    {
        if (_selectedElement is null)
            return;

        _selectedElement.HighlightRule = _expertHighlightRule.Clone();
        if (_expertHighlightRule.Enabled)
        {
            _selectedElement.TextColor = _expertHighlightRule.TextColor;
            _selectedElement.BackgroundColor = _expertHighlightRule.BackgroundColor;
            if (_expertHighlightRule.FontStyle.Contains("Bold", StringComparison.OrdinalIgnoreCase))
                _selectedElement.Bold = true;
            if (_expertHighlightRule.FontStyle.Contains("Italic", StringComparison.OrdinalIgnoreCase))
                _selectedElement.Italic = true;
        }
    }

    private async Task FindNextInReportAsync()
    {
        if (string.IsNullOrWhiteSpace(_findText))
        {
            _findResultText = "Enter text to find.";
            return;
        }

        var match = _document.Sections
            .SelectMany(section => section.Elements.Select(element => new ReportDesignerElementSelection { Section = section, Element = element }))
            .FirstOrDefault(selection =>
                selection.Element.DisplayText.Contains(_findText, StringComparison.OrdinalIgnoreCase) ||
                selection.Element.Name.Contains(_findText, StringComparison.OrdinalIgnoreCase) ||
                selection.Element.Binding.Contains(_findText, StringComparison.OrdinalIgnoreCase));

        if (match is null)
        {
            _findResultText = $"No report object contains '{_findText}'.";
            return;
        }

        SelectElement(match.Section, match.Element);
        ShowExplorerTab(ReportExplorerTab);
        _findResultText = $"Found: {match.Element.Name} in {GetReportSectionExplorerLabel(match.Section)}.";
        await Task.CompletedTask;
    }

    private static string BuildHighlightCondition(ReportDesignerHighlightRule rule)
    {
        if (!rule.Enabled)
            return "";

        var field = string.IsNullOrWhiteSpace(rule.FieldName) ? "this field" : rule.FieldName;
        return $"{field} {rule.Operator} {rule.Value}";
    }

    private string BuildFilterFormulaPreview()
    {
        if (_expertFilters.Count == 0)
            return "";

        return string.Join(" and" + Environment.NewLine, _expertFilters.Select(filter =>
            $"{CrystalFormulaName(filter.Field)} {FilterOperatorToFormula(filter.Operator)} {FormatFilterValue(filter.Value)}"));
    }

    private static string CrystalFormulaName(ReportDesignerField field)
    {
        return string.IsNullOrWhiteSpace(field.DisplayName) ? "{Field}" : $"{{{field.DisplayName}}}";
    }

    private static string FilterOperatorToFormula(string value)
    {
        return value switch
        {
            "is not equal to" => "<>",
            "is less than" => "<",
            "is less than or equal to" => "<=",
            "is greater than" => ">",
            "is greater than or equal to" => ">=",
            "contains" => "contains",
            "does not contain" => "does not contain",
            "begins with" => "starts with",
            "ends with" => "ends with",
            _ => "="
        };
    }

    private static string FormatFilterValue(string value)
    {
        if (decimal.TryParse(value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out _))
            return value;

        return $"'{value.Replace("'", "''", StringComparison.Ordinal)}'";
    }

    private void ApplyDatabaseExpert()
    {
        _document.DataSources = _expertSelectedTables.Select(CloneTable).ToList();
        var formulaFields = _document.Fields.Where(field => field.IsFormula).Select(CloneField).ToList();
        var tableFields = _document.DataSources.SelectMany(table => table.Fields).Select(CloneField);
        _document.Fields = tableFields
            .Concat(formulaFields)
            .GroupBy(field => field.DisplayName, StringComparer.OrdinalIgnoreCase)
            .Select(group => group.First())
            .ToList();
    }

    private void ApplyGroupExpert()
    {
        _document.Groups = _expertGroupFields
            .Select((field, index) =>
            {
                var existing = _expertGroups.FirstOrDefault(group =>
                    string.Equals(CleanCrystalFormula(group.Condition), field.DisplayName, StringComparison.OrdinalIgnoreCase));
                return new ReportDesignerGroup
                {
                    Name = $"Group #{index + 1}: {field.DisplayName}",
                    Condition = $"{{{field.DisplayName}}}",
                    SortDirection = existing?.SortDirection ?? "Ascending"
                };
            })
            .ToList();
    }

    private void ApplySectionExpert()
    {
        foreach (var edited in _expertSections)
        {
            var section = _document.Sections.FirstOrDefault(candidate =>
                string.Equals(candidate.Id, edited.Id, StringComparison.Ordinal) ||
                string.Equals(candidate.Name, edited.Name, StringComparison.OrdinalIgnoreCase));
            if (section is null)
                continue;

            section.HeightTwips = edited.HeightTwips;
            section.HideForDrillDown = edited.HideForDrillDown;
            section.IsSuppressed = edited.IsSuppressed;
            section.PrintAtBottomOfPage = edited.PrintAtBottomOfPage;
            section.SuppressIfBlank = edited.SuppressIfBlank;
            section.UnderlayFollowingSections = edited.UnderlayFollowingSections;
            section.ReadOnly = edited.ReadOnly;
            section.RelativePositions = edited.RelativePositions;
            section.NewPageBefore = edited.NewPageBefore;
            section.NewPageAfter = edited.NewPageAfter;
            section.ResetPageNumberAfter = edited.ResetPageNumberAfter;
            section.KeepTogether = edited.KeepTogether;
            section.BackgroundColor = edited.BackgroundColor;
        }
    }

    private void ApplyFormulaExpert()
    {
        var nonFormulaFields = _document.Fields.Where(field => !field.IsFormula).Select(CloneField);
        var formulaFields = _expertFormulaFields
            .Where(field => !string.IsNullOrWhiteSpace(field.Name))
            .Select(field =>
            {
                var clone = CloneField(field);
                clone.IsFormula = true;
                if (string.IsNullOrWhiteSpace(clone.Type))
                    clone.Type = "Formula";
                return clone;
            });
        _document.Fields = nonFormulaFields
            .Concat(formulaFields)
            .GroupBy(field => field.DisplayName, StringComparer.OrdinalIgnoreCase)
            .Select(group => group.First())
            .ToList();
    }

