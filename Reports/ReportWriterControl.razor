    /// <summary>
    /// Loads a Crystal Report .rpt file, sets parameters, renders to PDF, and displays in iframe.
    /// </summary>
    public async Task ShowCrystalReport(string rptFilePath, params (string Name, object? Value)[] parameters)
    {
        await ShowCrystalReport(rptFilePath, parameters.ToDictionary(p => p.Name, p => p.Value?.ToString() ?? ""));
    }

    /// <summary>
    /// Loads a Crystal Report .rpt file with dictionary parameters.
    /// </summary>
    public async Task ShowCrystalReport(string rptFilePath, Dictionary<string, string> parameters)
    {
        IsLoading = true;
        ErrorMessage = null;
        PdfDataUrl = "";
        Tabs.Clear();
        await InvokeAsync(StateHasChanged);

        try
        {
            if (CrystalSvc == null)
            {
                ErrorMessage = "No Crystal Reports exporter is registered with the host.";
                Logger.LogWarning("ShowCrystalReport called but IReportExporter is not registered.");
                return;
            }
            CrystalSvc.LoadReport(rptFilePath);
            CrystalSvc.SetParameters(parameters);

            var pdfBytes = CrystalSvc.ExportToPdf();
            PdfDataUrl = $"data:application/pdf;base64,{Convert.ToBase64String(pdfBytes)}";

            Logger.LogInformation("Crystal Report rendered: {File} ({Pages} bytes PDF)", rptFilePath, pdfBytes.Length);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to render Crystal Report: {File}", rptFilePath);
            ErrorMessage = $"Failed to load report: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    // ═══════════════════════════════════════════════════════════════
    // Crystal XML Report rendering (CR definition exported as .xml)
    // ═══════════════════════════════════════════════════════════════

    /// <summary>
    /// Loads a Crystal Reports XML definition, parses it into a <see cref="ReportDefinition"/>,
    /// and renders it as an HTML report (Option 4).
    ///
    /// Use when the report runtime is NOT available (Linux, macOS, containers) — the XML
    /// export contains enough metadata (tables, joins, WHERE formula, groups, parameters,
    /// detail columns) to rebuild the report as a SQL-driven HTML table.
    /// </summary>
    /// <param name="xmlFilePath">Absolute path to the Crystal Reports .xml export.</param>
    /// <param name="parameters">Parameter values (e.g. <c>{"Worksheet", 12345}</c>, <c>{"TenantId", 1}</c>).</param>
    public async Task ShowXmlReport(string xmlFilePath, Dictionary<string, object>? parameters = null)
    {
        IsLoading = true;
        ErrorMessage = null;
        PdfDataUrl = "";
        Tabs.Clear();
        ActiveTabIndex = 0;
        await InvokeAsync(StateHasChanged);

        try
        {
            // Parse the Crystal Reports XML into a ReportDefinition
            var definition = XmlLoader.Load(xmlFilePath);

            // Track source path + parameters so drill-down tabs can re-query.
            _xmlFilePath = xmlFilePath;
            _lastParameters = parameters ?? new Dictionary<string, object>();

            // Auto-inject configured session parameters (see ReportOptions.SessionAutoInjectParameters) if the
            // report's SQL references them. Fully generic — driven by ReportOptions.
            parameters ??= new Dictionary<string, object>();
            AutoInjectSessionParameters(parameters, definition.Sql);

            await ShowSqlReport(definition, parameters);
            Logger.LogInformation("Crystal XML report rendered: {File}", xmlFilePath);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to render Crystal XML report: {File}", xmlFilePath);
            ErrorMessage = $"Failed to load XML report: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    /// <summary>
    /// Exports the currently loaded Crystal Report to the specified format.
    /// Returns null when no <see cref="IReportExporter"/> is registered (the
    /// host should fall back to browser print-to-PDF in that case).
    /// </summary>
    public Task<byte[]?> ExportCrystalReport(string format)
    {
        try
        {
            if (CrystalSvc == null) return Task.FromResult<byte[]?>(null);
            return Task.FromResult<byte[]?>(format.ToUpperInvariant() switch
            {
                "PDF" => CrystalSvc.ExportToPdf(),
                "EXCEL" or "XLS" => CrystalSvc.ExportToExcel(),
                "WORD" or "DOC" => CrystalSvc.ExportToWord(),
                "RTF" => CrystalSvc.ExportToRtf(),
                "CSV" => CrystalSvc.ExportToCsv(),
                _ => CrystalSvc.ExportToPdf()
            });
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Crystal Report export failed: {Format}", format);
            return Task.FromResult<byte[]?>(null);
        }
    }

    // ═══════════════════════════════════════════════════════════════
    // SQL Report rendering (Option 4: SQL → HTML/CSS → PDF)
    // ═══════════════════════════════════════════════════════════════

    /// <summary>
    /// Executes a SQL-based report definition and renders it as paginated HTML.
    /// </summary>
    public async Task ShowSqlReport(ReportDefinition definition, Dictionary<string, object>? parameterValues = null)
    {
        IsLoading = true;
        ErrorMessage = null;
        PdfDataUrl = "";
        Tabs.Clear();
        ActiveTabIndex = 0;
        await InvokeAsync(StateHasChanged);

        try
        {
            // Build parameter object for SQL query
            var sqlParams = new Dictionary<string, object>();
            foreach (var paramDef in definition.Parameters)
            {
                if (parameterValues?.TryGetValue(paramDef.Name, out var val) == true)
                    sqlParams[paramDef.Name] = val;
                else if (!string.IsNullOrEmpty(paramDef.DefaultValue))
                    sqlParams[paramDef.Name] = paramDef.DefaultValue;
            }

            // Forward any caller-supplied parameter that wasn't explicitly declared in the definition
            // (e.g. host-injected session parameters, or parameters the XML loader missed).
            if (parameterValues != null)
            {
                foreach (var kv in parameterValues)
                {
                    if (!sqlParams.ContainsKey(kv.Key))
                        sqlParams[kv.Key] = kv.Value;
                }
            }

            // Auto-inject configured session parameters (see ReportOptions.SessionAutoInjectParameters; extend
            // via ReportOptions.SessionAutoInjectParameters for other well-known keys).
            AutoInjectSessionParameters(sqlParams, definition.Sql);

            // Log what we're about to run so users can see parameter values when a query
            // unexpectedly returns 0 rows (column type mismatch, wrong session value, etc).
            Logger.LogInformation("Main report parameters: {Params}",
                string.Join(", ", sqlParams.Select(kv => $"{kv.Key}={kv.Value} ({kv.Value?.GetType().Name})")));
            Logger.LogInformation("Main report SQL:\n{Sql}", definition.Sql);

            // Execute SQL
            var dt = db.Execute(definition.Sql, sqlParams.Count > 0 ? sqlParams : null);
            GuardRowLimit(dt);
            Logger.LogInformation("Main report returned {Rows} rows", dt.Rows.Count);

            // Render to HTML pages
            var visibleColumns = definition.Columns.Where(c => !c.Hidden).ToList();
            // Compute rows-per-page here so RenderHtmlPages and BuildGroupTree stay in sync
            // (the tree needs to know which page each group's first row lands on).
            var rowsPerPage = definition.RowsPerPage > 0
                ? definition.RowsPerPage
                // Fallback when the report definition didn't carry a row cap
                  // (e.g. code-built reports). Now interpreted as a cap on
                  // total VISIBLE rows (data + group headers + footers) — the
                  // splitter counts each transition's overhead so the cap
                  // gives a uniform visual page height regardless of how
                  // many transitions a particular page contains.
                  : (definition.Orientation == ReportOrientation.Landscape ? 49 : 70);

            // If the definition includes a separate TreeSql, run it to populate the tree
            // with ALL group levels (outermost → innermost). Without this the tree would
            // only show the groups in the summary SELECT, hiding deeper drill targets
            // that exist solely in the detail-level hierarchy.
            var treeData = dt;
            if (!string.IsNullOrWhiteSpace(definition.TreeSql))
            {
                try
                {
                    treeData = db.Execute(definition.TreeSql, sqlParams.Count > 0 ? sqlParams : null);
                    Logger.LogInformation("Tree SQL returned {Rows} hierarchy rows", treeData.Rows.Count);
                }
                catch (Exception treeEx)
                {
                    Logger.LogWarning(treeEx, "Tree SQL failed — falling back to main result for tree");
                    treeData = dt;
                }
            }

            // Adaptive column-width pass: honor the XML's stated widths as
            // hints (which is what VB6 uses), then expand numeric columns to
            // fully fit header + widest value, and distribute remaining space
            // to text columns so they fit on one line where possible.
            ComputeAdaptiveColumnWidths(definition, visibleColumns, dt);

            // Populate the Main Report tab (index 0). Drill-downs are appended by OpenDrillDown.
            var mainTab = new ReportTab
            {
                Title = "Main Report",
                Path = new(),  // empty path = no drill
                Pages = RenderHtmlPages(definition, dt, visibleColumns),
                Tree = BuildGroupTree(treeData, definition, rowsPerPage),
                CurrentPage = 1,
                Orientation = definition.Orientation
            };
            Tabs.Add(mainTab);
            ActiveTabIndex = 0;

            // Remember parameters for drill-down queries.
            _lastParameters = parameterValues != null
                ? new Dictionary<string, object>(parameterValues)
                : new Dictionary<string, object>();

            Logger.LogInformation("SQL Report rendered: {Title} ({Rows} rows, {Pages} pages, {Groups} top groups)",
                definition.Title, dt.Rows.Count, mainTab.Pages.Count, mainTab.Tree.Count);

            OnRenderComplete?.Invoke();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to render SQL report: {Title}", definition.Title);
            ErrorMessage = $"Report error: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    /// <summary>
    /// Renders a DataTable as an HTML report (for ShowSQLReport-style usage).
    /// </summary>
    public async Task ShowDataTableReport(string title, DataTable data, ReportOrientation orientation = ReportOrientation.Portrait)
    {
        IsLoading = true;
        ErrorMessage = null;
        PdfDataUrl = "";
        Tabs.Clear();
        // Orientation is now stored on each tab; set in the tab construction below.
        await InvokeAsync(StateHasChanged);

        try
        {
            // Auto-generate columns from DataTable
            var definition = new ReportDefinition
            {
                Title = title,
                Orientation = orientation
            };
            foreach (DataColumn col in data.Columns)
            {
                var reportCol = new ReportColumn
                {
                    Field = col.ColumnName,
                    HeaderText = col.ColumnName,
                    ColumnType = MapDataType(col.DataType)
                };
                // Auto-align numbers right
                if (reportCol.ColumnType is ReportColumnType.Decimal or ReportColumnType.Currency or ReportColumnType.Integer)
                    reportCol.Alignment = ReportAlignment.Right;
                definition.Columns.Add(reportCol);
            }

            var visibleColumns = definition.Columns;
            // Populate Main Report tab for the DataTable-driven path.
            Tabs.Clear();
            Tabs.Add(new ReportTab
            {
                Title = "Main Report",
                Pages = RenderHtmlPages(definition, data, visibleColumns),
                Tree = new(),
                CurrentPage = 1,
                Orientation = orientation
            });
            ActiveTabIndex = 0;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to render DataTable report");
            ErrorMessage = $"Report error: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    /// <summary>Triggers the browser print dialog for the rendered report.</summary>
    public async Task Print()
    {
        await JSRuntime.InvokeVoidAsync("window.print");
    }

    /// <summary>Clears the current report.</summary>
    public void Clear()
    {
        PdfDataUrl = "";
        Tabs.Clear();
        ActiveTabIndex = 0;
        ErrorMessage = null;
        // Closing the Crystal engine is the host's responsibility — IReportExporter
        // doesn't expose a Close() because not all implementations need one.
        StateHasChanged();
    }

    // ═══════════════════════════════════════════════════════════════
    //  UNIFIED ENTRY POINT — ShowReportAsync
    //  ─────────────────────────────────────────────────────────────
    //  Single high-level call that:
    //    1. Decides .rpt vs .xml. If only the .rpt exists, converts it to
    //       XML with the native C# converter before rendering.
    //    2. Prompts the user (via the embedded ReportParamDialogControl)
    //       for any required parameters not pre-supplied.
    //    3. Runs MultiValueParameterRewriter so dual-list-box selections
    //       become IN-clause expansions.
    //    4. Routes to ShowSqlReport and updates
    //       toolbar / status-bar state.
    //
    //  Replaces FRptViewer's old per-page ShowReport orchestration —
    //  thin host pages just call this and wire OnClose.
    // ═══════════════════════════════════════════════════════════════

    /// <summary>
    /// Load and render a report by path (.rpt or .xml). Prompts the
    /// user for any required parameters not supplied via
    /// <paramref name="seedParameters"/>. Auto-injects
    /// <c>DivisionID</c> from the session context.
    /// </summary>
    public async Task ShowReportAsync(string file, IReadOnlyDictionary<string, string>? seedParameters = null)
    {
        try
        {
            IsLoading = true;
            ReportFilePath = file;
            await OnPageTitleChanged.InvokeAsync(Path.GetFileNameWithoutExtension(file));
            StatusMessage = $"Loading report: {file}";
            await InvokeAsync(StateHasChanged);

            _seedParameters.Clear();
            if (seedParameters != null)
                foreach (var kv in seedParameters)
                    if (!string.IsNullOrEmpty(kv.Value))
                        _seedParameters[kv.Key] = kv.Value;
            if (!_seedParameters.ContainsKey("DivisionID"))
            {
                var divId = SessionState.Get("DivisionID");
                if (divId != null) _seedParameters["DivisionID"] = divId.ToString() ?? "";
            }

            if (!file.EndsWith(".rpt", StringComparison.OrdinalIgnoreCase)
                && !file.EndsWith(".xml", StringComparison.OrdinalIgnoreCase))
            {
                StatusMessage = $"Unsupported report extension: {file}";
                return;
            }

            // Prefer an existing XML export. If only the .rpt is available,
            // materialize the XML with the native C# converter and render that.
            var xmlPath = await ResolveOrConvertXmlPathAsync(file);
            if (xmlPath != null)
            {
                var definition = XmlLoader.Load(xmlPath);
                var typedParams = _seedParameters.ToDictionary(p => p.Key, p => (object)p.Value);

                var missingRequired = definition.Parameters
                    .Where(p => p.Required
                        && !typedParams.ContainsKey(p.Name)
                        && !string.Equals(p.Name, "DivisionID", StringComparison.OrdinalIgnoreCase))
                    .ToList();

                if (missingRequired.Count > 0 && _paramDialog != null)
                {
                    StatusMessage = "Waiting for parameter values...";
                    IsLoading = false;
                    await InvokeAsync(StateHasChanged);

                    var title = $"Report: {Path.GetFileNameWithoutExtension(xmlPath)}";
                    var userValues = await _paramDialog.PromptAsync(title, missingRequired, _lastPromptedValues);
                    if (userValues == null)
                    {
                        StatusMessage = "Report cancelled.";
                        return;
                    }
                    foreach (var kv in userValues)
                        typedParams[kv.Key] = kv.Value;

                    IsLoading = true;
                    StatusMessage = $"Loading report: {xmlPath}";
                    await InvokeAsync(StateHasChanged);
                }

                // Snapshot pre-rewrite values for the "Parameters" re-prompt.
                _lastPromptedValues = new Dictionary<string, object>(typedParams, StringComparer.OrdinalIgnoreCase);

                // Multi-value rewrite: string[] entries become IN (@N_0, @N_1, ...).
                var multiSelections = new Dictionary<string, IReadOnlyList<string>>(StringComparer.OrdinalIgnoreCase);
                foreach (var key in typedParams.Keys.ToList())
                {
                    if (typedParams[key] is string[] arr)
                    {
                        multiSelections[key] = arr;
                        typedParams.Remove(key);
                    }
                }
                if (multiSelections.Count > 0)
                {
                    typedParams = MultiValueParameterRewriter.Apply(definition, multiSelections, typedParams);

                    // Drill-down tabs re-load a fresh definition from the
                    // XML — with the ORIGINAL "= @Param" predicates. Capture
                    // the multi-value selections in DefinitionPostProcessor
                    // so OpenDrillDown rewrites the drill SQL to use the
                    // same IN-expansion the main report got. Without this,
                    // drill SQL would compare against @Community alone
                    // (whichever value SQL Server binds first) and never
                    // match rows from any other picked community.
                    var capturedSelections = multiSelections;
                    DefinitionPostProcessor = drillDef =>
                    {
                        MultiValueParameterRewriter.Apply(
                            drillDef, capturedSelections, new Dictionary<string, object>());
                    };
                }
                else
                {
                    // No multi-value selection this run — clear any
                    // postprocessor from a prior load so a subsequent
                    // drill doesn't get stale rewrites applied.
                    DefinitionPostProcessor = null;
                }

                SetXmlSource(xmlPath);
                await ShowSqlReport(definition, typedParams);
                ReportLoaded = true;
                StatusMessage = $"Print Preview - {Path.GetFileNameWithoutExtension(xmlPath)} (XML)";
            }
            else
            {
                // Report XML missing on disk — surface a clear, VISIBLE
                // "<filename> not Found" message (the fx-report-error block,
                // not just a status-bar line) so the user sees exactly which
                // report definition is absent.
                var missingName = Path.GetFileName(file);
                ErrorMessage = $"{missingName} not Found";
                StatusMessage = $"{missingName} not Found";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
            StatusMessage = $"Error: {ex.Message}";
            Logger.LogError(ex, "ShowReportAsync failed for {File}", file);
        }
        finally
        {
            IsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    /// <summary>
    /// Resolves the XML sibling for a given .rpt / .xml path. Looks for
    /// .../Reports/xml/Foo.xml when the input lives under .../Reports/rpt/,
    /// otherwise checks a sibling .xml in the same folder.
    /// </summary>
    private static string? ResolveXmlPathLocal(string file)
    {
        if (string.IsNullOrWhiteSpace(file)) return null;
        if (file.EndsWith(".xml", StringComparison.OrdinalIgnoreCase))
            return File.Exists(file) ? file : null;
        var dir = Path.GetDirectoryName(file) ?? "";
        var baseName = Path.GetFileNameWithoutExtension(file);
        if (!string.IsNullOrEmpty(dir) &&
            Path.GetFileName(dir).Equals("rpt", StringComparison.OrdinalIgnoreCase))
        {
            var xmlDir = Path.Combine(Path.GetDirectoryName(dir) ?? "", "xml");
            var candidate = Path.Combine(xmlDir, baseName + ".xml");
            if (File.Exists(candidate)) return candidate;
        }
        var sibling = Path.Combine(dir, baseName + ".xml");
        if (File.Exists(sibling)) return sibling;
        return null;
    }

    private async Task<string?> ResolveOrConvertXmlPathAsync(string file)
    {
        var xmlPath = ResolveXmlPathLocal(file);
        if (xmlPath != null || !file.EndsWith(".rpt", StringComparison.OrdinalIgnoreCase))
            return xmlPath;

        if (OperatingSystem.IsBrowser())
            throw new NotSupportedException("Crystal .rpt conversion requires server-side .NET because it reads the report binary from disk.");

        var outputPath = GetDefaultXmlOutputPath(file);
        Logger.LogInformation("Converting Crystal RPT for viewer: {Rpt} -> {Xml}", file, outputPath);

        var result = await CrystalRptToXml.ConvertAsync(
            file,
            outputPath,
            new CrystalRptConversionOptions(
                ExtractSubreports: true,
                Progress: message => Logger.LogDebug("RptToXml: {Message}", message)));

        return result.ReportXmlPath;
    }

    private static string GetDefaultXmlOutputPath(string rptFilePath)
    {
        var dir = Path.GetDirectoryName(rptFilePath) ?? "";
        var baseName = Path.GetFileNameWithoutExtension(rptFilePath);
        if (!string.IsNullOrEmpty(dir) &&
            Path.GetFileName(dir).Equals("rpt", StringComparison.OrdinalIgnoreCase))
        {
            return Path.Combine(Path.GetDirectoryName(dir) ?? "", "xml", baseName + ".xml");
        }

        return Path.Combine(dir, baseName + ".xml");
    }

