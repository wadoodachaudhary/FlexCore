    public Task<byte[]?> ExportCrystalReport(string format)
    {
        try
        {
            if (CrystalSvc == null) return Task.FromResult<byte[]?>(null);
            return Task.FromResult<byte[]?>(format.ToUpperInvariant() switch
            {
                "PDF" => CrystalSvc.ExportToPdf(),
                "EXCEL" or "XLS" => CrystalSvc.ExportToExcel(),
                "WORD" or "DOC" => CrystalSvc.ExportToWord(),
                "RTF" => CrystalSvc.ExportToRtf(),
                "CSV" => CrystalSvc.ExportToCsv(),
                _ => CrystalSvc.ExportToPdf()
            });
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Crystal Report export failed: {Format}", format);
            return Task.FromResult<byte[]?>(null);
        }
    }

    public async Task ShowSqlReport(ReportDefinition definition, Dictionary<string, object>? parameterValues = null)
    {
        IsLoading = true;
        ErrorMessage = null;
        PdfDataUrl = "";
        Tabs.Clear();
        ActiveTabIndex = 0;
        await InvokeAsync(StateHasChanged);

        try
        {
            var sqlParams = new Dictionary<string, object>();
            foreach (var paramDef in definition.Parameters)
            {
                if (parameterValues?.TryGetValue(paramDef.Name, out var val) == true)
                    sqlParams[paramDef.Name] = val;
                else if (!string.IsNullOrEmpty(paramDef.DefaultValue))
                    sqlParams[paramDef.Name] = paramDef.DefaultValue;
            }

            if (parameterValues != null)
            {
                foreach (var kv in parameterValues)
                {
                    if (!sqlParams.ContainsKey(kv.Key))
                        sqlParams[kv.Key] = kv.Value;
                }
            }

            AutoInjectSessionParameters(sqlParams, definition.Sql);

            Logger.LogInformation("Main report parameters: {Params}",
                string.Join(", ", sqlParams.Select(kv => $"{kv.Key}={kv.Value} ({kv.Value?.GetType().Name})")));
            Logger.LogInformation("Main report SQL:\n{Sql}", definition.Sql);

            var dt = db.Execute(definition.Sql, sqlParams.Count > 0 ? sqlParams : null);
            GuardRowLimit(dt);
            Logger.LogInformation("Main report returned {Rows} rows", dt.Rows.Count);

            var visibleColumns = definition.Columns.Where(c => !c.Hidden).ToList();
            var rowsPerPage = definition.RowsPerPage > 0
                ? definition.RowsPerPage
                  : (definition.Orientation == ReportOrientation.Landscape ? 49 : 70);

            var treeData = dt;
            if (!string.IsNullOrWhiteSpace(definition.TreeSql))
            {
                try
                {
                    treeData = db.Execute(definition.TreeSql, sqlParams.Count > 0 ? sqlParams : null);
                    Logger.LogInformation("Tree SQL returned {Rows} hierarchy rows", treeData.Rows.Count);
                }
                catch (Exception treeEx)
                {
                    Logger.LogWarning(treeEx, "Tree SQL failed — falling back to main result for tree");
                    treeData = dt;
                }
            }

            ComputeAdaptiveColumnWidths(definition, visibleColumns, dt);

            var mainTab = new ReportTab
            {
                Title = "Main Report",
                Path = new(),  // empty path = no drill
                Pages = RenderHtmlPages(definition, dt, visibleColumns),
                Tree = BuildGroupTree(treeData, definition, rowsPerPage),
                CurrentPage = 1,
                Orientation = definition.Orientation
            };
            Tabs.Add(mainTab);
            ActiveTabIndex = 0;

            _lastParameters = parameterValues != null
                ? new Dictionary<string, object>(parameterValues)
                : new Dictionary<string, object>();

            Logger.LogInformation("SQL Report rendered: {Title} ({Rows} rows, {Pages} pages, {Groups} top groups)",
                definition.Title, dt.Rows.Count, mainTab.Pages.Count, mainTab.Tree.Count);

            OnRenderComplete?.Invoke();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to render SQL report: {Title}", definition.Title);
            ErrorMessage = $"Report error: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

