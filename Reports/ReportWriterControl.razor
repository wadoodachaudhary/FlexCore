    private static readonly int[] ZoomSteps = new[] { 25, 50, 75, 100, 125, 150, 200 };

    private async Task ChromeOnZoomIn()
    {
        var cur = ZoomLevel > 0 ? ZoomLevel : 100;
        var next = ZoomSteps.FirstOrDefault(s => s > cur);
        ZoomLevel = next == 0 ? 200 : next;
        await ChromeOnZoomChanged();
    }

    private async Task ChromeOnZoomOut()
    {
        var cur = ZoomLevel > 0 ? ZoomLevel : 100;
        var prev = ZoomSteps.LastOrDefault(s => s < cur);
        ZoomLevel = prev == 0 ? 25 : prev;
        await ChromeOnZoomChanged();
    }

