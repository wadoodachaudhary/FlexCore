                <span class="fx-rpt-toolbar-label">Print</span>
            </ToolbarButtonControl>

            <div class="fx-rpt-export-menu @(ExportMenuOpen ? "open" : "")">
                <ToolbarButtonControl Vertical="true" OnClick="ToggleExportMenu">
                    <span style="font-size:18px;">📤</span>
                    <span class="fx-rpt-toolbar-label">Export ▾</span>
                </ToolbarButtonControl>
                <div class="fx-rpt-export-items">
                    <button @onclick='() => ChromeOnExport("PDF")'>📄 PDF</button>
                    <button @onclick='() => ChromeOnExport("Excel")'>📊 Excel</button>
                    <button @onclick='() => ChromeOnExport("Word")'>📝 Word</button>
                    <button @onclick='() => ChromeOnExport("CSV")'>📋 CSV</button>
                </div>
            </div>

            <ToolbarSeparatorControl />

            <ToolbarButtonControl Vertical="true" OnClick="ChromeOnRefresh">
                <span style="font-size:18px;">🔄</span>
                <span class="fx-rpt-toolbar-label">Refresh</span>
            </ToolbarButtonControl>

            <ToolbarSeparatorControl />

            <div class="fx-rpt-zoom-controls">
                <ToolbarButtonControl OnClick="ChromeOnZoomOut">
                    <span style="font-size:16px;">🔍−</span>
