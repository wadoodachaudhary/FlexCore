    // Page navigation — drives the toolbar's first/prev/page#/next/last.
    private void OnFirstPage() => JumpTo(1);
    private void OnPreviousPage() => JumpTo(CurrentPage - 1);
    private void OnNextPage() => JumpTo(CurrentPage + 1);
    private void OnLastPage() => JumpTo(PageCount);
    private void OnPageChanged(int target) => JumpTo(target);
    private void JumpTo(int target)
    {
        var clamped = Math.Max(1, Math.Min(target, PageCount));
        if (ActiveTab != null) ActiveTab.CurrentPage = clamped;
    }

    private async Task ChromeOnPrint() => await Print();

    private void ToggleExportMenu() => ExportMenuOpen = !ExportMenuOpen;

    private async Task ChromeOnExport(string format)
    {
        ExportMenuOpen = false;
        StatusMessage = $"Exporting as {format}...";
        await InvokeAsync(StateHasChanged);
        try
        {
            // Browser print-to-PDF works in all browsers for the HTML
            // report. For Crystal-Engine export of richer formats hosts
            // can extend IReportExporter.
            await JSRuntime.InvokeVoidAsync("window.print");
            StatusMessage = $"Export ({format}) sent to browser.";
        }
        catch (Exception ex)
        {
            StatusMessage = $"Export failed: {ex.Message}";
            Logger.LogError(ex, "Export {Format} failed", format);
        }
    }

    private async Task ChromeOnRefresh()
    {
        if (string.IsNullOrEmpty(ReportFilePath)) return;
        await ShowReportAsync(ReportFilePath, _seedParameters);
    }

    private async Task ChromeOnEditParameters()
    {
        if (string.IsNullOrEmpty(ReportFilePath)) return;
        // Re-run with no pre-seeded values — the dialog re-opens with
        // the user's last selections (we cached them in _lastPromptedValues).
        _seedParameters.Clear();
        var divId = SessionState.Get("DivisionID");
        if (divId != null) _seedParameters["DivisionID"] = divId.ToString() ?? "";
        await ShowReportAsync(ReportFilePath, null);
    }

    private async Task ChromeOnZoomChanged()
    {
        await ViewerSettings.SetZoomLevelAsync(ZoomLevel);
    }

    // Zoom steps used by the +/- toolbar buttons. Special values
    // 0 (Fit Page) and -1 (Fit Width) are handled by ChromeOnZoomIn /
    // ChromeOnZoomOut treating them as 100% for stepping purposes.
    private static readonly int[] ZoomSteps = new[] { 25, 50, 75, 100, 125, 150, 200 };

    private async Task ChromeOnZoomIn()
    {
        var cur = ZoomLevel > 0 ? ZoomLevel : 100;
        var next = ZoomSteps.FirstOrDefault(s => s > cur);
        ZoomLevel = next == 0 ? 200 : next;
        await ChromeOnZoomChanged();
    }

    private async Task ChromeOnZoomOut()
    {
        var cur = ZoomLevel > 0 ? ZoomLevel : 100;
        var prev = ZoomSteps.LastOrDefault(s => s < cur);
        ZoomLevel = prev == 0 ? 25 : prev;
        await ChromeOnZoomChanged();
    }

    private void ChromeOnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") _ = ChromeOnSearch();
    }
    private Task ChromeOnSearch()
    {
        StatusMessage = string.IsNullOrWhiteSpace(SearchText)
            ? "Search cleared."
            : $"Search: \"{SearchText}\" (highlight pending).";
        return Task.CompletedTask;
    }

    private void ToggleGroupTreePanel() => ShowGroupTree = !ShowGroupTree;

    private async Task SetTreeMode(TreeNavigationMode mode)
    {
        if (TreeMode == mode) return;
        TreeMode = mode;
        // Switching OUT of Group mode: drop any in-flight red flash so
        // the previously-highlighted header doesn't stay tinted while
        // the user is now in DrillDown territory.
        if (mode != TreeNavigationMode.Group)
        {
            try { await JSRuntime.InvokeVoidAsync("hfClearGroupHighlight"); }
            catch { /* JS not ready — silently ignore */ }
        }
    }

    private void ToggleGroupNode(FxGroupNode node) => node.Expanded = !node.Expanded;

    private async Task OnGroupNodeClicked(FxGroupNode node)
    {
        // Capture the click for the visual "selected" highlight on the
        // tree label — read back in RenderGroupTreeNode to add the
        // .selected class. Survives the page navigation that happens
        // immediately below.
        _selectedTreeNode = node;

        if (TreeMode == TreeNavigationMode.DrillDown && _xmlFilePath != null && _lastParameters != null)
        {
            // Build the drill-down path: every ancestor up to this node.
            var path = new List<DrillDownFilter>();
            void Collect(FxGroupNode current, List<FxGroupNode> roots)
            {
                // Walk roots until current is found (Crystal's tree is
                // shallow — usually 1-3 levels, so this O(n) walk is fine).
                bool TryFind(FxGroupNode n, List<FxGroupNode> trail)
                {
                    trail.Add(n);
                    if (ReferenceEquals(n, current)) return true;
                    foreach (var c in n.Children)
                        if (TryFind(c, trail)) return true;
                    trail.RemoveAt(trail.Count - 1);
                    return false;
                }
                foreach (var root in roots)
                {
                    var trail = new List<FxGroupNode>();
                    if (TryFind(root, trail))
                    {
                        foreach (var n in trail)
                            path.Add(new DrillDownFilter(n.Field, n.Value));
                        return;
                    }
                }
            }
            Collect(node, GroupTree);
            if (path.Count > 0)
                await OpenDrillDown(node, path);
            return;
        }

        // Group mode: jump to the page that hosts this group, then ask
        // the renderer's JS helpers to scroll to its anchor and (in
        // Group mode) flash the matching group-header row in red so
        // the user can spot exactly which row they navigated to.
        // Mirrors the legacy FReportRunner.NavigateToGroupHeader flow.
        StatusMessage = $"Group: {node.Label} (page {node.PageIndex} of {PageCount})";
        if (node.PageIndex > 0)
        {
            JumpTo(node.PageIndex);
            await InvokeAsync(StateHasChanged);
        }

        if (string.IsNullOrEmpty(node.AnchorId)) return;
        try
        {
            // hfHighlightGroup = scroll + flash red. hfScrollToAnchor =
            // just scroll. Group mode (default) gets the highlight; the
            // DrillDown branch above already returned before this code.
            await JSRuntime.InvokeVoidAsync("hfHighlightGroup", node.AnchorId);
        }
        catch
        {
            // JS module not loaded yet — fall back to plain scroll. If
            // even that fails the click degrades to a page jump only.
            try { await JSRuntime.InvokeVoidAsync("hfScrollToAnchor", node.AnchorId); }
            catch { /* swallow */ }
        }
    }

    // ═══════════════════════════════════════════════════════════════
    // HTML Rendering Engine
    // ═══════════════════════════════════════════════════════════════

    // ═══════════════════════════════════════════════════════════════
    // Group Tree builder — mirrors Crystal Reports DisplayGroupTree
    // ═══════════════════════════════════════════════════════════════

    /// <summary>
    /// Builds a hierarchical tree of <see cref="FxGroupNode"/>s from the rendered DataTable
    /// and the report's <see cref="ReportDefinition.Groups"/> list. Each node records which
    /// rendered-page it lives on, so clicking the node navigates to that page.
    ///
    /// <para>
    /// The tree uses the same sort order as the main report: rows are sorted by the group
    /// columns outermost-first. For each distinct value at level 0, children are recursively
    /// grouped by the next level's field, and so on.
    /// </para>
    /// </summary>
    private List<FxGroupNode> BuildGroupTree(DataTable data, ReportDefinition def, int rowsPerPage)
    {
        if (def.Groups.Count == 0 || data.Rows.Count == 0)
            return new List<FxGroupNode>();

        // Sort rows outermost-first, matching what RenderHtmlPages does.
        var rows = data.AsEnumerable().ToList();
        foreach (var group in def.Groups.AsEnumerable().Reverse())
        {
            rows = group.SortDirection == ReportSortDirection.Ascending
                ? rows.OrderBy(r => (r.Table.Columns.Contains(group.Field) ? r[group.Field]?.ToString() : "") ?? "").ToList()
                : rows.OrderByDescending(r => (r.Table.Columns.Contains(group.Field) ? r[group.Field]?.ToString() : "") ?? "").ToList();
        }

        // Build a row-to-page lookup using the SAME pagination logic the
        // renderer uses (rowsPerPage cap + ReportGroup.PageBreakBefore).
        // Without this the tree's PageIndex would be off whenever a group has
        // PageBreakBefore set (e.g. Model Costs Report breaks per Model).
        var renderGroups = def.Groups
            .Where(g => data.Columns.Contains(g.Field))
            .ToList();
        var pageSlices = SplitIntoPages(rows, renderGroups, rowsPerPage);
        var rowToPage = new Dictionary<DataRow, int>(rows.Count);
        for (int p = 0; p < pageSlices.Count; p++)
            foreach (var r in pageSlices[p].Rows) rowToPage[r] = p + 1;

        // Pair each row with its sorted index AND its actual page number.
        var indexedRows = rows.Select((r, idx) =>
            new IndexedRow(r, idx, rowToPage.TryGetValue(r, out var pn) ? pn : 1)).ToList();

        return BuildGroupLevel(indexedRows, def.Groups, 0, rowsPerPage);
    }

    /// <summary>Tree-builder scratch record — row + its original sort position + its rendered page.</summary>
    private sealed record IndexedRow(DataRow Row, int SortedIndex, int PageNumber);

    private List<FxGroupNode> BuildGroupLevel(List<IndexedRow> indexed, List<ReportGroup> groups, int level, int rowsPerPage)
    {
        if (level >= groups.Count) return new List<FxGroupNode>();
        var group = groups[level];

        // Group indexed rows by the current level's field value.
        var buckets = new List<(string Value, List<IndexedRow> Items, int FirstPage)>();
        string? lastValue = null;
        List<IndexedRow>? currentBucket = null;
        int firstPage = 1;

        foreach (var item in indexed)
        {
            var row = item.Row;
            // Trim trailing whitespace from CHAR(N)-padded DB values so the tree label and the
            // drill-down filter literal exactly match (avoids an SQL = comparison mismatch on
            // some collations/settings).
            var rawValue = row.Table.Columns.Contains(group.Field) ? row[group.Field]?.ToString() : "";
            var value = (rawValue ?? "").TrimEnd();

            if (currentBucket == null || value != lastValue)
            {
                if (currentBucket != null)
                    buckets.Add((lastValue ?? "", currentBucket, firstPage));
                currentBucket = new List<IndexedRow>();
                firstPage = item.PageNumber;
                lastValue = value;
            }
            currentBucket.Add(item);
        }
        if (currentBucket != null)
            buckets.Add((lastValue ?? "", currentBucket, firstPage));

        // Build nodes
        var nodes = new List<FxGroupNode>();
        foreach (var (value, items, pageIdx) in buckets)
        {
            var node = new FxGroupNode
            {
                // Display label — "(empty)" placeholder only; the raw value is preserved
                // separately for SQL drill-down filter comparisons.
                Label = string.IsNullOrWhiteSpace(value) ? "(empty)" : value,
                Value = value ?? "",
                Field = group.Field,
                Level = level,
                PageIndex = pageIdx,
                AnchorId = $"group-{level}-{SanitizeForId(value ?? "")}",
                Children = BuildGroupLevel(items, groups, level + 1, rowsPerPage)
            };
            nodes.Add(node);
        }
        return nodes;
    }

    private static string SanitizeForId(string s)
        => new string((s ?? "").Select(c => char.IsLetterOrDigit(c) ? c : '_').ToArray());

    // ═══════════════════════════════════════════════════════════════════
    // Column-width strategy
    // ═══════════════════════════════════════════════════════════════════
    //
    // Policy (XML-first, per Crystal Reports / VB6 parity):
    //   1. If the Crystal XML supplies an explicit width (FieldObject Width=
    //      in twips), USE IT AS-IS. The report author chose it deliberately;
    //      our job is to honor it, not second-guess.
    //   2. Numeric / Date / Boolean columns get a FLOOR at max(header, widest
    //      sampled value) — they must always show in full, no wrap. The XML
    //      hint wins when wider than the floor.
    //   3. Columns WITHOUT an XML hint get sized from header + sampled data
    //      (the previous data-driven path). This kicks in for SQL reports
    //      built in code that don't have any twips info.
    //   4. If the resulting column-width sum exceeds the printable page
    //      width, scale down only the TEXT columns proportionally — numeric
    //      columns keep their floor so headers + values stay readable.
    //      Excess text wraps via the existing word-break CSS.
    //
    // Pixel measurement uses ~6.5 px/char regular, ~7.5 px/char bold for
    // proportional Arial at the report-table font size. Good enough for
    // layout decisions; we never need pixel-perfect.
    private void ComputeAdaptiveColumnWidths(ReportDefinition def,
        List<ReportColumn> visibleColumns, DataTable data)
    {
        if (visibleColumns.Count == 0) return;

        // Page-width budget — Letter @ 96 dpi minus the .fx-report-page
        // padding (≈ 100 px total). Used only when the XML widths overflow.
        const int kCellPadding = 14;          // 6px each side + small slack
        const int kMinFlexFloor = 60;         // hard min for any flex column
        int pageBudget = def.Orientation == ReportOrientation.Landscape ? 956 : 716;

        // Gather per-column metrics
        var info = new List<ColumnSizingInfo>(visibleColumns.Count);
        foreach (var col in visibleColumns)
        {
            int headerPx = MeasureTextPx(col.HeaderText, bold: true) + kCellPadding;
            int dataMaxPx = MeasureColumnDataPx(col, data, sampleSize: 250) + kCellPadding;
            // col.Width was set by CrystalXmlReportLoader from the XML's twips
            // value. 0 means no XML hint — we fall back to data sizing.
            int xmlHintPx = col.Width > 0 ? col.Width : 0;
            bool rigid = IsRigidColumnType(col.ColumnType);
            info.Add(new ColumnSizingInfo(col, headerPx, dataMaxPx, xmlHintPx, rigid));
        }

        // Pass 1 — Assign each column its TARGET width.
        //   • XML present → honor it (numeric also enforces header+data floor).
        //   • XML absent  → fall back to header+data.
        foreach (var ci in info)
        {
            int target;
            if (ci.XmlHintPx > 0)
            {
                // Honor Crystal's stated width. For numeric columns we still
                // enforce the floor — wrapping a numeric header / value is
                // worse than overflowing a slightly-wider column.
                target = ci.IsRigid
                    ? Math.Max(ci.XmlHintPx, Math.Max(ci.HeaderPx, ci.DataMaxPx))
                    : ci.XmlHintPx;
            }
            else
            {
                // No XML hint — size from header + widest sampled value.
                target = Math.Max(ci.HeaderPx, ci.DataMaxPx);
                if (!ci.IsRigid) target = Math.Max(target, kMinFlexFloor);
            }
            ci.Col.Width = target;
        }

        // Pass 2 — If total exceeds page budget, scale text columns down.
        // Numeric columns are protected at their floor (header + widest value)
        // so they keep their integrity; the remaining slack comes out of text.
        int totalWidth = info.Sum(i => i.Col.Width);
        if (totalWidth <= pageBudget) return;

        int rigidSum = info.Where(i => i.IsRigid).Sum(i => i.Col.Width);
        var flex = info.Where(i => !i.IsRigid).ToList();
        if (flex.Count == 0) return;        // no text columns to give up space

        int budgetForFlex = pageBudget - rigidSum;
        int currentFlexSum = flex.Sum(i => i.Col.Width);
        if (budgetForFlex <= 0)
        {
            // Numeric columns alone exceed the page — give every text column
            // the floor and let the page scroll horizontally. Rare but safe.
            foreach (var ci in flex) ci.Col.Width = kMinFlexFloor;
            return;
        }

        // Scale every text column proportionally to its current (XML or
        // data-driven) width. Floor at header+data so column headers stay
        // readable; text content wraps when it exceeds the column.
        double ratio = (double)budgetForFlex / currentFlexSum;
        foreach (var ci in flex)
        {
            int scaled = (int)Math.Round(ci.Col.Width * ratio);
            int floor = Math.Max(ci.HeaderPx, kMinFlexFloor);
            ci.Col.Width = Math.Max(scaled, floor);
        }
    }

    /// <summary>True for columns that must show in full without wrapping.</summary>
    private static bool IsRigidColumnType(ReportColumnType t) =>
        t is ReportColumnType.Integer
          or ReportColumnType.Decimal
          or ReportColumnType.Currency
          or ReportColumnType.Percent
          or ReportColumnType.Date
          or ReportColumnType.DateTime
          or ReportColumnType.Boolean;

    /// <summary>
    /// Approximate the pixel width of a string at the report-table font size
    /// (11px Arial). Bold characters render roughly 15% wider than regular.
    /// Numbers / commas / decimals are slightly narrower than letters but the
    /// average is good enough for layout decisions.
    /// </summary>
    private static int MeasureTextPx(string? text, bool bold)
    {
        if (string.IsNullOrEmpty(text)) return 0;
        double avgChar = bold ? 7.5 : 6.5;
        return (int)Math.Ceiling(text.Length * avgChar);
    }

    /// <summary>
    /// Returns the widest formatted-value pixel width across a sample of
    /// rows for the given column. Sample-capped so a million-row report
    /// doesn't pay an O(N) measurement cost.
    /// </summary>
    private static int MeasureColumnDataPx(ReportColumn col, DataTable data, int sampleSize)
    {
        if (data.Rows.Count == 0) return 0;
        // Field name might not be in the DataTable (group-only field) — bail.
        if (!data.Columns.Contains(col.Field)) return 0;

        int n = Math.Min(data.Rows.Count, Math.Max(1, sampleSize));
        int max = 0;
        for (int i = 0; i < n; i++)
        {
            var formatted = FormatCellValueForSizing(data.Rows[i], col);
            int px = MeasureTextPx(formatted, bold: false);
            if (px > max) max = px;
        }
        return max;
    }

    /// <summary>
    /// Mirror of <c>FormatCellValue</c> — duplicated here as a static so the
    /// width sizer can run without entering the per-cell render path. Uses the
    /// column's Format string when set; otherwise stringifies the value.
    /// </summary>
    private static string FormatCellValueForSizing(DataRow row, ReportColumn col)
    {
        if (!row.Table.Columns.Contains(col.Field)) return "";
        var v = row[col.Field];
        if (v == null || v == DBNull.Value) return "";
        if (!string.IsNullOrEmpty(col.Format) && v is IFormattable f)
        {
            try { return f.ToString(col.Format, CultureInfo.CurrentCulture); }
            catch { /* fall through */ }
        }
        return v.ToString() ?? "";
    }

    /// <summary>Per-column scratchpad used by <see cref="ComputeAdaptiveColumnWidths"/>.</summary>
    private sealed class ColumnSizingInfo
    {
        public ReportColumn Col;
        public int HeaderPx;
        public int DataMaxPx;
        public int XmlHintPx;
        public bool IsRigid;
        public ColumnSizingInfo(ReportColumn col, int headerPx, int dataMaxPx, int xmlHintPx, bool isRigid)
        { Col = col; HeaderPx = headerPx; DataMaxPx = dataMaxPx; XmlHintPx = xmlHintPx; IsRigid = isRigid; }
    }

    private List<string> RenderHtmlPages(ReportDefinition def, DataTable data, List<ReportColumn> columns)
    {
        // Cap on TOTAL VISIBLE rows per page (data + group headers + group
        // footers). CrystalXmlReportLoader populates RowsPerPage from
        // <PrintOptions PageContentHeight=...> when present; the fallbacks
        // here apply to code-built reports.
        var rowsPerPage = def.RowsPerPage > 0 ? def.RowsPerPage : (def.Orientation == ReportOrientation.Landscape ? 49 : 70);

        // Sort/group data if groups defined.
        // Only groups whose Field is present in the DataTable can be used for sorting —
        // `def.Groups` may include deeper levels that live only in the separate TreeSql
        // query result, not in the main summary result.
        var rows = data.AsEnumerable().ToList();
        var sortableGroups = def.Groups.Where(g => data.Columns.Contains(g.Field)).ToList();
        if (sortableGroups.Count > 0)
        {
            rows = rows.OrderBy(r => 0).ToList(); // stable placeholder
            foreach (var group in sortableGroups.AsEnumerable().Reverse())
            {
                rows = group.SortDirection == ReportSortDirection.Ascending
                    ? rows.OrderBy(r => r[group.Field]?.ToString() ?? "").ToList()
                    : rows.OrderByDescending(r => r[group.Field]?.ToString() ?? "").ToList();
            }
        }

        // Only groups whose field lives in the DataTable can be rendered (others
        // are tree-only navigation levels for drill-down). Computed once and
        // shared by both pagination (which honors PageBreakBefore) and the
        // per-page renderer (which does the actual transition detection).
        var renderGroups = def.Groups
            .Where(g => rows.Count == 0 || rows[0].Table.Columns.Contains(g.Field))
            .ToList();

        // ── Pass 1: split rows into pages ───────────────────────────────
        // Honors both rowsPerPage AND any group with PageBreakBefore=true
        // (e.g. Model Desc — every new model starts on a new page). Each
        // slice also carries a ClosingFooterLevel: when a forced break
        // fires at level L, the outgoing page is told to flush footers for
        // levels L..innermost so the totals appear on the page that's
        // ENDING (not orphaned at the top of the next page).
        var pageSlices = SplitIntoPages(rows, renderGroups, rowsPerPage);

        // ── Pass 2: render with SHARED lastValues across pages ──────────
        // Sharing the array means a group header is emitted only when its
        // value actually changes — NOT every time a new page begins. This
        // gives the "don't repeat Community/Model on every page" behavior
        // the VB6 viewer has.
        var lastValues = new string?[renderGroups.Count];
        var pages = new List<string>();
        for (int p = 0; p < pageSlices.Count; p++)
        {
            bool isLast = (p == pageSlices.Count - 1);
            var slice = pageSlices[p];
            pages.Add(RenderPage(def, columns, slice.Rows, rows,
                pageNum: p + 1, totalPages: pageSlices.Count,
                isFirstPage: p == 0, isLastPage: isLast,
                renderGroups, lastValues,
                closingFooterLevel: slice.ClosingFooterLevel));
        }
        return pages;
    }

    /// <summary>
    /// One paginator output: the rows that belong on this page plus a
    /// closing-footer-level hint. <c>ClosingFooterLevel = -1</c> means the
    /// page ends due to a row-count cap (groups continue on next page —
    /// don't emit closing footers). Any non-negative value means a forced
    /// page break fired at that group level; the renderer should emit
    /// footers from innermost down to that level so the totals print on the
    /// outgoing page rather than orphaning at the top of the next one.
    /// </summary>
    private sealed record PageSlice(List<DataRow> Rows, int ClosingFooterLevel);

    /// <summary>
    /// Splits the row list into pages honoring:
    ///   • the visible-row cap (<paramref name="visibleRowsPerPage"/> = data
    ///     rows + group headers + group footers),
    ///   • any group's <see cref="ReportGroup.PageBreakBefore"/> flag (forces
    ///     a new page when that group's value changes).
    ///
    /// <para>
    /// Counting <em>visible</em> rows (rather than just data rows) gives a
    /// uniform page height: a Model with many phases / sub-groups will hold
    /// fewer detail rows on a page because each transition costs a header +
    /// footer line. A Model with one big phase will hold more detail rows.
    /// Both pages end up about the same vertical extent.
    /// </para>
    ///
    /// <para>
    /// The transition-cost calculation mirrors what <see cref="RenderPage"/>
    /// does, so the splitter's prediction matches the renderer's output.
    /// </para>
    /// </summary>
    private static List<PageSlice> SplitIntoPages(
        List<DataRow> rows, List<ReportGroup> renderGroups, int visibleRowsPerPage)
    {
        var result = new List<PageSlice>();
        var current = new List<DataRow>();
        int visibleUsed = 0;

        // Indices of groups that trigger a forced page break.
        var breakLevels = renderGroups
            .Select((g, idx) => g.PageBreakBefore ? idx : -1)
            .Where(i => i >= 0)
            .ToList();

        // Mirrors RenderPage's lastValues — needed to predict each row's
        // transition cost (footers + headers it will emit).
        var lastValues = new string?[renderGroups.Count];

        // Tracker for forced-break detection (separate from lastValues
        // because it has different semantics — only updated for break-
        // levels and only used to detect value changes).
        var prevBreakValues = new string?[renderGroups.Count];

        foreach (var row in rows)
        {
            // ── Compute this row's visible cost (data row + transitions) ──
            int transitionLevel = renderGroups.Count;
            for (int i = 0; i < renderGroups.Count; i++)
            {
                var grp = renderGroups[i];
                if (!row.Table.Columns.Contains(grp.Field)) continue;
                var v = (row[grp.Field]?.ToString() ?? "").TrimEnd();
                if (lastValues[i] == null || v != lastValues[i])
                {
                    transitionLevel = i;
                    break;
                }
            }
            int rowCost = ComputeVisibleCost(transitionLevel, renderGroups, lastValues);

            // ── Detect forced page-break (PageBreakBefore on any group) ──
            int forcedBreakLevel = -1;
            if (current.Count > 0 && breakLevels.Count > 0)
            {
                foreach (var lvl in breakLevels)
                {
                    var grp = renderGroups[lvl];
                    if (!row.Table.Columns.Contains(grp.Field)) continue;
                    var v = (row[grp.Field]?.ToString() ?? "").TrimEnd();
                    if (prevBreakValues[lvl] != null && v != prevBreakValues[lvl])
                    {
                        if (forcedBreakLevel < 0 || lvl < forcedBreakLevel)
                            forcedBreakLevel = lvl;
                    }
                }
            }

            // ── Decide whether to flush the current page ──
            bool needBreak = forcedBreakLevel >= 0
                          || (current.Count > 0 && visibleUsed + rowCost > visibleRowsPerPage);

            if (needBreak)
            {
                result.Add(new PageSlice(current, forcedBreakLevel));
                current = new List<DataRow>();
                visibleUsed = 0;

                if (forcedBreakLevel >= 0)
                {
                    // RenderPage will null lastValues for these levels after
                    // emitting the closing footers — mirror that here so the
                    // first row on the next page costs a fresh header chain.
                    for (int i = forcedBreakLevel; i < renderGroups.Count; i++)
                        lastValues[i] = null;

                    // Re-derive transition + cost for the new page's first row.
                    transitionLevel = renderGroups.Count;
                    for (int i = 0; i < renderGroups.Count; i++)
                    {
                        var grp = renderGroups[i];
                        if (!row.Table.Columns.Contains(grp.Field)) continue;
                        var v = (row[grp.Field]?.ToString() ?? "").TrimEnd();
                        if (lastValues[i] == null || v != lastValues[i])
                        {
                            transitionLevel = i;
                            break;
                        }
                    }
                    rowCost = ComputeVisibleCost(transitionLevel, renderGroups, lastValues);
                }
                // For row-cap break: lastValues stays — groups continue on
                // next page, no closing footers, transition cost remains as
                // computed (the row's transition will fire on the new page).
            }

            // ── Update tracking state to MATCH RenderPage's bookkeeping ──
            if (breakLevels.Count > 0)
            {
                foreach (var lvl in breakLevels)
                {
                    var grp = renderGroups[lvl];
                    if (!row.Table.Columns.Contains(grp.Field)) continue;
                    prevBreakValues[lvl] = (row[grp.Field]?.ToString() ?? "").TrimEnd();
                }
            }

            // Mirror RenderPage: when a transition fires at level L, all
            // levels [L..innermost] get their lastValues updated to this
            // row's values.
            if (transitionLevel < renderGroups.Count)
            {
                for (int i = transitionLevel; i < renderGroups.Count; i++)
                {
                    var grp = renderGroups[i];
                    if (!row.Table.Columns.Contains(grp.Field)) continue;
                    lastValues[i] = (row[grp.Field]?.ToString() ?? "").TrimEnd();
                }
            }

            current.Add(row);
            visibleUsed += rowCost;
        }

        // Last page is never a forced break (it's the natural end of the report).
        if (current.Count > 0) result.Add(new PageSlice(current, ClosingFooterLevel: -1));
        if (result.Count == 0) result.Add(new PageSlice(new List<DataRow>(), -1));  // empty report → 1 empty page
        return result;
    }

    /// <summary>
    /// Visible-row cost of one detail row given the transition level.
    /// Mirrors what <see cref="RenderPage"/> emits per row:
    ///   • Always 1 detail row.
    ///   • If a transition fires at level L, emit footers for every
    ///     currently-OPEN inner level (lastValues[i] != null) from
    ///     innermost down to L — innermost-first ordering — plus headers
    ///     for [L..innermost] (always).
    /// </summary>
    private static int ComputeVisibleCost(int transitionLevel, List<ReportGroup> renderGroups, string?[] lastValues)
    {
        int cost = 1;   // detail row
        if (transitionLevel < renderGroups.Count)
        {
            // Footers — only emitted when the level was previously open.
            int footers = 0;
            for (int i = renderGroups.Count - 1; i >= transitionLevel; i--)
                if (lastValues[i] != null && renderGroups[i].ShowFooter)
                    footers++;
            // Headers — always emitted for the transition level + every deeper.
            int headers = 0;
            for (int i = transitionLevel; i < renderGroups.Count; i++)
                if (renderGroups[i].ShowHeader)
                    headers++;
            cost += footers + headers;
        }
        return cost;
    }

    private string RenderPage(ReportDefinition def, List<ReportColumn> columns, List<DataRow> pageRows,
        List<DataRow> allRows, int pageNum, int totalPages, bool isFirstPage, bool isLastPage,
        List<ReportGroup> renderGroups, string?[] lastValues, int closingFooterLevel = -1)
    {
        var html = new System.Text.StringBuilder();
        var now = DateTime.Now;

        // Page header — title/subtitle alignment pulled from the Crystal XML (ObjectFormat
        // HorizontalAlignment); falls back to Center when the XML doesn't specify.
        var titleAlignStyle = AlignmentStyle(def.TitleAlignment);
        var subtitleAlignStyle = AlignmentStyle(def.SubtitleAlignment);
        html.AppendLine("<div class='fx-rpt-header'>");
        html.AppendLine($"  <div class='fx-rpt-title' style='{titleAlignStyle}'>{Escape(def.Title)}</div>");
        if (!string.IsNullOrEmpty(def.Subtitle))
            html.AppendLine($"  <div class='fx-rpt-subtitle' style='{subtitleAlignStyle}'>{Escape(def.Subtitle)}</div>");
        html.AppendLine($"  <div class='fx-rpt-date'>{now:yyyy-MM-dd HH:mm}</div>");
        html.AppendLine("</div>");

        // Table
        html.AppendLine("<table class='fx-rpt-table'>");

        // Column headers — emit a CSS class that mirrors the column type so
        // numeric / date columns can opt out of wrapping and text columns can
        // wrap on word boundaries when the data overflows the computed width.
        html.AppendLine("<thead><tr>");
        foreach (var col in columns)
        {
            var align = col.Alignment switch
            {
                ReportAlignment.Right => "text-align:right",
                ReportAlignment.Center => "text-align:center",
                _ => "text-align:left"
            };
            var width = col.Width > 0 ? $"width:{col.Width}px;" : "";
            var typeCls = IsRigidColumnType(col.ColumnType) ? "fx-rpt-col-nowrap" : "fx-rpt-col-wrap";
            var headerHtml = BuildColumnHeaderHtml(col);
            html.AppendLine($"  <th class='{typeCls}' style='{align};{width}'>{headerHtml}</th>");
        }
        html.AppendLine("</tr></thead>");

        // Data rows — handle multi-level grouping like Crystal Reports.
        // Rules per row:
        //   • Walk groups outermost → innermost. The first group whose value differs from
        //     the previous row is the "transition level".
        //   • Before emitting headers for the transition: emit FOOTERS (subtotals) for
        //     every level from innermost down to the transition level (deeper-first).
        //   • Then emit HEADERS for the transition level and every deeper level.
        //   • Then emit the detail row.
        // After the LAST page's last row: emit footers for every still-open group
        // (innermost-first). On non-last pages, group state continues onto the
        // next page so headers/footers don't repeat unnecessarily.
        html.AppendLine("<tbody>");

        // renderGroups + lastValues are passed in from RenderHtmlPages — they
        // are SHARED across pages so headers / footers fire only on actual
        // value transitions (not every page boundary).

        // Per-column "last rendered value" tracking for SuppressRepeats —
        // when a column flags itself as repeat-suppressing (typically the
        // leftmost RecordSortField, e.g. Master Assembly List's POIndex),
        // we emit an empty cell when the current row's value matches the
        // previous row's at the same column. Mirrors Crystal's
        // "Suppress If Duplicated" property which RptToXml doesn't export
        // reliably, so the loader infers it from the SortField list.
        var lastCellValues = new Dictionary<string, string>(StringComparer.Ordinal);

        foreach (var row in pageRows)
        {
            if (renderGroups.Count > 0)
            {
                // Find the outermost level whose value changed.
                int transition = renderGroups.Count;
                for (int i = 0; i < renderGroups.Count; i++)
                {
                    var v = row.Table.Columns.Contains(renderGroups[i].Field)
                        ? (row[renderGroups[i].Field]?.ToString() ?? "").TrimEnd()
                        : "";
                    if (lastValues[i] == null || v != lastValues[i])
                    {
                        transition = i;
                        break;
                    }
                }
                // Emit footers for currently-open deeper groups (deepest first).
                for (int i = renderGroups.Count - 1; i >= transition; i--)
                {
                    if (lastValues[i] != null && renderGroups[i].ShowFooter)
                        html.AppendLine(RenderMultiLevelFooter(renderGroups, i, columns, allRows, lastValues));
                }
                // Emit headers for the transition level + every deeper level.
                for (int i = transition; i < renderGroups.Count; i++)
                {
                    var grp = renderGroups[i];
                    if (!row.Table.Columns.Contains(grp.Field)) continue;
                    var v = (row[grp.Field]?.ToString() ?? "").TrimEnd();
                    lastValues[i] = v;
                    if (grp.ShowHeader)
                        html.AppendLine(RenderMultiLevelHeader(grp, i, columns, row, def.Groups, v));
                }

                // A group transition resets the per-column "last value"
                // tracking. Without this, a SuppressRepeats column whose
                // value happens to match the previous group's last row
                // would render blank on the first row of the new group —
                // visually breaking the grouping the user just saw a header
                // for.
                if (transition < renderGroups.Count)
                    lastCellValues.Clear();
            }

            // Detail row — clickable for drill-down (data-path = full group path of the row).
            var rowPath = BuildCellPathAttribute(row, def.Groups);
            var rowAttrs = string.IsNullOrEmpty(rowPath)
                ? ""
                : $" class='fx-drill-row' data-path='{rowPath}'";
            html.Append($"<tr{rowAttrs}>");
            foreach (var col in columns)
            {
                var align = col.Alignment switch
                {
                    ReportAlignment.Right => "text-align:right",
                    ReportAlignment.Center => "text-align:center",
                    _ => ""
                };
                var style = BuildCellStyle(row, col, align);
                var typeCls = IsRigidColumnType(col.ColumnType) ? "fx-rpt-col-nowrap" : "fx-rpt-col-wrap";
                var cellCls = col.IsSubreportObject ? $"{typeCls} fx-rpt-subreport-cell" : typeCls;
                if (col.IsSubreportObject)
                {
                    html.Append($"<td class='{cellCls}'{style}>{BuildSubreportLinkHtml(col, row, useHeaderFallback: false)}</td>");
                    continue;
                }

                var value = FormatCellValue(row, col);
                var rendered = value;
                if (col.SuppressRepeats)
                {
                    if (lastCellValues.TryGetValue(col.Field, out var prev) && prev == value)
                        rendered = "";
                    else
                        lastCellValues[col.Field] = value;
                }
                html.Append($"<td class='{cellCls}'{style}>{Escape(rendered)}</td>");
            }
            html.AppendLine("</tr>");
        }

        // Closing footers — three cases:
        //   1. LAST page              → flush every still-open group footer
        //                                (the report is ending).
        //   2. Forced PageBreakBefore → flush the breaking group + every
        //                                INNER group on the OUTGOING page so
        //                                their totals print on this page
        //                                instead of orphaning at the top of
        //                                the next page. Then null out the
        //                                affected lastValues so the next
        //                                page emits fresh headers.
        //   3. Row-cap break          → leave groups OPEN; they continue on
        //                                the next page without re-emitting
        //                                headers/footers.
        if (isLastPage)
        {
            for (int i = renderGroups.Count - 1; i >= 0; i--)
            {
                if (lastValues[i] != null && renderGroups[i].ShowFooter)
                    html.AppendLine(RenderMultiLevelFooter(renderGroups, i, columns, allRows, lastValues));
            }
        }
        else if (closingFooterLevel >= 0)
        {
            // Innermost-first so each footer renders against fully-populated
            // group state for its inner counterparts.
            for (int i = renderGroups.Count - 1; i >= closingFooterLevel; i--)
            {
                if (lastValues[i] != null && renderGroups[i].ShowFooter)
                    html.AppendLine(RenderMultiLevelFooter(renderGroups, i, columns, allRows, lastValues));
            }
            // Mark these levels as "closed" so the next page's first row
            // triggers a normal HEADER transition without the renderer also
            // emitting redundant footers.
            for (int i = closingFooterLevel; i < renderGroups.Count; i++)
                lastValues[i] = null;
        }

        html.AppendLine("</tbody>");

        // Grand total (if last page and aggregates defined)
        if (isLastPage && def.Groups.Any(g => g.Aggregates.Count > 0))
        {
            html.AppendLine("<tfoot>");
            html.Append("<tr class='fx-rpt-grand-total'>");
            foreach (var col in columns)
            {
                var agg = def.Groups.SelectMany(g => g.Aggregates).FirstOrDefault(a => a.Field == col.Field);
                if (agg != null)
                {
                    var val = ComputeAggregate(allRows, agg);
                    html.Append($"<td style='text-align:right;font-weight:bold'>{agg.Label} {val}</td>");
                }
                else if (col == columns[0])
                {
                    html.Append($"<td style='font-weight:bold'>Grand Total ({allRows.Count} records)</td>");
                }
                else
                {
                    html.Append("<td></td>");
                }
            }
            html.AppendLine("</tr>");
            html.AppendLine("</tfoot>");
        }

        html.AppendLine("</table>");

        // Page footer
        var footerLeft = ReplacePlaceholders(def.FooterLeft, def.Title, pageNum, totalPages, now);
        var footerCenter = ReplacePlaceholders(def.FooterCenter, def.Title, pageNum, totalPages, now);
        var footerRight = ReplacePlaceholders(def.FooterRight, def.Title, pageNum, totalPages, now);

        html.AppendLine("<div class='fx-rpt-footer'>");
        html.AppendLine($"  <span>{Escape(footerLeft)}</span>");
        html.AppendLine($"  <span>{Escape(footerCenter)}</span>");
        html.AppendLine($"  <span>{Escape(footerRight)}</span>");
        html.AppendLine("</div>");

        return html.ToString();
    }

    private string RenderGroupFooter(ReportGroup group, List<ReportColumn> columns, List<DataRow> allRows, string groupValue)
    {
        var groupRows = allRows.Where(r => r[group.Field]?.ToString() == groupValue).ToList();
        var html = new System.Text.StringBuilder();
        html.Append($"<tr class='fx-rpt-group-footer'>");
        foreach (var col in columns)
        {
            var agg = group.Aggregates.FirstOrDefault(a => a.Field == col.Field);
            if (agg != null)
            {
                var val = ComputeAggregate(groupRows, agg);
                html.Append($"<td style='text-align:right;font-weight:bold'>{agg.Label} {val}</td>");
            }
            else if (col == columns[0])
            {
                html.Append($"<td style='font-weight:bold'>Subtotal ({groupRows.Count})</td>");
            }
            else
            {
                html.Append("<td></td>");
            }
        }
        html.Append("</tr>");
        return html.ToString();
    }

    /// <summary>
    /// Emits a Crystal-Reports-style group HEADER row at <paramref name="level"/>. Layout:
    /// <list type="bullet">
    ///   <item><description>Indent (one cell per outer-group level) for visual nesting.</description></item>
    ///   <item><description>The group value itself in the next cell.</description></item>
    ///   <item><description>Remaining cells span (colspan) to fill the row.</description></item>
    /// </list>
    /// The row is also marked <c>fx-drill-row</c> with a <c>data-path</c> attribute so
    /// clicking the header drills into that group.
    /// </summary>
    private string RenderMultiLevelHeader(ReportGroup group, int level, List<ReportColumn> columns,
        DataRow row, List<ReportGroup> allGroups, string groupValue)
    {
        var html = new System.Text.StringBuilder();
        var anchorId = $"group-{level}-" + new string(groupValue.Select(c => char.IsLetterOrDigit(c) ? c : '_').ToArray());
        var hdrPath = BuildCellPathAttribute(row, allGroups);
        var cls = $"fx-rpt-group-header fx-rpt-group-l{level}" + (string.IsNullOrEmpty(hdrPath) ? "" : " fx-drill-row");
        var pathAttr = string.IsNullOrEmpty(hdrPath) ? "" : $" data-path='{hdrPath}'";
        // Resolve the group's description column value from the current row
        // (if a DescriptionField is configured). The loader sets this when
        // the Crystal GroupHeader section has a FieldObject or TextObject
        // template that references a "{Table.Field}" distinct from the
        // group's own code — typically a self-join's "_1" alias holding
        // the parent group's description text, or a direct reference to
        // the lookup table's Description column. Falls back to empty when
        // no description is configured, keeping reports without
        // descriptions unaffected.
        var description = !string.IsNullOrEmpty(group.DescriptionField)
                       && row.Table.Columns.Contains(group.DescriptionField)
            ? (row[group.DescriptionField]?.ToString()?.TrimEnd() ?? "")
            : "";

        // Emit ONE colspan'd cell across the whole row instead of N empty
        // cells per level. Empty <td>s would inherit each column's width
        // (e.g. ItemDesc @ 200 px), making outer groups indent way more
        // than "2 characters". The .fx-rpt-group-l{level} CSS class adds
        // a precise per-level padding-left (~12 px ≈ 2 char widths).
        //
        // When a description is configured, render it stacked above the
        // group code on a second line — matches the legacy Crystal Viewer's
        // typical "Major Group  <description>" / "Group Code  <value>"
        // layout (Major Group and Category Report is the canonical example).
        // Side-by-side concat looked cramped and didn't match the .rpt
        // designer's vertical layout. When no description is configured we
        // fall back to the legacy single-line "{Value}" header.
        string cellHtml;
        if (!string.IsNullOrWhiteSpace(description))
        {
            cellHtml =
                $"<div>{Escape(description)}</div>" +
                $"<div style='font-weight:normal;font-size:0.9em;color:#666;'>{Escape(groupValue)}</div>";
        }
        else
        {
            var headerText = group.HeaderFormat
                .Replace("{Value}", groupValue)
                .Replace("{Count}", "")
                .Replace("{Description}", "");
            cellHtml = Escape(headerText);
        }

        html.Append($"<tr class='{cls}' id='{anchorId}'{pathAttr}>");
        html.Append($"<td colspan='{columns.Count}' style='font-weight:bold;'>{cellHtml}</td>");
        html.AppendLine("</tr>");
        return html.ToString();
    }

    /// <summary>
    /// Emits a group FOOTER row at <paramref name="level"/> with subtotals for any currency
    /// columns belonging to that group's aggregates. Indents like the matching header.
    /// Subtotals are computed by summing the group's rows for each numeric column.
    /// </summary>
    private string RenderMultiLevelFooter(List<ReportGroup> renderGroups, int level,
        List<ReportColumn> columns, List<DataRow> allRows, string?[] lastValues)
    {
        // Identify the rows that fall under this footer (matching all enclosing-level values).
        var matching = allRows.AsEnumerable();
        for (int i = 0; i <= level; i++)
        {
            var g = renderGroups[i];
            var v = lastValues[i] ?? "";
            matching = matching.Where(r => allRows.Count == 0 ||
                ((r.Table.Columns.Contains(g.Field) ? r[g.Field]?.ToString()?.TrimEnd() : "") ?? "") == v);
        }
        var groupRows = matching.ToList();

        var html = new System.Text.StringBuilder();
        var label = lastValues[level] ?? "";

        // Find the FIRST numeric column — the label cell colspans over every
        // text column to its left so the totals stay in their own column slot
        // (perfectly column-aligned with the data above). If there are no
        // numeric columns at all, the label spans the whole row.
        int firstNumericCol = -1;
        for (int i = 0; i < columns.Count; i++)
        {
            if (columns[i].ColumnType is ReportColumnType.Currency
                                       or ReportColumnType.Decimal
                                       or ReportColumnType.Integer)
            {
                firstNumericCol = i;
                break;
            }
        }
        int labelSpan = firstNumericCol < 0 ? columns.Count : firstNumericCol;
        if (labelSpan < 1) labelSpan = 1;

        html.Append($"<tr class='fx-rpt-group-footer fx-rpt-group-l{level}'>");

        // Label cell — single colspan over the text columns at the left.
        // Indent comes from the .fx-rpt-group-footer.fx-rpt-group-l{level} CSS
        // class (padding-left), NOT from empty <td>s — those would inherit
        // wide column widths and push the label all the way to the middle.
        html.Append($"<td colspan='{labelSpan}' " +
                    $"style='font-weight:bold;border-top:1px solid #999;text-align:right;'>" +
                    $"{Escape(label)}&nbsp;</td>");

        // Numeric column slots — each gets its sum (or remains empty for non-
        // numeric columns at the right). Order matches the header so the
        // total renders directly under its column header.
        for (int colIdx = labelSpan; colIdx < columns.Count; colIdx++)
        {
            var col = columns[colIdx];
            if (col.ColumnType is ReportColumnType.Currency
                               or ReportColumnType.Decimal
                               or ReportColumnType.Integer)
            {
                var sum = 0.0;
                foreach (var r in groupRows)
                {
                    if (!r.Table.Columns.Contains(col.Field)) continue;
                    var raw = r[col.Field];
                    if (raw == null || raw == DBNull.Value) continue;
                    if (double.TryParse(raw.ToString(), out var d)) sum += d;
                }
                var formatted = col.ColumnType == ReportColumnType.Currency
                    ? sum.ToString("C2")
                    : col.ColumnType == ReportColumnType.Integer
                        ? sum.ToString("N0")
                        : sum.ToString("N2");
                html.Append($"<td class='fx-rpt-col-nowrap' " +
                            $"style='text-align:right;font-weight:bold;border-top:1px solid #999;'>" +
                            $"{Escape(formatted)}</td>");
            }
            else
            {
                html.Append("<td style='border-top:1px solid #999;'></td>");
            }
        }
        html.Append("</tr>");
        return html.ToString();
    }

    /// <summary>How many trailing money/decimal/integer columns to right-align subtotals into.</summary>
    private static int SumColumnsCount(List<ReportColumn> columns, int startLevel)
    {
        int count = 0;
        for (int i = startLevel; i < columns.Count; i++)
        {
            if (columns[i].ColumnType is ReportColumnType.Currency or ReportColumnType.Decimal or ReportColumnType.Integer)
                count++;
        }
        return Math.Max(1, count);
    }

    // ═══════════════════════════════════════════════════════════════
    // Formatting Helpers
    // ═══════════════════════════════════════════════════════════════

    private static string BuildCellStyle(DataRow row, ReportColumn col, string alignmentStyle)
    {
        var styles = new List<string>();
        if (!string.IsNullOrWhiteSpace(alignmentStyle))
            styles.Add(alignmentStyle);

        var color = col.TextColor;
        var bold = col.Bold;
        if (col.ConditionalStyle != null && EvaluateConditionalStyle(row, col.ConditionalStyle))
        {
            if (!string.IsNullOrWhiteSpace(col.ConditionalStyle.TrueTextColor))
                color = col.ConditionalStyle.TrueTextColor;
            if (col.ConditionalStyle.TrueBold.HasValue)
                bold = col.ConditionalStyle.TrueBold.Value;
        }
        else if (col.ConditionalStyle != null)
        {
            if (!string.IsNullOrWhiteSpace(col.ConditionalStyle.FalseTextColor))
                color = col.ConditionalStyle.FalseTextColor;
            if (col.ConditionalStyle.FalseBold.HasValue)
                bold = col.ConditionalStyle.FalseBold.Value;
        }

        if (!string.IsNullOrWhiteSpace(color))
            styles.Add($"color:{color}");
        if (bold)
            styles.Add("font-weight:bold");

        return styles.Count == 0 ? "" : $" style='{string.Join(";", styles)}'";
    }

    private static bool EvaluateConditionalStyle(DataRow row, ReportColumnConditionalStyle condition)
    {
        if (string.IsNullOrWhiteSpace(condition.Field) || !row.Table.Columns.Contains(condition.Field))
            return false;

        var actual = row[condition.Field];
        if (actual == null || actual == DBNull.Value)
            return false;

        var expectedText = condition.Value;
        if (double.TryParse(Convert.ToString(actual, CultureInfo.InvariantCulture), NumberStyles.Any, CultureInfo.InvariantCulture, out var actualNumber) &&
            double.TryParse(expectedText, NumberStyles.Any, CultureInfo.InvariantCulture, out var expectedNumber))
        {
            return condition.Operator switch
            {
                "<>" => actualNumber != expectedNumber,
                ">" => actualNumber > expectedNumber,
                ">=" => actualNumber >= expectedNumber,
                "<" => actualNumber < expectedNumber,
                "<=" => actualNumber <= expectedNumber,
                _ => actualNumber == expectedNumber
            };
        }

        var comparison = string.Compare(Convert.ToString(actual, CultureInfo.InvariantCulture), expectedText,
            StringComparison.OrdinalIgnoreCase);
        return condition.Operator switch
        {
            "<>" => comparison != 0,
            ">" => comparison > 0,
            ">=" => comparison >= 0,
            "<" => comparison < 0,
            "<=" => comparison <= 0,
            _ => comparison == 0
        };
    }

    private static string FormatCellValue(DataRow row, ReportColumn col)
    {
        var val = row.Table.Columns.Contains(col.Field) ? row[col.Field] : null;
        if (val == null || val == DBNull.Value) return "";

        if (!string.IsNullOrEmpty(col.Format))
        {
            try
            {
                if (val is IFormattable formattable)
                    return formattable.ToString(col.Format, CultureInfo.CurrentCulture);
            }
            catch { }
        }

        // Wrap conversions in a try — a column's inferred type can be wrong (e.g. a text
        // column accidentally typed as Currency because its name contains "cost"); rather
        // than crashing the whole render, fall back to the raw string.
        try
        {
            return col.ColumnType switch
            {
                ReportColumnType.Currency => Convert.ToDouble(val).ToString("C2"),
                ReportColumnType.Decimal => Convert.ToDouble(val).ToString("N2"),
                ReportColumnType.Integer => Convert.ToInt64(val).ToString("N0"),
                ReportColumnType.Percent => (Convert.ToDouble(val) * 100).ToString("N1") + "%",
                ReportColumnType.Date => Convert.ToDateTime(val).ToString("yyyy-MM-dd"),
                ReportColumnType.DateTime => Convert.ToDateTime(val).ToString("yyyy-MM-dd HH:mm"),
                ReportColumnType.Boolean => Convert.ToBoolean(val) ? "Yes" : "No",
                _ => val.ToString() ?? ""
            };
        }
        catch
        {
            return val.ToString() ?? "";
        }
    }

    private static string ComputeAggregate(List<DataRow> rows, ReportAggregate agg)
    {
        try
        {
            var values = rows.Where(r => r.Table.Columns.Contains(agg.Field) && r[agg.Field] != DBNull.Value)
                             .Select(r => Convert.ToDouble(r[agg.Field]))
                             .ToList();

            if (values.Count == 0) return "";

            double result = agg.AggregateType switch
            {
                ReportAggregateType.Sum => values.Sum(),
                ReportAggregateType.Average => values.Average(),
                ReportAggregateType.Count => values.Count,
                ReportAggregateType.Min => values.Min(),
                ReportAggregateType.Max => values.Max(),
                _ => values.Sum()
            };

            return !string.IsNullOrEmpty(agg.Format)
                ? result.ToString(agg.Format)
                : result.ToString("N2");
        }
        catch { return ""; }
    }

    private static string ReplacePlaceholders(string text, string title, int page, int total, DateTime now)
    {
        if (string.IsNullOrEmpty(text)) return "";
        return text
            .Replace("{PageNumber}", page.ToString())
            .Replace("{TotalPages}", total.ToString())
            .Replace("{DateTime}", now.ToString("yyyy-MM-dd HH:mm"))
            .Replace("{ReportTitle}", title);
    }

    private static string Escape(string? text)
        => System.Web.HttpUtility.HtmlEncode(text ?? "");

    private static string BuildColumnHeaderHtml(ReportColumn col)
    {
        return Escape(col.HeaderText);
    }

    private static string BuildSubreportLinkHtml(ReportColumn col, DataRow? row, bool useHeaderFallback)
    {
        var link = col.SubreportLink;
        if (link == null || !link.EnableOnDemand ||
            (string.IsNullOrWhiteSpace(link.Url) && !link.IsInline))
            return useHeaderFallback ? Escape(col.HeaderText) : "";

        var label = string.IsNullOrWhiteSpace(link.SubreportName)
            ? col.HeaderText
            : link.SubreportName;
        if (string.IsNullOrWhiteSpace(label))
            label = "Open";

        var linkText = Escape(label);
        var href = System.Web.HttpUtility.HtmlAttributeEncode(
            string.IsNullOrWhiteSpace(link.Url) ? "#" : link.Url);
        var title = System.Web.HttpUtility.HtmlAttributeEncode(
            $"Open {label} subreport");
        var payload = row == null ? "" : BuildSubreportPayloadAttribute(link, label, row);
        var payloadAttr = string.IsNullOrEmpty(payload) ? "" : $" data-subreport='{payload}'";
        return $"<a class='fx-rpt-subreport-link' href='{href}'{payloadAttr} title='{title}'>{linkText}</a>";
    }

    private static string BuildSubreportPayloadAttribute(ReportSubreportLink link, string label, DataRow row)
    {
        var filters = new List<object>();
        foreach (var parameterLink in link.ParameterLinks)
        {
            if (string.IsNullOrWhiteSpace(parameterLink.MainReportAlias) ||
                string.IsNullOrWhiteSpace(parameterLink.SubreportTable) ||
                string.IsNullOrWhiteSpace(parameterLink.SubreportField) ||
                !row.Table.Columns.Contains(parameterLink.MainReportAlias))
            {
                continue;
            }

            var value = row[parameterLink.MainReportAlias];
            filters.Add(new
            {
                table = parameterLink.SubreportTable,
                field = parameterLink.SubreportField,
                parameter = parameterLink.LinkedParameterName,
                value = value == null || value == DBNull.Value ? "" : value.ToString() ?? ""
            });
        }

        var json = JsonSerializer.Serialize(new
        {
            title = label,
            xmlPath = link.XmlPath,
            subreportName = link.SubreportName,
            isInline = link.IsInline,
            filters
        });
        return System.Web.HttpUtility.HtmlAttributeEncode(json);
    }

    private static void AddLinkedSubreportParameters(
        Dictionary<string, object> sqlParams,
        ReportDefinition subDefinition,
        List<SubreportClickFilter>? linkedParameterValues)
    {
        if (linkedParameterValues == null || linkedParameterValues.Count == 0)
            return;

        var parametersByName = new Dictionary<string, ReportParameter>(StringComparer.OrdinalIgnoreCase);
        foreach (var parameter in subDefinition.Parameters)
            parametersByName.TryAdd(parameter.Name, parameter);

        foreach (var filter in linkedParameterValues)
        {
            var parameterName = SanitizeCrystalParameterName(filter.parameter);
            if (string.IsNullOrWhiteSpace(parameterName))
            {
                continue;
            }

            if (parametersByName.TryGetValue(parameterName, out var parameter))
                sqlParams[parameterName] = CoerceSubreportParameterValue(filter.value ?? "", parameter.ParameterType);
            else if (subDefinition.Sql.Contains("@" + parameterName, StringComparison.OrdinalIgnoreCase))
                sqlParams[parameterName] = filter.value ?? "";
        }
    }

    private static object CoerceSubreportParameterValue(string value, ReportParameterType type)
        => type switch
        {
            ReportParameterType.Integer => long.TryParse(value, NumberStyles.Any, CultureInfo.InvariantCulture, out var i) ? i : value,
            ReportParameterType.Decimal => decimal.TryParse(value, NumberStyles.Any, CultureInfo.InvariantCulture, out var d) ? d : value,
            ReportParameterType.Date => DateTime.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.None, out var dt) ? dt : value,
            ReportParameterType.Boolean => bool.TryParse(value, out var b) ? b : value,
            _ => value
        };

    private static string SanitizeCrystalParameterName(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return "";
        var text = raw.Trim();
        if (text.StartsWith("{?", StringComparison.Ordinal) && text.EndsWith("}", StringComparison.Ordinal))
            text = text[2..^1];
        else if (text.StartsWith("?", StringComparison.Ordinal))
            text = text[1..];

        var sb = new System.Text.StringBuilder(text.Length);
        foreach (var c in text)
            if (char.IsLetterOrDigit(c) || c == '_') sb.Append(c);
        return sb.ToString();
    }

    /// <summary>Produces the inline <c>text-align</c> style for a <see cref="ReportAlignment"/>.</summary>
    private static string AlignmentStyle(ReportAlignment alignment) => alignment switch
    {
        ReportAlignment.Left => "text-align:left",
        ReportAlignment.Right => "text-align:right",
        _ => "text-align:center"
    };

    /// <summary>
    /// Applies the configured <see cref="ReportOptions.SessionAutoInjectParameters"/> to a
    /// SQL parameter bag: for each configured name, if the SQL references <c>@Name</c>
    /// and the caller didn't supply a value, pull it from session state. Lets report
    /// writers add organization-wide default parameters (UserId, TenantId, ...)
    /// without any report-specific code in the writer.
    /// </summary>
    private void AutoInjectSessionParameters(Dictionary<string, object> sqlParams, string sql)
    {
        foreach (var name in Options.SessionAutoInjectParameters)
        {
            if (string.IsNullOrWhiteSpace(name)) continue;
            if (sqlParams.ContainsKey(name)) continue;
            if (!sql.Contains("@" + name, StringComparison.OrdinalIgnoreCase)) continue;
            var value = ResolveSessionParameter(name);
            if (value != null) sqlParams[name] = value;
        }
    }

    /// <summary>
    /// Looks up a well-known session-provided parameter value via the host-provided
    /// <see cref="IReportSessionContext"/>. Lets the host wire any number of parameter
    /// names (UserId, TenantId, …) without changing this control.
    /// </summary>
    private object? ResolveSessionParameter(string name) => SessionState.Get(name);

    /// <summary>
    /// Throws if the SQL result exceeds <see cref="ReportOptions.MaxRowsPerReport"/>. Protects
    /// the UI from runaway result sets (a badly-filtered report could otherwise return
    /// millions of rows and lock up the browser). Configurable per-installation.
    /// </summary>
    private void GuardRowLimit(System.Data.DataTable dt)
    {
        var limit = Options.MaxRowsPerReport;
        if (limit > 0 && dt.Rows.Count > limit)
            throw new InvalidOperationException(
                $"Report returned {dt.Rows.Count} rows, exceeding the configured limit of {limit}. " +
                $"Add more restrictive parameters or raise ReportOptions.MaxRowsPerReport.");
    }

    /// <summary>
    /// Builds the <c>data-path</c> attribute value for a rendered row — a JSON array of
    /// <c>{field, value}</c> entries for every group field present in the row's DataTable.
    /// The result is HTML-attribute-encoded so it can live inside <c>data-path='...'</c>
    /// without breaking the HTML (single quotes and &lt;/&gt; chars are escaped).
    ///
    /// <para>
    /// When the user clicks the row, the JS delegator reads this attribute and passes it
    /// to <see cref="OnCellClick"/>, which uses it to open a drill-down tab.
    /// </para>
    /// </summary>
    private static string BuildCellPathAttribute(DataRow row, List<ReportGroup> groups)
    {
        var entries = new List<object>();
        foreach (var g in groups)
        {
            if (!row.Table.Columns.Contains(g.Field)) continue;
            var v = (row[g.Field]?.ToString() ?? "").TrimEnd();
            entries.Add(new { field = g.Field, value = v });
        }
        if (entries.Count == 0) return "";
        var json = JsonSerializer.Serialize(entries);
        // HTML-attribute-encode the JSON (handles &, <, >, ", ') so it's safe in data-path='...'.
        return System.Web.HttpUtility.HtmlAttributeEncode(json);
    }

    private static ReportColumnType MapDataType(Type type)
    {
        if (type == typeof(int) || type == typeof(long) || type == typeof(short) || type == typeof(byte))
            return ReportColumnType.Integer;
        if (type == typeof(decimal) || type == typeof(double) || type == typeof(float))
            return ReportColumnType.Decimal;
        if (type == typeof(DateTime) || type == typeof(DateTimeOffset))
            return ReportColumnType.DateTime;
        if (type == typeof(bool))
            return ReportColumnType.Boolean;
        return ReportColumnType.Text;
    }

    // ═══════════════════════════════════════════════════════════════
    //  CHROME RENDER FRAGMENTS — bare page content + recursive tree node
    //  (Both used by the @if (ShowChrome) { … } / else { … } branches at
    //  the top of the markup. Defined in @code so the recursive tree
    //  fragment can call itself.)
    // ═══════════════════════════════════════════════════════════════

    private RenderFragment RenderReportContent() => __builder =>
    {
        @if (IsLoading && !ShowChrome)
        {
            <div class="fx-report-loading">Loading report...</div>
        }
        else if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="fx-report-error">
                <strong>Report Error</strong>
                <p>@ErrorMessage</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(PdfDataUrl))
        {
            <iframe src="@PdfDataUrl" class="fx-report-pdf-frame" title="Report"></iframe>
        }
        else if (Tabs.Count > 0 && ActiveTab != null && ActiveTab.Pages.Count > 0)
        {
            @if (Tabs.Count > 1)
            {
                <div class="fx-report-tab-bar">
                    @for (var i = 0; i < Tabs.Count; i++)
                    {
                        var idx = i;
                        var tab = Tabs[idx];
                        <div class="fx-report-tab @(idx == ActiveTabIndex ? "active" : "")"
                             @onclick="() => SwitchTab(idx)">
                            <span>@tab.Title</span>
                            @if (idx > 0)
                            {
                                <button class="fx-report-tab-close"
                                        @onclick="() => CloseTab(idx)"
                                        @onclick:stopPropagation="true">×</button>
                            }
                        </div>
                    }
                </div>
            }
            <div class="fx-report-pages">
                <div class="fx-report-page @(ActiveTab.Orientation == ReportOrientation.Landscape ? "landscape" : "portrait")">
                    @((MarkupString)ActiveTab.Pages[Math.Min(Math.Max(ActiveTab.CurrentPage, 1), ActiveTab.Pages.Count) - 1])
                </div>
            </div>
        }
        else
        {
            <div class="fx-report-empty">No report loaded.</div>
        }
    };

    private RenderFragment RenderGroupTreeNode(FxGroupNode node) => __builder =>
    {
        <li>
            <span class="fx-rpt-tree-node">
                @if (node.Children?.Any() == true)
                {
                    <span class="fx-rpt-tree-toggle" @onclick="() => ToggleGroupNode(node)" @onclick:stopPropagation="true">
                        @(node.Expanded ? "▼" : "▶")
                    </span>
                }
                else
                {
                    <span class="fx-rpt-tree-toggle leaf">&nbsp;</span>
                }
                <span class="fx-rpt-tree-label @(ReferenceEquals(_selectedTreeNode, node) ? "selected" : "")"
                      @onclick="() => OnGroupNodeClicked(node)" title="@node.Value">
                    @node.Label
                </span>
            </span>
            @if (node.Expanded && node.Children?.Any() == true)
            {
                <ul>
                    @foreach (var child in node.Children)
                    {
                        @RenderGroupTreeNode(child)
                    }
                </ul>
            }
        </li>
    };
}
