    public async Task ShowReportAsync(string file, IReadOnlyDictionary<string, string>? seedParameters = null)
    {
        try
        {
            IsLoading = true;
            ReportFilePath = file;
            await OnPageTitleChanged.InvokeAsync(Path.GetFileNameWithoutExtension(file));
            StatusMessage = $"Loading report: {file}";
            await InvokeAsync(StateHasChanged);

            _seedParameters.Clear();
            if (seedParameters != null)
                foreach (var kv in seedParameters)
                    if (!string.IsNullOrEmpty(kv.Value))
                        _seedParameters[kv.Key] = kv.Value;
            if (!_seedParameters.ContainsKey("DivisionID"))
            {
                var divId = SessionState.Get("DivisionID");
                if (divId != null) _seedParameters["DivisionID"] = divId.ToString() ?? "";
            }

            if (!file.EndsWith(".rpt", StringComparison.OrdinalIgnoreCase)
                && !file.EndsWith(".xml", StringComparison.OrdinalIgnoreCase))
            {
                StatusMessage = $"Unsupported report extension: {file}";
                return;
            }

            var xmlPath = await ResolveOrConvertXmlPathAsync(file);
            if (xmlPath != null)
            {
                var definition = XmlLoader.Load(xmlPath);
                var typedParams = _seedParameters.ToDictionary(p => p.Key, p => (object)p.Value);

                var missingRequired = definition.Parameters
                    .Where(p => p.Required
                        && !typedParams.ContainsKey(p.Name)
                        && !string.Equals(p.Name, "DivisionID", StringComparison.OrdinalIgnoreCase))
                    .ToList();

                if (missingRequired.Count > 0 && _paramDialog != null)
                {
                    StatusMessage = "Waiting for parameter values...";
                    IsLoading = false;
                    await InvokeAsync(StateHasChanged);

                    var title = $"Report: {Path.GetFileNameWithoutExtension(xmlPath)}";
                    var userValues = await _paramDialog.PromptAsync(title, missingRequired, _lastPromptedValues);
                    if (userValues == null)
                    {
                        StatusMessage = "Report cancelled.";
                        return;
                    }
                    foreach (var kv in userValues)
                        typedParams[kv.Key] = kv.Value;

                    IsLoading = true;
                    StatusMessage = $"Loading report: {xmlPath}";
                    await InvokeAsync(StateHasChanged);
                }

                _lastPromptedValues = new Dictionary<string, object>(typedParams, StringComparer.OrdinalIgnoreCase);

                var multiSelections = new Dictionary<string, IReadOnlyList<string>>(StringComparer.OrdinalIgnoreCase);
                foreach (var key in typedParams.Keys.ToList())
                {
                    if (typedParams[key] is string[] arr)
                    {
                        multiSelections[key] = arr;
                        typedParams.Remove(key);
                    }
                }
                if (multiSelections.Count > 0)
                {
                    typedParams = MultiValueParameterRewriter.Apply(definition, multiSelections, typedParams);

                    var capturedSelections = multiSelections;
                    DefinitionPostProcessor = drillDef =>
                    {
                        MultiValueParameterRewriter.Apply(
                            drillDef, capturedSelections, new Dictionary<string, object>());
                    };
                }
                else
                {
                    DefinitionPostProcessor = null;
                }

                SetXmlSource(xmlPath);
                await ShowSqlReport(definition, typedParams);
                ReportLoaded = true;
                StatusMessage = $"Print Preview - {Path.GetFileNameWithoutExtension(xmlPath)} (XML)";
            }
            else
            {
                var missingName = Path.GetFileName(file);
                ErrorMessage = $"{missingName} not Found";
                StatusMessage = $"{missingName} not Found";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
            StatusMessage = $"Error: {ex.Message}";
            Logger.LogError(ex, "ShowReportAsync failed for {File}", file);
        }
        finally
        {
            IsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string? ResolveXmlPathLocal(string file)
    {
        if (string.IsNullOrWhiteSpace(file)) return null;
        if (file.EndsWith(".xml", StringComparison.OrdinalIgnoreCase))
            return File.Exists(file) ? file : null;
        var dir = Path.GetDirectoryName(file) ?? "";
        var baseName = Path.GetFileNameWithoutExtension(file);
        if (!string.IsNullOrEmpty(dir) &&
            Path.GetFileName(dir).Equals("rpt", StringComparison.OrdinalIgnoreCase))
        {
            var xmlDir = Path.Combine(Path.GetDirectoryName(dir) ?? "", "xml");
            var candidate = Path.Combine(xmlDir, baseName + ".xml");
            if (File.Exists(candidate)) return candidate;
        }
        var sibling = Path.Combine(dir, baseName + ".xml");
        if (File.Exists(sibling)) return sibling;
        return null;
    }

    private async Task<string?> ResolveOrConvertXmlPathAsync(string file)
    {
        var xmlPath = ResolveXmlPathLocal(file);
        if (xmlPath != null || !file.EndsWith(".rpt", StringComparison.OrdinalIgnoreCase))
            return xmlPath;

        if (OperatingSystem.IsBrowser())
            throw new NotSupportedException("Crystal .rpt conversion requires server-side .NET because it reads the report binary from disk.");

        var outputPath = GetDefaultXmlOutputPath(file);
        Logger.LogInformation("Converting Crystal RPT for viewer: {Rpt} -> {Xml}", file, outputPath);

        var result = await CrystalRptToXml.ConvertAsync(
            file,
            outputPath,
            new CrystalRptConversionOptions(
                ExtractSubreports: true,
                Progress: message => Logger.LogDebug("RptToXml: {Message}", message)));

        return result.ReportXmlPath;
    }

    private static string GetDefaultXmlOutputPath(string rptFilePath)
    {
        var dir = Path.GetDirectoryName(rptFilePath) ?? "";
        var baseName = Path.GetFileNameWithoutExtension(rptFilePath);
        if (!string.IsNullOrEmpty(dir) &&
            Path.GetFileName(dir).Equals("rpt", StringComparison.OrdinalIgnoreCase))
        {
            return Path.Combine(Path.GetDirectoryName(dir) ?? "", "xml", baseName + ".xml");
        }

        return Path.Combine(dir, baseName + ".xml");
    }

