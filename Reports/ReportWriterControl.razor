@* ReportWriterControl - generic SQL-driven HTML report renderer.

   • Renders a ReportDefinition (built in code or loaded from a Crystal XML
     export) to paginated HTML pages with Crystal-Reports-style group
     headers, footers, drill-down tabs, and a clickable group tree.
   • Converts raw Crystal Reports .rpt files to Crystal XML with the native
     C# converter, then renders them through the same SQL/HTML pipeline.

   Application-agnostic: every external dependency is an interface
   (IReportDataExecutor, IReportSessionContext, IReportExporter,
   IReportPickListProvider). Host apps register concrete implementations
   in their DI container.

   Usage:
     <ReportWriterControl @ref="reportWriter" />

     // SQL/XML report:
     await reportWriter.ShowSqlReport(reportDefinition, parameterValues);

     // Crystal Report (.rpt, converted to XML first):
     await reportWriter.ShowReportAsync("path/to/report.rpt", parameters);
*@

@namespace Fx.ControlKit.Reports

@using System.Data
@using System.Globalization
@using System.IO
@using System.Text.Json
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Web
@implements IDisposable

@inject CrystalXmlReportLoader XmlLoader
@inject IReportDataExecutor db
@inject IReportSessionContext SessionState
@inject IJSRuntime JSRuntime
@inject ILogger<ReportWriterControl> Logger
@inject ReportOptions Options
@* IReportExporter is OPTIONAL — Crystal-Reports binary export is host-specific.
   When the host has no Crystal Reports DLLs available, no implementation is
   registered, and the writer falls back to browser print-to-PDF for export. *@
@inject IReportExporter? CrystalSvc
@* IReportViewerSettings persists per-user viewer preferences (zoom level
   today; room for more). Falls back to InMemoryReportViewerSettings when
   no host adapter is registered. *@
@inject IReportViewerSettings ViewerSettings

@if (ShowChrome)
{
    @* Full viewer chrome — toolbar + group tree + status bar + param dialog.
       Set ShowChrome=false on the host to drop these and render the bare
       page area only (dashboards, modal previews, embedded thumbnails). *@
    <div class="fx-rpt-viewer-container">

        @if (IsLoading)
        {
            <div class="fx-rpt-loading-overlay">
                <div class="fx-rpt-loading-spinner">⏳ Loading Report...</div>
            </div>
        }

        @* ── Toolbar (FxControlKit ToolbarControl + ToolbarButtonControl) ──── *@
        <ToolbarControl>
            <div class="fx-rpt-nav">
                <button disabled="@(CurrentPage <= 1)" @onclick="OnFirstPage" title="First Page">⏮</button>
                <button disabled="@(CurrentPage <= 1)" @onclick="OnPreviousPage" title="Previous Page">◀</button>
                <input type="number" value="@CurrentPage" @onchange="@(e => OnPageChanged(int.TryParse(e.Value?.ToString(), out var p) ? p : 1))" min="1" max="@PageCount" title="Page Number" />
                <span>of @PageCount</span>
                <button disabled="@(CurrentPage >= PageCount)" @onclick="OnNextPage" title="Next Page">▶</button>
                <button disabled="@(CurrentPage >= PageCount)" @onclick="OnLastPage" title="Last Page">⏭</button>
            </div>

            <ToolbarSeparatorControl />

            <ToolbarButtonControl Vertical="true" OnClick="OnClose">
                <span style="font-size:18px;">✕</span>
                <span class="fx-rpt-toolbar-label">Close</span>
            </ToolbarButtonControl>

            <ToolbarSeparatorControl />

            <ToolbarButtonControl Vertical="true" OnClick="ChromeOnPrint">
                <span style="font-size:18px;">🖨️</span>
                <span class="fx-rpt-toolbar-label">Print</span>
            </ToolbarButtonControl>

            <div class="fx-rpt-export-menu @(ExportMenuOpen ? "open" : "")">
                <ToolbarButtonControl Vertical="true" OnClick="ToggleExportMenu">
                    <span style="font-size:18px;">📤</span>
                    <span class="fx-rpt-toolbar-label">Export ▾</span>
                </ToolbarButtonControl>
                <div class="fx-rpt-export-items">
                    <button @onclick='() => ChromeOnExport("PDF")'>📄 PDF</button>
                    <button @onclick='() => ChromeOnExport("Excel")'>📊 Excel</button>
                    <button @onclick='() => ChromeOnExport("Word")'>📝 Word</button>
                    <button @onclick='() => ChromeOnExport("CSV")'>📋 CSV</button>
                </div>
            </div>

            <ToolbarSeparatorControl />

            <ToolbarButtonControl Vertical="true" OnClick="ChromeOnRefresh">
                <span style="font-size:18px;">🔄</span>
                <span class="fx-rpt-toolbar-label">Refresh</span>
            </ToolbarButtonControl>

            <ToolbarSeparatorControl />

            <div class="fx-rpt-zoom-controls">
                <ToolbarButtonControl OnClick="ChromeOnZoomOut">
                    <span style="font-size:16px;">🔍−</span>
                </ToolbarButtonControl>
                <select @bind="ZoomLevel" @bind:after="ChromeOnZoomChanged" title="Zoom Level">
                    <option value="25">25%</option>
                    <option value="50">50%</option>
                    <option value="75">75%</option>
                    <option value="100">100%</option>
                    <option value="125">125%</option>
                    <option value="150">150%</option>
                    <option value="200">200%</option>
                    <option value="0">Fit Page</option>
                    <option value="-1">Fit Width</option>
                </select>
                <ToolbarButtonControl OnClick="ChromeOnZoomIn">
                    <span style="font-size:16px;">🔍+</span>
                </ToolbarButtonControl>
            </div>

            <ToolbarSeparatorControl />

            <div class="fx-rpt-search-controls">
                <input type="text" @bind="SearchText" @bind:event="oninput" placeholder="Search..." @onkeydown="ChromeOnSearchKeyDown" />
                <ToolbarButtonControl OnClick="ChromeOnSearch">
                    <span style="font-size:16px;">🔎</span>
                </ToolbarButtonControl>
            </div>

            <ToolbarSeparatorControl />

            <ToolbarButtonControl Vertical="true" OnClick="ChromeOnEditParameters">
                <span style="font-size:18px;">⚙️</span>
                <span class="fx-rpt-toolbar-label">Parameters</span>
            </ToolbarButtonControl>

            <ToolbarSeparatorControl />

            <ToolbarButtonControl Vertical="true" OnClick="ToggleGroupTreePanel">
                <span style="font-size:18px;">🌳</span>
                <span class="fx-rpt-toolbar-label">@(ShowGroupTree ? "Hide Tree" : "Show Tree")</span>
            </ToolbarButtonControl>

            <ToolbarSeparatorControl />

            <div class="fx-rpt-tree-mode" role="radiogroup" aria-label="Tree click behavior" title="What happens when you click a group node">
                <span class="fx-rpt-tree-mode-label">Tree:</span>
                <label class="fx-rpt-tree-mode-radio">
                    <input type="radio" name="fx-rpt-tree-mode" value="Group"
                           checked="@(TreeMode == TreeNavigationMode.Group)"
                           @onchange="() => SetTreeMode(TreeNavigationMode.Group)" />
                    <span title="Click a node to scroll to that group on the current tab.">Group</span>
                </label>
                <label class="fx-rpt-tree-mode-radio">
                    <input type="radio" name="fx-rpt-tree-mode" value="DrillDown"
                           checked="@(TreeMode == TreeNavigationMode.DrillDown)"
                           @onchange="() => SetTreeMode(TreeNavigationMode.DrillDown)" />
                    <span title="Click a node to open a new drill-down tab filtered to that group.">Drill Down</span>
                </label>
            </div>
        </ToolbarControl>

        @* ── Content Area — group tree + bare renderer ────────────────── *@
        <div class="fx-rpt-content-area">
            @if (ShowGroupTree)
            {
                <div class="fx-rpt-group-tree">
                    <strong style="font-size: 13px; display: block; margin-bottom: 8px;">Report Groups</strong>
                    @if (GroupTree.Any())
                    {
                        <ul>
                            @foreach (var node in GroupTree)
                            {
                                @RenderGroupTreeNode(node)
                            }
                        </ul>
                    }
                    else
                    {
                        <p style="color: #999; font-size: 12px;">No groups available.</p>
                    }
                </div>
            }

            <div class="fx-rpt-viewer-panel" style="transform: scale(@(ZoomScale)); transform-origin: top left;">
                @RenderReportContent()
            </div>
        </div>

        @* ── Status Bar ──────────────────────────────────────── *@
        <div class="fx-rpt-status-bar">
            <span>@StatusMessage</span>
            <span>@(ReportLoaded ? $"Zoom: {(ZoomLevel > 0 ? ZoomLevel + "%" : ZoomLevel == 0 ? "Fit Page" : "Fit Width")}" : "")</span>
        </div>
    </div>

    @* Embedded parameter prompt — opened by ShowReportAsync when the
       report has required parameters not pre-seeded. *@
    <ReportParamDialogControl @ref="_paramDialog" />
}
else
{
    @* Bare renderer — same content as the chrome-wrapped panel but without
       toolbar/tree/status. Hosts that want to embed the report inside their
       own UI (dashboards, modal previews) set ShowChrome=false. *@
    <div class="fx-report-container">
        @RenderReportContent()
    </div>
}

@code {
    // ════════════════════════════════════════════════════════════════════
    //  PARAMETERS
    // ════════════════════════════════════════════════════════════════════

    /// <summary>
    /// When true (default), the control renders its full viewer chrome:
    /// toolbar (first / prev / next / last / close / print / export /
    /// refresh / zoom / search / parameters / hide-tree / tree-mode),
    /// left-side group tree panel, status bar, and the embedded
    /// parameter prompt dialog. Set to false to drop the bare renderer
    /// into a host that already provides its own UI (dashboards, modal
    /// previews, etc.) — only the page area is shown.
    /// </summary>
    [Parameter] public bool ShowChrome { get; set; } = true;

    /// <summary>
    /// Fires when the user clicks the toolbar's Close button. Hosts wire
    /// this to navigate back, close a modal, signal a tab host, etc.
    /// When unset and ShowChrome=true, the Close button is still
    /// rendered but the click is a no-op.
    /// </summary>
    [Parameter] public EventCallback OnClose { get; set; }

    /// <summary>
    /// Fires when <see cref="ShowReportAsync"/> resolves the report to
    /// load — receives the report's display name (filename without
    /// extension). Hosts use this to update a parent shell's titlebar
    /// (e.g. FMain's child-form title) without re-parsing the report
    /// path themselves.
    /// </summary>
    [Parameter] public EventCallback<string> OnPageTitleChanged { get; set; }

    // === Public State ===
    public bool IsLoading { get; private set; }
    public string? ErrorMessage { get; private set; }
    public ReportOrientation Orientation => ActiveTab?.Orientation ?? ReportOrientation.Portrait;
    public int PageCount => ActiveTab?.Pages.Count ?? 0;

    /// <summary>Currently displayed page (1-based) in the ACTIVE tab. Adjust via <see cref="GoToPage"/>.</summary>
    public int CurrentPage => ActiveTab?.CurrentPage ?? 1;

    /// <summary>
    /// Hierarchical group tree for the ACTIVE tab. Mirrors Crystal Reports' <c>DisplayGroupTree</c>.
    /// </summary>
    public List<FxGroupNode> GroupTree => ActiveTab?.Tree ?? _emptyTree;

    /// <summary>All open tabs — index 0 is always the Main Report. Drill-down tabs are appended.</summary>
    public List<ReportTab> Tabs { get; private set; } = new();

    /// <summary>Index of the currently-displayed tab.</summary>
    public int ActiveTabIndex { get; private set; } = 0;

    /// <summary>Convenience accessor for the active tab (null if none open).</summary>
    public ReportTab? ActiveTab => (Tabs.Count > 0 && ActiveTabIndex < Tabs.Count) ? Tabs[ActiveTabIndex] : null;

    /// <summary>Fires after the report finishes rendering (so the viewer can refresh its tree).</summary>
    public event Action? OnRenderComplete;

    /// <summary>
    /// Optional hook invoked on every <see cref="ReportDefinition"/> just after it is
    /// loaded from XML and before its SQL is executed. Lets the host page tweak the
    /// definition (e.g. rewrite single-value parameters as multi-value <c>IN</c>
    /// clauses, swap column formats, override grouping, etc.).
    ///
    /// <para>
    /// Currently invoked from <see cref="OpenDrillDown"/> so drill-down tabs share
    /// the same massaging the host applied to the main definition before calling
    /// <see cref="ShowSqlReport"/>.
    /// </para>
    /// </summary>
    public Action<ReportDefinition>? DefinitionPostProcessor { get; set; }

    // === Internal State ===
    private string PdfDataUrl = "";
    private static readonly List<FxGroupNode> _emptyTree = new();

    // Context for drill-down — stored when ShowSqlReport runs from an XML-backed report so
    // the tree-click handler can build drill-down tabs without re-parsing the XML.
    private string? _xmlFilePath;
    private Dictionary<string, object>? _lastParameters;

    // .NET ↔ JS bridge for row-cell click drill-down (every rendered row is clickable).
    private DotNetObjectReference<ReportWriterControl>? _dotNetRef;
    private bool _jsClickHandlerRegistered;

    // ════════════════════════════════════════════════════════════════════
    //  CHROME STATE — toolbar / status bar / group tree / param dialog
    // ════════════════════════════════════════════════════════════════════

    // Public-readable status message (status bar's left cell). Updated as
    // the user navigates / loads / cancels / errors.
    public string StatusMessage { get; private set; } = "Ready";
    public bool ReportLoaded { get; private set; }

    // Toolbar / panel toggles.
    private bool ShowGroupTree = true;
    private bool ExportMenuOpen;

    // Tree-click mode — Group scrolls to / highlights the matching group
    // header on the current tab; DrillDown opens a new filtered tab.
    private TreeNavigationMode TreeMode { get; set; } = TreeNavigationMode.Group;

    // Zoom (percent; 0 = Fit Page, -1 = Fit Width). Loaded from
    // IReportViewerSettings on first render.
    private int ZoomLevel = 100;
    private double ZoomScale => ZoomLevel > 0 ? ZoomLevel / 100.0 : 1.0;

    // Search box state.
    private string SearchText = "";

    // Tracks the report file most recently passed to ShowReportAsync —
    // drives the Refresh button and ReportFilePath-aware features.
    private string ReportFilePath = "";

    // Captured BEFORE multi-value rewrite so the "Parameters" toolbar
    // button can re-prompt with the user's prior selections intact.
    private Dictionary<string, object>? _lastPromptedValues;

    // Caller-supplied / session-injected parameters merged into every
    // ShowReportAsync run (e.g. DivisionID).
    private readonly Dictionary<string, string> _seedParameters = new(StringComparer.OrdinalIgnoreCase);

    // Embedded parameter prompt dialog — same control the page used to
    // host. Filled in by Blazor on first render.
    private ReportParamDialogControl? _paramDialog;

    // True once OnAfterRenderAsync has loaded the persisted zoom level
    // from IReportViewerSettings. Prevents the value from snapping back
    // to 100 if a render fires before the load completes.
    private bool _settingsLoaded;

    // Currently-selected tree node — set in OnGroupNodeClicked, read by
    // RenderGroupTreeNode to apply the .selected class so the user can
    // see which node they last clicked even after the page navigation
    // settles. Cleared on report reload.
    private FxGroupNode? _selectedTreeNode;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            // Load persisted zoom level from the host-supplied settings
            // store. Falls back to 100 when the host hasn't registered
            // an adapter (InMemoryReportViewerSettings default).
            if (!_settingsLoaded)
            {
                try
                {
                    ZoomLevel = await ViewerSettings.GetZoomLevelAsync();
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Failed to load zoom from IReportViewerSettings; using default 100");
                    ZoomLevel = 100;
                }
                _settingsLoaded = true;
                await InvokeAsync(StateHasChanged);
            }
        }
        // Attach/refresh the JS click delegator whenever content changes (tabs + pages can
        // re-render at any time). hfAttachDrillHandler is idempotent.
        if (_dotNetRef != null && Tabs.Count > 0 && !_jsClickHandlerRegistered)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("hfAttachDrillHandler", _dotNetRef);
                _jsClickHandlerRegistered = true;
            }
            catch { /* JS not ready yet — will retry on next render */ }
        }
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
        _dotNetRef = null;
    }

    /// <summary>
    /// Called from JavaScript when the user clicks any row in the rendered report. The
    /// <paramref name="pathJson"/> is a JSON array of <c>{field, value}</c> objects built
    /// from the row's group-field columns — it describes the drill target.
    /// </summary>
    [JSInvokable]
    public async Task OnCellClick(string pathJson)
    {
        if (string.IsNullOrWhiteSpace(pathJson)) return;
        try
        {
            var entries = JsonSerializer.Deserialize<List<CellPathEntry>>(pathJson);
            if (entries == null || entries.Count == 0) return;
            var path = entries.Select(e => new DrillDownFilter(e.field ?? "", e.value ?? "")).ToList();
            // Tab title = the deepest (rightmost) value the user effectively drilled to.
            var leaf = path[^1];
            var label = string.IsNullOrEmpty(leaf.Value) ? "(empty)" : leaf.Value;
            var fakeNode = new FxGroupNode { Label = label, Value = leaf.Value, Field = leaf.Field };
            await OpenDrillDown(fakeNode, path);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "OnCellClick failed for path: {Path}", pathJson);
        }
    }

    /// <summary>
    /// Called from JavaScript when the user clicks a Crystal SubreportObject link in a row.
    /// Opens the extracted subreport XML as another viewer tab, filtered by that row's
    /// Crystal SubReportLink mappings.
    /// </summary>
    [JSInvokable]
    public async Task OnSubreportClick(string payloadJson)
    {
        if (string.IsNullOrWhiteSpace(payloadJson)) return;
        try
        {
            var payload = JsonSerializer.Deserialize<SubreportClickPayload>(payloadJson);
            if (payload == null || string.IsNullOrWhiteSpace(payload.xmlPath)) return;

            var payloadFilters = payload.filters ?? new List<SubreportClickFilter>();
            var filters = payloadFilters
                .Where(f => !string.IsNullOrWhiteSpace(f.table) && !string.IsNullOrWhiteSpace(f.field))
                .Select(f => new ReportFieldFilter(f.table ?? "", f.field ?? "", f.value ?? ""))
                .ToList();

            await OpenSubreport(
                payload.title ?? "Subreport",
                payload.xmlPath!,
                filters,
                payload.isInline,
                payload.subreportName ?? payload.title ?? "",
                payloadFilters);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "OnSubreportClick failed for payload: {Payload}", payloadJson);
        }
    }

    /// <summary>JSON shape emitted in row <c>data-path</c> attributes.</summary>
    private sealed class CellPathEntry
    {
        public string? field { get; set; }
        public string? value { get; set; }
    }

    private sealed class SubreportClickPayload
    {
        public string? title { get; set; }
        public string? xmlPath { get; set; }
        public string? subreportName { get; set; }
        public bool isInline { get; set; }
        public List<SubreportClickFilter>? filters { get; set; }
    }

    private sealed class SubreportClickFilter
    {
        public string? table { get; set; }
        public string? field { get; set; }
        public string? parameter { get; set; }
        public string? value { get; set; }
    }

    /// <summary>
    /// Registers the source Crystal Reports XML file path for the report currently being shown.
    /// Callers that invoke <see cref="ShowSqlReport"/> directly (rather than
    /// <see cref="ShowXmlReport"/>) must call this beforehand so drill-down tabs can re-parse
    /// the XML with different filters.
    /// </summary>
    public void SetXmlSource(string xmlFilePath)
    {
        _xmlFilePath = xmlFilePath;
    }

    /// <summary>Navigates to the specified page (1-based) in the active tab.</summary>
    public void GoToPage(int pageNum)
    {
        var tab = ActiveTab;
        if (tab == null || tab.Pages.Count == 0) return;
        tab.CurrentPage = Math.Max(1, Math.Min(pageNum, tab.Pages.Count));
        StateHasChanged();
    }

    /// <summary>Switches the active tab.</summary>
    public void SwitchTab(int tabIndex)
    {
        if (tabIndex >= 0 && tabIndex < Tabs.Count)
        {
            ActiveTabIndex = tabIndex;
            StateHasChanged();
            OnRenderComplete?.Invoke();
        }
    }

    /// <summary>Closes a drill-down tab (cannot close the Main Report tab at index 0).</summary>
    public void CloseTab(int tabIndex)
    {
        if (tabIndex <= 0 || tabIndex >= Tabs.Count) return;
        Tabs.RemoveAt(tabIndex);
        if (ActiveTabIndex >= Tabs.Count) ActiveTabIndex = Tabs.Count - 1;
        if (ActiveTabIndex < 0) ActiveTabIndex = 0;
        StateHasChanged();
        OnRenderComplete?.Invoke();
    }

    /// <summary>
    /// Opens a drill-down tab for the given tree node. Re-queries with the drill path as an
    /// extra WHERE filter and shows the Detail-level columns (which were suppressed at top-level).
    /// If a tab with the same path is already open, just switches to it.
    /// </summary>
    public async Task OpenDrillDown(FxGroupNode node, List<DrillDownFilter> fullPath)
    {
        if (string.IsNullOrEmpty(_xmlFilePath))
        {
            Logger.LogWarning("Drill-down requested but no source XML file is tracked.");
            return;
        }

        // If a tab with this exact path already exists, just activate it.
        var existing = Tabs.FindIndex(t => PathEquals(t.Path, fullPath));
        if (existing >= 0) { SwitchTab(existing); return; }

        IsLoading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var drillDef = XmlLoader.LoadDrillDown(_xmlFilePath, fullPath);

            // Let the host page massage the drill-down definition (e.g. rewrite
            // single-value Crystal parameters as multi-value IN clauses). The
            // host applied the same transformation to the main definition
            // before calling ShowSqlReport — applying it here keeps drill-down
            // SQL in sync with the parameters in _lastParameters.
            DefinitionPostProcessor?.Invoke(drillDef);

            Orientation_DoNotSet_UseTab(drillDef.Orientation);

            // Resolve parameters the same way as the main report (including any host-registered session-injected parameters).
            var sqlParams = new Dictionary<string, object>();
            foreach (var p in drillDef.Parameters)
            {
                if (_lastParameters?.TryGetValue(p.Name, out var val) == true)
                    sqlParams[p.Name] = val;
                else if (!string.IsNullOrEmpty(p.DefaultValue))
                    sqlParams[p.Name] = p.DefaultValue;
            }
            if (_lastParameters != null)
                foreach (var kv in _lastParameters)
                    if (!sqlParams.ContainsKey(kv.Key)) sqlParams[kv.Key] = kv.Value;
            AutoInjectSessionParameters(sqlParams, drillDef.Sql);

            // Log what we're about to run — critical for debugging empty
            // drill-downs. Console.WriteLine bypasses the Serilog
            // Fx.ControlKit.Reports → Warning override that silences
            // LogInformation, so the SQL is always visible in the
            // process console output (and the file sink picks up the
            // Logger.LogInformation copies as well, when the override
            // is dialed back to Information).
            var pathStr = string.Join(" -> ", fullPath.Select(f => $"{f.Field}={f.Value}"));
            var paramStr = string.Join(", ", sqlParams.Select(kv => $"{kv.Key}={kv.Value} ({kv.Value?.GetType().Name})"));
            Console.WriteLine($"\n═══ DRILL-DOWN ═══");
            Console.WriteLine($"  Path:       [{pathStr}]");
            Console.WriteLine($"  Parameters: {paramStr}");
            Console.WriteLine($"  SQL:");
            Console.WriteLine(drillDef.Sql);
            Console.WriteLine($"═══════════════════\n");
            Logger.LogInformation("Drill-down path: [{Path}]", pathStr);
            Logger.LogInformation("Drill-down parameters: {Params}", paramStr);
            Logger.LogInformation("Drill-down SQL:\n{Sql}", drillDef.Sql);

            var dt = db.Execute(drillDef.Sql, sqlParams.Count > 0 ? sqlParams : null);
            GuardRowLimit(dt);
            var visibleCols = drillDef.Columns.Where(c => !c.Hidden).ToList();
            var rowsPerPage = drillDef.RowsPerPage > 0
                ? drillDef.RowsPerPage
                : (drillDef.Orientation == ReportOrientation.Landscape ? 49 : 70);

            // Same adaptive width pass as the main report — keeps drill-down
            // tabs visually consistent and avoids horizontal overflow when the
            // drill-down columns differ from the summary columns.
            ComputeAdaptiveColumnWidths(drillDef, visibleCols, dt);

            var tab = new ReportTab
            {
                Title = node.Label,
                Path = fullPath.ToList(),
                Pages = RenderHtmlPages(drillDef, dt, visibleCols),
                Tree = BuildGroupTree(dt, drillDef, rowsPerPage),
                CurrentPage = 1,
                Orientation = drillDef.Orientation
            };

            if (dt.Rows.Count == 0 || AllRowsAreEmpty(dt, visibleCols))
            {
                // Either no rows matched the filters, or the LEFT-JOINed detail tables had
                // nothing to attach (every visible column is NULL). Show a diagnostic message
                // so the tab isn't visually blank.
                var reason = dt.Rows.Count == 0
                    ? "No rows matched the drill-down filters."
                    : "No detail rows available for this drill target (all detail-level columns are empty).";
                tab.Pages = new List<string> {
                    $@"<div style='padding:24px; font-family:Arial,sans-serif;'>
                       <h3 style='color:#666;'>{reason}</h3>
                       <p><strong>Filters applied:</strong></p>
                       <ul>{string.Join("", fullPath.Select(f => $"<li>{System.Web.HttpUtility.HtmlEncode(f.Field)} = '{System.Web.HttpUtility.HtmlEncode(string.IsNullOrEmpty(f.Value) ? "(empty)" : f.Value)}'</li>"))}</ul>
                       <p style='color:#888; font-size:12px;'>Usually means this is a &quot;leaf&quot; drill target — no child rows exist for it. Try a different tree node.</p>
                    </div>"
                };
            }

            Tabs.Add(tab);
            ActiveTabIndex = Tabs.Count - 1;

            Logger.LogInformation("Drill-down tab opened: {Title} ({Rows} rows, {Pages} pages)",
                tab.Title, dt.Rows.Count, tab.Pages.Count);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Drill-down failed for node {Label}", node.Label);
            ErrorMessage = $"Drill-down error: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
            await InvokeAsync(StateHasChanged);
            OnRenderComplete?.Invoke();
        }
    }

    /// <summary>
    /// Opens an on-demand Crystal subreport as a normal ReportWriter tab. The sidecar XML
    /// is parsed and executed just like the main report; Crystal SubReportLink mappings
    /// from the clicked row become direct table-field filters on the subreport query.
    /// </summary>
    private async Task OpenSubreport(
        string title,
        string xmlPath,
        List<ReportFieldFilter> filters,
        bool isInline = false,
        string subreportName = "",
        List<SubreportClickFilter>? linkedParameterValues = null)
    {
        if (string.IsNullOrWhiteSpace(xmlPath))
        {
            Logger.LogWarning("Subreport requested but no XML path was supplied.");
            return;
        }

        var fullXmlPath = Path.GetFullPath(xmlPath);
        if (!File.Exists(fullXmlPath))
        {
            ErrorMessage = $"Subreport XML not found: {fullXmlPath}";
            Logger.LogWarning("Subreport XML not found: {XmlPath}", fullXmlPath);
            await InvokeAsync(StateHasChanged);
            return;
        }

        var sourceKey = isInline && !string.IsNullOrWhiteSpace(subreportName)
            ? $"{fullXmlPath}#{subreportName}"
            : fullXmlPath;
        var existing = Tabs.FindIndex(t =>
            string.Equals(t.SourceXmlPath, sourceKey, StringComparison.OrdinalIgnoreCase)
            && FieldFiltersEqual(t.FieldFilters, filters));
        if (existing >= 0)
        {
            SwitchTab(existing);
            return;
        }

        IsLoading = true;
        StatusMessage = $"Loading subreport: {title}";
        await InvokeAsync(StateHasChanged);

        try
        {
            var subDef = isInline
                ? XmlLoader.LoadInlineSubreport(fullXmlPath, subreportName, filters)
                : filters.Count > 0
                    ? XmlLoader.LoadWithFieldFilters(fullXmlPath, filters)
                    : XmlLoader.Load(fullXmlPath);

            DefinitionPostProcessor?.Invoke(subDef);
            Orientation_DoNotSet_UseTab(subDef.Orientation);

            var sqlParams = new Dictionary<string, object>(StringComparer.OrdinalIgnoreCase);
            foreach (var p in subDef.Parameters)
            {
                if (_lastParameters?.TryGetValue(p.Name, out var val) == true)
                    sqlParams[p.Name] = val;
                else if (!string.IsNullOrEmpty(p.DefaultValue))
                    sqlParams[p.Name] = p.DefaultValue;
            }
            if (_lastParameters != null)
                foreach (var kv in _lastParameters)
                    if (!sqlParams.ContainsKey(kv.Key)) sqlParams[kv.Key] = kv.Value;
            AddLinkedSubreportParameters(sqlParams, subDef, linkedParameterValues);
            AutoInjectSessionParameters(sqlParams, subDef.Sql);

            var filterStr = string.Join(", ", filters.Select(f => $"{f.Table}.{f.Field}={f.Value}"));
            Logger.LogInformation("Subreport {Title} filters: {Filters}", title, filterStr);
            Logger.LogInformation("Subreport SQL:\n{Sql}", subDef.Sql);

            var dt = db.Execute(subDef.Sql, sqlParams.Count > 0 ? sqlParams : null);
            GuardRowLimit(dt);
            var visibleCols = subDef.Columns.Where(c => !c.Hidden).ToList();
            var rowsPerPage = subDef.RowsPerPage > 0
                ? subDef.RowsPerPage
                : (subDef.Orientation == ReportOrientation.Landscape ? 49 : 70);

            ComputeAdaptiveColumnWidths(subDef, visibleCols, dt);

            var tabTitle = string.IsNullOrWhiteSpace(title)
                ? Path.GetFileNameWithoutExtension(fullXmlPath)
                : title;
            var tab = new ReportTab
            {
                Title = tabTitle,
                SourceXmlPath = sourceKey,
                FieldFilters = filters.ToList(),
                Pages = RenderHtmlPages(subDef, dt, visibleCols),
                Tree = BuildGroupTree(dt, subDef, rowsPerPage),
                CurrentPage = 1,
                Orientation = subDef.Orientation
            };

            if (dt.Rows.Count == 0 || AllRowsAreEmpty(dt, visibleCols))
            {
                var reason = dt.Rows.Count == 0
                    ? "No rows matched the subreport filters."
                    : "No detail rows available for this subreport target.";
                tab.Pages = new List<string> {
                    $@"<div style='padding:24px; font-family:Arial,sans-serif;'>
                       <h3 style='color:#666;'>{reason}</h3>
                       <p><strong>Filters applied:</strong></p>
                       <ul>{string.Join("", filters.Select(f => $"<li>{System.Web.HttpUtility.HtmlEncode(f.Table)}.{System.Web.HttpUtility.HtmlEncode(f.Field)} = '{System.Web.HttpUtility.HtmlEncode(string.IsNullOrEmpty(f.Value) ? "(empty)" : f.Value)}'</li>"))}</ul>
                    </div>"
                };
            }

            Tabs.Add(tab);
            ActiveTabIndex = Tabs.Count - 1;
            StatusMessage = $"Subreport: {tab.Title}";

            Logger.LogInformation("Subreport tab opened: {Title} ({Rows} rows, {Pages} pages)",
                tab.Title, dt.Rows.Count, tab.Pages.Count);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Subreport failed for {Title} at {XmlPath}", title, fullXmlPath);
            ErrorMessage = $"Subreport error: {ex.Message}";
            StatusMessage = $"Subreport error: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
            await InvokeAsync(StateHasChanged);
            OnRenderComplete?.Invoke();
        }
    }

    // Historical name kept for back-compat with template parsing. Orientation is now per-tab.
    private void Orientation_DoNotSet_UseTab(ReportOrientation o) { /* no-op */ }

    private static bool FieldFiltersEqual(List<ReportFieldFilter> a, List<ReportFieldFilter> b)
    {
        if (a.Count != b.Count) return false;
        for (var i = 0; i < a.Count; i++)
        {
            if (!string.Equals(a[i].Table, b[i].Table, StringComparison.OrdinalIgnoreCase)
                || !string.Equals(a[i].Field, b[i].Field, StringComparison.OrdinalIgnoreCase)
                || !string.Equals(a[i].Value, b[i].Value, StringComparison.Ordinal))
                return false;
        }
        return true;
    }

    private static bool PathEquals(List<DrillDownFilter> a, List<DrillDownFilter> b)
    {
        if (a.Count != b.Count) return false;
        for (int i = 0; i < a.Count; i++)
            if (!string.Equals(a[i].Field, b[i].Field, StringComparison.OrdinalIgnoreCase)
                || !string.Equals(a[i].Value, b[i].Value, StringComparison.Ordinal))
                return false;
        return true;
    }

    /// <summary>
    /// Returns true if every row in <paramref name="dt"/> has NULL (or empty string) in
    /// all of the specified display columns. Used to detect drill-down queries that returned
    /// rows only because of the anchor INNER join, but where the LEFT-JOINed detail tables
    /// had no matching entries — the result would render as a visually-empty tab. Fully
    /// generic: works for any report's column set.
    /// </summary>
    private static bool AllRowsAreEmpty(DataTable dt, List<ReportColumn> cols)
    {
        if (dt.Rows.Count == 0) return true;
        foreach (DataRow row in dt.Rows)
        {
            foreach (var c in cols)
            {
                if (!dt.Columns.Contains(c.Field)) continue;
                var v = row[c.Field];
                if (v != null && v != DBNull.Value && !string.IsNullOrEmpty(v.ToString()))
                    return false;
            }
        }
        return true;
    }

