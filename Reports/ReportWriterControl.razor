    private void ToggleGroupNode(FxGroupNode node) => node.Expanded = !node.Expanded;

    private async Task OnGroupNodeClicked(FxGroupNode node)
    {
        _selectedTreeNode = node;

        if (TreeMode == TreeNavigationMode.DrillDown && _xmlFilePath != null && _lastParameters != null)
        {
            var path = new List<DrillDownFilter>();
            void Collect(FxGroupNode current, List<FxGroupNode> roots)
            {
                bool TryFind(FxGroupNode n, List<FxGroupNode> trail)
                {
                    trail.Add(n);
                    if (ReferenceEquals(n, current)) return true;
                    foreach (var c in n.Children)
                        if (TryFind(c, trail)) return true;
                    trail.RemoveAt(trail.Count - 1);
                    return false;
                }
                foreach (var root in roots)
                {
                    var trail = new List<FxGroupNode>();
                    if (TryFind(root, trail))
                    {
                        foreach (var n in trail)
                            path.Add(new DrillDownFilter(n.Field, n.Value));
                        return;
                    }
                }
            }
            Collect(node, GroupTree);
            if (path.Count > 0)
                await OpenDrillDown(node, path);
            return;
        }

        StatusMessage = $"Group: {node.Label} (page {node.PageIndex} of {PageCount})";
        if (node.PageIndex > 0)
        {
            JumpTo(node.PageIndex);
            await InvokeAsync(StateHasChanged);
        }

        if (string.IsNullOrEmpty(node.AnchorId)) return;
        await HighlightReportGroupAsync(node.AnchorId);
    }

