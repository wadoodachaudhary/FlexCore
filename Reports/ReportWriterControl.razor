                <span>of @PageCount</span>
                <button disabled="@(CurrentPage >= PageCount)" @onclick="OnNextPage" title="Next Page">▶</button>
                <button disabled="@(CurrentPage >= PageCount)" @onclick="OnLastPage" title="Last Page">⏭</button>
