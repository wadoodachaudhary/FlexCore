@* ReportParamDialogControl — modal prompt for Crystal Reports parameter values.

   Mirrors the VB6 / Crystal "Enter Parameter Values" dialog. For each required
   parameter it renders a panel containing:

     - left:  the prompt text (e.g. "Enter Job:")
     - right: a secondary label with the parameter's display name
     - body:  one of:
        * dual-list-box   (AllowMultiple=True with default-values or pick-list)
        * combo dropdown  (AllowMultiple=False with 2+ default values)
        * pick-list combo (single-value pick-list provided by host)
        * date / number / boolean / free-text typed input

   Lives in FlexKit (no DB or app-specific dependencies). The host app
   registers an IReportPickListProvider implementation (or none — the
   dialog gracefully falls back to free-text inputs for parameters with
   neither default values nor a pick-list).

   Output contract:
     - Single-value parameters: result[Name] = the scalar value (string /
       long / decimal / DateTime / bool).
     - Multi-value parameters: result[Name] = string[] of the user's picks.
       Callers should pass these arrays through
       Fx.ControlKit.Reports.MultiValueParameterRewriter.Apply so the SQL's
       "= @Name" placeholder gets expanded into "IN (@Name_0, ...)".

   Usage:
     <ReportParamDialogControl @ref="paramDialog" />
     ...
     var values = await paramDialog.PromptAsync(reportTitle, definition.Parameters);
     if (values == null) return; // user cancelled
*@

@namespace Fx.ControlKit.Reports

@using Fx.ControlKit

@if (_visible)
{
    <div class="fx-dialog-overlay">
        <div class="fx-dialog fx-param-dialog">
            <div class="fx-dialog-header">
                <span>Enter Parameter Values</span>
                <button class="fx-dialog-close" type="button" @onclick="Cancel">×</button>
            </div>
            <div class="fx-dialog-body fx-param-body">
                @if (!string.IsNullOrWhiteSpace(_title))
                {
                    <div class="fx-param-title">@_title</div>
                }
                @foreach (var p in _parameters)
                {
                    var pickList = _pickLists.TryGetValue(p.Name, out var list) ? list : null;
                    var defaults = p.DefaultValues;
                    var hasDefaults = defaults.Count > 0;
                    var hasMultiSource = p.AllowMultiple && (hasDefaults || (pickList != null && pickList.Count > 0));
                    <div class="fx-param-panel">
                        <div class="fx-param-panel-header">
                            <span class="fx-param-prompt-text">
                                @(!string.IsNullOrEmpty(p.Prompt) ? p.Prompt : p.Name)
                            </span>
                            <span class="fx-param-secondary-label">
                                @(!string.IsNullOrWhiteSpace(p.DisplayName) ? p.DisplayName : p.Name)
                            </span>
                        </div>
                        <div class="fx-param-panel-body">
                            @if (p.AllowMultiple)
                            {
                                @* ── Dual-list-box ─────────────────────────
                                   Crystal renders multi-value parameters as an
                                   Available/Selected pair. The Available pool
                                   comes from <ParameterDefaultValues> (the
                                   common case for the DT-style reports),
                                   falling back to the host-provided pick-list
                                   if present. When neither source has items,
                                   the dual-list still renders empty so the
                                   "Enter a Value" input below can populate
                                   it for AllowCustomCurrentValues=True
                                   parameters. *@
                                <MultiSelectDualListControl TItem="ListItem"
                                                            Items="@GetMultiAvailable(p.Name)"
                                                            SelectedItems="@GetMultiSelected(p.Name)"
                                                            SelectedItemsChanged="@(items => SetMultiSelected(p.Name, items))"
                                                            LeftHeader="Available Values:"
                                                            RightHeader="Selected Values:"
                                                            KeySelector="@(i => i.Key)"
                                                            LabelSelector="@(i => i.Label)"
                                                            VisibleRows="7"
                                                            Height="180px" />

                                @if (p.AllowCustomCurrentValues || !hasMultiSource)
                                {
                                    @* "Enter a Value" custom-entry row — mirrors
                                       the Crystal dialog's inline text input +
                                       > button for adding ad-hoc values to the
                                       Selected pane. *@
                                    <div class="fx-param-custom-row">
                                        <label class="fx-param-value-label">Enter a Value:</label>
                                        <input type="text"
                                               class="fx-param-value-input"
                                               value="@_customDrafts.GetValueOrDefault(p.Name)"
                                               @oninput="@(e => _customDrafts[p.Name] = e.Value?.ToString() ?? "")"
                                               @onkeydown="@(e => OnCustomKeyDown(e, p.Name))" />
                                        <button type="button"
                                                class="fx-param-custom-add"
                                                title="Add this value to the Selected list"
                                                @onclick="@(() => AddCustomValue(p.Name))">
                                            &gt;
                                        </button>
                                    </div>
                                }
                            }
                            else if (hasDefaults && defaults.Count >= 2)
                            {
                                @* Crystal default-values dropdown — shows description,
                                   sets value behind it. Same as before. *@
                                <select class="fx-param-defaults-dropdown"
                                        @onchange="@(e => SetValue(p.Name, e.Value?.ToString() ?? ""))">
                                    @foreach (var choice in defaults)
                                    {
                                        <option value="@choice.Value"
                                                selected="@(_values.GetValueOrDefault(p.Name) == choice.Value)">
                                            @(string.IsNullOrWhiteSpace(choice.Description) ? choice.Value : choice.Description)
                                        </option>
                                    }
                                </select>
                                @if (p.AllowCustomCurrentValues)
                                {
                                    <label class="fx-param-value-label">Enter a Value:</label>
                                    <input type="text"
                                           class="fx-param-value-input"
                                           value="@_values.GetValueOrDefault(p.Name)"
                                           @oninput="@(e => SetValue(p.Name, e.Value?.ToString() ?? ""))" />
                                }
                            }
                            else if (pickList != null && pickList.Count > 0)
                            {
                                <select class="fx-param-picklist-dropdown"
                                        @onchange="@(e => SetValue(p.Name, e.Value?.ToString() ?? ""))">
                                    <option value="" selected="@(string.IsNullOrEmpty(_values.GetValueOrDefault(p.Name)))">
                                        @(p.IsOptional ? "..." : "--")
                                    </option>
                                    @foreach (var item in pickList)
                                    {
                                        <option value="@item.Value" selected="@(_values.GetValueOrDefault(p.Name) == item.Value)">@item.Display</option>
                                    }
                                </select>
                            }
                            else if (p.ParameterType == ReportParameterType.Integer || p.ParameterType == ReportParameterType.Decimal)
                            {
                                <input type="number"
                                       value="@_values.GetValueOrDefault(p.Name)"
                                       @oninput="@(e => SetValue(p.Name, e.Value?.ToString() ?? ""))" />
                            }
                            else if (p.ParameterType == ReportParameterType.Date)
                            {
                                <DatePickerControl Value="@ParseDateValue(_values.GetValueOrDefault(p.Name))"
                                                   ValueChanged="@(v => SetValue(p.Name, v.HasValue ? v.Value.ToString("yyyy-MM-dd") : ""))" />
                            }
                            else if (p.ParameterType == ReportParameterType.Boolean)
                            {
                                <select @onchange="@(e => SetValue(p.Name, e.Value?.ToString() ?? ""))">
                                    <option value="True" selected="@(_values.GetValueOrDefault(p.Name) == "True")">True</option>
                                    <option value="False" selected="@(_values.GetValueOrDefault(p.Name) == "False")">False</option>
                                </select>
                            }
                            else
                            {
                                <input type="text"
                                       value="@_values.GetValueOrDefault(p.Name)"
                                       @oninput="@(e => SetValue(p.Name, e.Value?.ToString() ?? ""))" />
                            }
                        </div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="fx-param-error">@_error</div>
                }
            </div>
            <div class="fx-dialog-footer">
                <button class="fx-button fx-button-primary" type="button" @onclick="Accept">OK</button>
                <button class="fx-button" type="button" @onclick="Cancel">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    /// <summary>
    /// Optional pick-list source. When null (no implementation registered in DI)
    /// every parameter falls back to a free-text / typed input or — for
    /// multi-value parameters with default values — the dual-list-box sourced
    /// from those defaults.
    /// </summary>
    [Inject] private IReportPickListProvider? PickLists { get; set; }

    private bool _visible;
    private string _title = "";
    private List<ReportParameter> _parameters = new();
    private Dictionary<string, string> _values = new();
    private Dictionary<string, IReadOnlyList<PickListItem>> _pickLists = new();

    // Per-parameter dual-list state. Each multi-value parameter gets its
    // own Available pool (seeded from DefaultValues or PickListSql) and
    // Selected list. Keeping these as IList<ListItem> matches what
    // MultiSelectDualListControl binds to.
    private readonly Dictionary<string, List<ListItem>> _multiAvailable =
        new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, IList<ListItem>> _multiSelected =
        new(StringComparer.OrdinalIgnoreCase);

    // Per-parameter "Enter a Value:" draft state for AllowCustomCurrentValues
    // / no-source multi-value parameters. The custom value is committed to
    // the Selected list when the user clicks the > button or presses Enter.
    private readonly Dictionary<string, string> _customDrafts =
        new(StringComparer.OrdinalIgnoreCase);

    private string? _error;
    private TaskCompletionSource<Dictionary<string, object>?>? _tcs;

    /// <summary>Internal record used as the TItem for the dual-list-box.
    /// Stable key + display label.</summary>
    public sealed record ListItem(string Key, string Label);

    /// <summary>
    /// Shows the dialog, waits for user input, and returns a parameter-value
    /// dictionary suitable for <see cref="ReportWriterControl.ShowSqlReport"/>.
    /// Multi-value parameters come back as <c>string[]</c>; everything else
    /// comes back as a typed scalar. Returns null if the user cancelled.
    ///
    /// <para>
    /// <paramref name="initialValues"/> lets a caller re-open the dialog with
    /// the user's previous selections preserved (the "Return to Parameters"
    /// toolbar action in FRptViewer). Multi-value entries are recognized as
    /// <c>string[]</c> or <see cref="IEnumerable{T}"/> of strings; everything
    /// else is treated as a scalar and round-tripped through ToString() into
    /// the underlying input. Values for parameter names that aren't in the
    /// current prompt set are ignored.
    /// </para>
    /// </summary>
    public async Task<Dictionary<string, object>?> PromptAsync(
        string title,
        List<ReportParameter> parameters,
        IReadOnlyDictionary<string, object>? initialValues = null)
    {
        _title = title;
        // Only prompt for parameters that are both "Required" and don't already have a default value.
        _parameters = parameters.Where(p => p.Required).ToList();
        if (_parameters.Count == 0)
            return new Dictionary<string, object>();

        _values = _parameters.ToDictionary(p => p.Name, p => p.DefaultValue ?? "");
        _pickLists = new Dictionary<string, IReadOnlyList<PickListItem>>();
        if (PickLists != null)
        {
            foreach (var p in _parameters)
            {
                // Prefer the ReportParameter overload — the provider can
                // run the loader's auto-derived PickListSql (sourced from
                // the Crystal XML's RecordSelectionFormula binding) so
                // picklists work for any parameter that filters on a
                // table.field, with no host-side per-parameter mapping.
                var list = PickLists.GetPickList(p);
                if (list != null && list.Count > 0)
                    _pickLists[p.Name] = list;
            }
        }

        // Seed dual-list state for every multi-value parameter. The
        // Available pool comes from <ParameterDefaultValues> if any are
        // present, otherwise from the host pick-list (if registered).
        // When neither source contributes items the dual-list still
        // renders empty — the "Enter a Value" custom-entry row below it
        // (visible when AllowCustomCurrentValues=true) lets the user
        // populate the Selected pane by typing.
        _multiAvailable.Clear();
        _multiSelected.Clear();
        _customDrafts.Clear();
        foreach (var p in _parameters.Where(p => p.AllowMultiple))
        {
            var available = new List<ListItem>();
            if (p.DefaultValues.Count > 0)
            {
                foreach (var choice in p.DefaultValues)
                {
                    if (string.IsNullOrEmpty(choice.Value)) continue;
                    var label = string.IsNullOrWhiteSpace(choice.Description)
                        ? choice.Value : choice.Description;
                    available.Add(new ListItem(choice.Value, label));
                }
            }
            else if (_pickLists.TryGetValue(p.Name, out var list))
            {
                foreach (var item in list)
                {
                    if (string.IsNullOrEmpty(item.Value)) continue;
                    available.Add(new ListItem(item.Value, item.Display ?? item.Value));
                }
            }
            _multiAvailable[p.Name] = available;
            _multiSelected[p.Name] = new List<ListItem>();
            _customDrafts[p.Name] = "";
        }

        // Overlay caller-supplied initial values onto the seeded state.
        // Done LAST so it wins over picklist/default seeding — this is how
        // the "Return to Parameters" action restores the user's prior picks.
        if (initialValues != null)
        {
            foreach (var p in _parameters)
            {
                if (!initialValues.TryGetValue(p.Name, out var raw) || raw is null) continue;

                if (p.AllowMultiple)
                {
                    // Accept string[] or IEnumerable<string>. Build the
                    // Selected list by looking each value up in Available;
                    // entries not found in Available become ad-hoc Selected
                    // items (covers AllowCustomCurrentValues-typed values).
                    IEnumerable<string>? values = raw switch
                    {
                        string[] arr => arr,
                        IEnumerable<string> en => en,
                        _ => null
                    };
                    if (values == null) continue;

                    var available = _multiAvailable.TryGetValue(p.Name, out var av) ? av : new List<ListItem>();
                    var selected = new List<ListItem>();
                    foreach (var v in values)
                    {
                        if (string.IsNullOrEmpty(v)) continue;
                        var match = available.FirstOrDefault(i => string.Equals(i.Key, v, StringComparison.OrdinalIgnoreCase));
                        selected.Add(match ?? new ListItem(v, v));
                    }
                    _multiSelected[p.Name] = selected;
                }
                else
                {
                    // Scalar — stringify so the underlying typed input shows
                    // the prior value. Date is formatted as ISO so DatePickerControl
                    // parses it back via ParseDateValue.
                    _values[p.Name] = raw switch
                    {
                        DateTime dt => dt.ToString("yyyy-MM-dd"),
                        bool b      => b ? "True" : "False",
                        IFormattable f => f.ToString(null, System.Globalization.CultureInfo.InvariantCulture),
                        _ => raw.ToString() ?? ""
                    };
                }
            }
        }

        _error = null;
        _visible = true;
        _tcs = new TaskCompletionSource<Dictionary<string, object>?>();
        StateHasChanged();
        return await _tcs.Task;
    }

    // ── Multi-select helpers ─────────────────────────────────────────

    private List<ListItem> GetMultiAvailable(string name) =>
        _multiAvailable.TryGetValue(name, out var v) ? v : new List<ListItem>();

    private IList<ListItem> GetMultiSelected(string name) =>
        _multiSelected.TryGetValue(name, out var v) ? v : new List<ListItem>();

    private void SetMultiSelected(string name, IList<ListItem> items)
    {
        _multiSelected[name] = items;
        // No StateHasChanged needed — the dual-list-box already drives a
        // render when it mutates the bound list, and the only other
        // observer (the OK-button enabled state) doesn't yet exist.
    }

    private void AddCustomValue(string name)
    {
        if (!_customDrafts.TryGetValue(name, out var raw)) return;
        var trimmed = (raw ?? "").Trim();
        if (string.IsNullOrEmpty(trimmed)) return;

        var current = GetMultiSelected(name);
        // Don't add duplicates — if the value is already selected, just
        // clear the draft. Case-insensitive match mirrors how Crystal
        // dedupes values internally.
        if (current.Any(i => string.Equals(i.Key, trimmed, StringComparison.OrdinalIgnoreCase)))
        {
            _customDrafts[name] = "";
            StateHasChanged();
            return;
        }
        // Replace the bound list with a NEW reference so MultiSelectDualListControl's
        // OnParametersSet ReferenceEquals check fires and the Selected pane re-syncs.
        // Mutating the existing IList in place leaves _lastSelectedRef pointing at
        // the same object, and the dual-list silently ignores the addition.
        var updated = new List<ListItem>(current) { new ListItem(trimmed, trimmed) };
        _multiSelected[name] = updated;
        _customDrafts[name] = "";
        StateHasChanged();
    }

    private void OnCustomKeyDown(KeyboardEventArgs e, string name)
    {
        if (e.Key == "Enter") AddCustomValue(name);
    }

    private void SetValue(string name, string value)
    {
        _values[name] = value;
    }

    // ── Accept / Cancel ──────────────────────────────────────────────

    private void Accept()
    {
        // Validate — required (non-optional) params must be filled in.
        var missing = new List<ReportParameter>();
        foreach (var p in _parameters)
        {
            if (p.IsOptional) continue;
            if (p.AllowMultiple)
            {
                if (GetMultiSelected(p.Name).Count == 0) missing.Add(p);
            }
            else
            {
                if (string.IsNullOrWhiteSpace(_values.GetValueOrDefault(p.Name))) missing.Add(p);
            }
        }
        if (missing.Count > 0)
        {
            _error = "Please provide: " + string.Join(", ",
                missing.Select(p => string.IsNullOrWhiteSpace(p.DisplayName) ? p.Name : p.DisplayName));
            StateHasChanged();
            return;
        }

        var result = new Dictionary<string, object>();
        foreach (var p in _parameters)
        {
            if (p.AllowMultiple)
            {
                // Multi-value → string[]. Callers route these through
                // MultiValueParameterRewriter so each value becomes its own
                // @Name_0 / @Name_1 / … placeholder in the SQL.
                result[p.Name] = GetMultiSelected(p.Name)
                    .Select(i => i.Key)
                    .ToArray();
            }
            else
            {
                var raw = _values.GetValueOrDefault(p.Name, "");
                result[p.Name] = ConvertValue(raw, p.ParameterType);
            }
        }

        _visible = false;
        _tcs?.TrySetResult(result);
        StateHasChanged();
    }

    private void Cancel()
    {
        _visible = false;
        _tcs?.TrySetResult(null);
        StateHasChanged();
    }

    // Parse the ISO date string held in _values back to DateTime? for the
    // DatePickerControl (it binds DateTime?, not the raw <input type=date> string).
    private static DateTime? ParseDateValue(string? raw)
        => DateTime.TryParse(raw, out var dt) ? dt : (DateTime?)null;

    private static object ConvertValue(string raw, ReportParameterType type) => type switch
    {
        ReportParameterType.Integer => long.TryParse(raw, out var i) ? i : 0L,
        ReportParameterType.Decimal => decimal.TryParse(raw, out var d) ? d : 0m,
        ReportParameterType.Date => DateTime.TryParse(raw, out var dt) ? dt : DateTime.MinValue,
        ReportParameterType.Boolean => bool.TryParse(raw, out var b) && b,
        _ => raw
    };
}
