@namespace Fx.ControlKit
@typeparam TValue
@typeparam TItem
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using System.Globalization
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

<div class="@HostCssClass" style="@HostStyle"
     @ref="_hostRef"
     @onclick:stopPropagation="true"
     @onmousedown:stopPropagation="true"
     @onkeydown:stopPropagation="true">
    @if (Editable)
    {
        <div class="@ButtonCssClass"
             role="combobox"
             aria-haspopup="listbox"
             aria-expanded="@_isOpen">
            <input class="fx-dropdown-input"
                   disabled="@(!Enabled)"
                   tabindex="@TabIndex"
                   value="@_editableText"
                   placeholder="@Placeholder"
                   @onfocus="HandleEditableFocus"
                   @onblur="HandleEditableBlur"
                   @oninput="HandleEditableInput"
                   @onkeydown="HandleEditableKeyDown" />
            <span class="fx-dropdown-arrow" aria-hidden="true"
                  @onmousedown="SuppressNextEditableBlurCommit"
                  @onclick="HandleEditableArrowClick"
                  @onclick:stopPropagation="true"></span>
        </div>
    }
    else
    {
        <button type="button"
                class="@ButtonCssClass"
                disabled="@(!Enabled)"
                tabindex="@TabIndex"
                aria-haspopup="listbox"
                aria-expanded="@_isOpen"
                @onclick="HandleButtonClick"
                @onkeydown="HandleButtonKeyDown"
                @onkeydown:preventDefault="@_isOpen">
            <span class="fx-dropdown-text @PlaceholderCssClass">@DisplayText</span>
            <span class="fx-dropdown-arrow" aria-hidden="true"
                  @onclick="HandleArrowClick"
                  @onclick:stopPropagation="@OpenOnArrowClickOnly"></span>
        </button>
    }

    @if (_isOpen && Enabled)
    {
        <button type="button"
                class="fx-dropdown-backdrop"
                tabindex="-1"
                aria-label="Close dropdown"
                @onclick="CloseAsync"></button>

        <div class="fx-dropdown-panel" style="@PanelStyle" role="listbox" @onmousedown="SuppressNextEditableBlurCommit" @onclick:stopPropagation="true">
            @if (DataSource != null)
            {
                foreach (var item in DataSource)
                {
                    var val = GetFieldValue(item, ValueFieldName);
                    var txt = GetFieldValue(item, TextFieldName);
                    var isSelected = IsSelectedValue(val);
                    <button type="button"
                            class="fx-dropdown-option @(isSelected ? "selected" : "")"
                            role="option"
                            aria-selected="@isSelected"
                            @onkeydown="e => HandleOptionKeyDown(e, val, item)"
                            @onkeydown:preventDefault="true"
                            @onclick="() => SelectItemAsync(val, item)">
                        @txt
                    </button>
                }
            }
            else
            {
                <div class="fx-dropdown-empty">No values</div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public IEnumerable<TItem>? DataSource { get; set; }
    [Parameter] public TValue? Value { get; set; }
    [Parameter] public EventCallback<TValue?> ValueChanged { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? Width { get; set; }
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public bool Enabled { get; set; } = true;
    [Parameter] public int? TabIndex { get; set; }
    [Parameter] public bool AllowFiltering { get; set; }
    [Parameter] public bool Editable { get; set; }
    [Parameter] public bool CommitEditableTextOnBlur { get; set; } = true;
    [Parameter] public bool OpenOnRender { get; set; }
    [Parameter] public bool OpenOnArrowClickOnly { get; set; }
    [Parameter] public EventCallback<KeyboardEventArgs> OnKeyDown { get; set; }
    [Parameter] public EventCallback Closed { get; set; }

    [Parameter] public string TextFieldName { get; set; } = "";
    [Parameter] public string ValueFieldName { get; set; } = "";

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public EventCallback<ChangeEventArgs<TValue, TItem>> ValueChange { get; set; }

    private bool _isOpen;
    private bool _openOnRenderInitialized;
    private bool _editableInputFocused;
    private bool _suppressNextEditableBlurCommit;
    private bool _openUp;
    private bool _needsGeometryRefresh;
    private double? _panelMaxHeight;
    private double? _panelTop;
    private double? _panelLeft;
    private double? _panelMinWidth;
    private bool _hasMeasuredGeometry;
    private ElementReference _hostRef;
    private IJSObjectReference? _dropdownJsModule;
    private string _editableText = "";
    private string _typeSelectBuffer = "";
    private DateTime _typeSelectLastInputUtc = DateTime.MinValue;
    private static readonly TimeSpan TypeSelectResetDelay = TimeSpan.FromSeconds(1);

    private string HostCssClass => string.Join(" ", new[] { "fx-dropdown-host", _openUp ? "fx-dropdown-open-up" : null, CssClass }.Where(c => !string.IsNullOrWhiteSpace(c)));
    private string ButtonCssClass => string.Join(" ", new[] { "fx-dropdown", Editable ? "fx-dropdown-editable" : null, !Enabled ? "disabled" : null, CssClass }.Where(c => !string.IsNullOrWhiteSpace(c)));
    private string PanelStyle
    {
        get
        {
            var parts = new List<string>();
            if (_panelTop.HasValue || _panelLeft.HasValue)
                parts.Add("position:fixed");
            if (_panelTop is { } top)
                parts.Add($"top:{top.ToString("0.##", CultureInfo.InvariantCulture)}px");
            if (_panelLeft is { } left)
                parts.Add($"left:{left.ToString("0.##", CultureInfo.InvariantCulture)}px");
            if (_panelMinWidth is { } minWidth)
            {
                var width = minWidth.ToString("0.##", CultureInfo.InvariantCulture);
                parts.Add($"width:{width}px");
                parts.Add($"min-width:{width}px");
                parts.Add($"max-width:{width}px");
            }
            if (_panelMaxHeight is > 0)
                parts.Add($"max-height:{_panelMaxHeight.Value.ToString("0.##", CultureInfo.InvariantCulture)}px");
            if (parts.Count > 0)
                parts.Add("bottom:auto");
            return parts.Count == 0 ? string.Empty : string.Join(";", parts) + ";";
        }
    }
    private string HostStyle
    {
        get
        {
            var w = string.IsNullOrWhiteSpace(Width) ? CalculatedWidth() : Width;
            return string.IsNullOrWhiteSpace(w) ? "" : $"width:{w};";
        }
    }

    private string CalculatedWidth()
    {
        int maxLen = (Placeholder ?? "").Length;
        if (DataSource != null)
            foreach (var item in DataSource)
            {
                var len = GetFieldValue(item, TextFieldName).Length;
                if (len > maxLen) maxLen = len;
            }
        if (maxLen <= 0) return "";
        var ch = Math.Clamp((int)Math.Ceiling(maxLen * 1.1), 8, 28);
        return $"min(calc({ch}ch + 1.9em), calc(100vw - 24px))";
    }
    private bool HasSelectedValue
    {
        get
        {
            if (Value is null)
                return false;

            if (Value is string stringValue)
                return !string.IsNullOrEmpty(stringValue);

            return true;
        }
    }
    private string PlaceholderCssClass => HasSelectedValue ? "" : "fx-dropdown-placeholder";
    private string DisplayText => SelectedText ?? (HasSelectedValue ? Value?.ToString() ?? "" : Placeholder ?? "");
    private string EditableDisplayText => SelectedText ?? (HasSelectedValue ? Value?.ToString() ?? "" : "");

    private string? SelectedText
    {
        get
        {
            if (DataSource == null || !HasSelectedValue)
                return null;

            foreach (var item in DataSource)
            {
                var val = GetFieldValue(item, ValueFieldName);
                if (IsSelectedValue(val))
                    return GetFieldValue(item, TextFieldName);
            }

            return Value?.ToString();
        }
    }

    protected override void OnParametersSet()
    {
        if (!Enabled)
        {
            _isOpen = false;
            ResetDropdownGeometry();
            return;
        }

        if (OpenOnRender && !_openOnRenderInitialized)
        {
            OpenDropdown();
            _openOnRenderInitialized = true;
        }

        if (Editable && !_editableInputFocused)
            _editableText = EditableDisplayText;
    }

    private async Task HandleButtonClick()
    {
        if (!OpenOnArrowClickOnly)
            await ToggleOpen();
    }

    private async Task HandleArrowClick()
    {
        if (OpenOnArrowClickOnly)
            await ToggleOpen();
    }

    private async Task ToggleOpen()
    {
        if (Enabled)
        {
            if (_isOpen)
                await CloseAsync();
            else
                OpenDropdown();
        }
    }

    private void OpenDropdown()
    {
        if (!Enabled)
            return;

        _isOpen = true;
        _needsGeometryRefresh = true;
        _openUp = false;
        _panelMaxHeight = null;
        _panelTop = null;
        _panelLeft = null;
        _panelMinWidth = null;
        _hasMeasuredGeometry = false;
    }

    private void ResetDropdownGeometry()
    {
        _openUp = false;
        _panelMaxHeight = null;
        _panelTop = null;
        _panelLeft = null;
        _panelMinWidth = null;
        _hasMeasuredGeometry = false;
        _needsGeometryRefresh = false;
    }

    private async Task CloseAsync()
    {
        if (!_isOpen)
            return;

        _isOpen = false;
        ResetDropdownGeometry();
        ClearTypeSelectBuffer();
        if (Closed.HasDelegate)
            await Closed.InvokeAsync();
    }

    private async Task HandleButtonKeyDown(KeyboardEventArgs e)
    {
        if (!Enabled)
            return;

        if (await TryDelegateNavigationKeyAsync(e))
            return;

        if (e.Key is "Enter" or " ")
        {
            if (_isOpen)
                await CommitCurrentSelectionAsync();
        }
        else if (e.Key == "Escape")
        {
            await CloseAsync();
        }
        else if (e.Key == "ArrowDown")
        {
            await MoveSelectionAsync(1);
        }
        else if (e.Key == "ArrowUp")
        {
            await MoveSelectionAsync(-1);
        }
        else if (e.Key == "Home")
        {
            await MoveSelectionToAsync(first: true);
        }
        else if (e.Key == "End")
        {
            await MoveSelectionToAsync(first: false);
        }
        else if (await TrySelectByTypedPrefixAsync(e))
        {
            return;
        }
    }

    private async Task HandleOptionKeyDown(KeyboardEventArgs e, string strVal, TItem item)
    {
        if (!Enabled)
            return;

        if (await TryDelegateNavigationKeyAsync(e))
            return;

        if (e.Key is "Enter" or " ")
        {
            await SelectItemAsync(strVal, item);
        }
        else if (e.Key == "Escape")
        {
            await CloseAsync();
        }
        else if (e.Key == "ArrowDown")
        {
            await MoveSelectionAsync(1);
        }
        else if (e.Key == "ArrowUp")
        {
            await MoveSelectionAsync(-1);
        }
        else if (e.Key == "Home")
        {
            await MoveSelectionToAsync(first: true);
        }
        else if (e.Key == "End")
        {
            await MoveSelectionToAsync(first: false);
        }
        else if (await TrySelectByTypedPrefixAsync(e))
        {
            return;
        }
    }

    private Task HandleEditableFocus()
    {
        _editableInputFocused = true;
        return Task.CompletedTask;
    }

    private async Task HandleEditableBlur()
    {
        _editableInputFocused = false;

        if (_suppressNextEditableBlurCommit)
        {
            _suppressNextEditableBlurCommit = false;
            return;
        }

        if (CommitEditableTextOnBlur)
            await PublishEditableTextAsync(_editableText);
        else
            _editableText = EditableDisplayText;
    }

    private async Task HandleEditableKeyDown(KeyboardEventArgs e)
    {
        if (!Enabled)
            return;

        if (await TryDelegateNavigationKeyAsync(e))
            return;

        if (e.Key == "Enter")
        {
            await PublishEditableTextAsync(_editableText);
            await CloseAsync();
        }
        else if (e.Key == "ArrowDown")
        {
            await MoveSelectionAsync(1);
        }
        else if (e.Key == "ArrowUp")
        {
            await MoveSelectionAsync(-1);
        }
        else if (e.Key == "F4")
        {
            OpenDropdown();
        }
        else if (e.Key == "Escape")
        {
            _editableText = EditableDisplayText;
            await CloseAsync();
        }
    }

    private async Task HandleEditableArrowClick()
    {
        await ToggleOpen();
        _suppressNextEditableBlurCommit = false;
    }

    private void SuppressNextEditableBlurCommit()
    {
        if (_editableInputFocused)
            _suppressNextEditableBlurCommit = true;
    }

    private Task HandleEditableInput(Microsoft.AspNetCore.Components.ChangeEventArgs e)
    {
        _editableText = e.Value?.ToString() ?? "";
        return Task.CompletedTask;
    }

    private async Task<bool> TrySelectByTypedPrefixAsync(KeyboardEventArgs e)
    {
        if (!IsTypeSelectKey(e))
            return false;

        var items = GetMaterializedItems();
        if (items.Count == 0)
            return true;

        var now = DateTime.UtcNow;
        if (_typeSelectBuffer.Length > 0 && now - _typeSelectLastInputUtc > TypeSelectResetDelay)
            _typeSelectBuffer = "";

        _typeSelectLastInputUtc = now;
        var requestedBuffer = _typeSelectBuffer + e.Key;
        var repeatedCharacter = requestedBuffer.Length > 1
            && requestedBuffer.All(c => char.ToUpperInvariant(c) == char.ToUpperInvariant(requestedBuffer[0]));

        var matchIndex = FindTypeSelectMatchIndex(items, requestedBuffer, cycleFromCurrent: repeatedCharacter);
        if (matchIndex < 0 && requestedBuffer.Length > 1)
        {
            requestedBuffer = e.Key;
            matchIndex = FindTypeSelectMatchIndex(items, requestedBuffer, cycleFromCurrent: true);
        }

        _typeSelectBuffer = requestedBuffer;
        if (matchIndex < 0)
            return true;

        await SelectItemAtAsync(items, matchIndex, keepOpen: _isOpen);
        return true;
    }

    private static bool IsTypeSelectKey(KeyboardEventArgs e)
    {
        return !e.AltKey
            && !e.CtrlKey
            && !e.MetaKey
            && e.Key.Length == 1
            && !char.IsControl(e.Key[0])
            && !char.IsWhiteSpace(e.Key[0]);
    }

    private int FindTypeSelectMatchIndex(IReadOnlyList<TItem> items, string prefix, bool cycleFromCurrent)
    {
        if (items.Count == 0 || string.IsNullOrEmpty(prefix))
            return -1;

        var start = 0;
        if (cycleFromCurrent)
        {
            var currentIndex = FindSelectedIndex(items);
            start = currentIndex < 0 ? 0 : (currentIndex + 1) % items.Count;
        }

        for (var offset = 0; offset < items.Count; offset++)
        {
            var index = (start + offset) % items.Count;
            if (ItemStartsWithTypedPrefix(items[index], prefix))
                return index;
        }

        return -1;
    }

    private bool ItemStartsWithTypedPrefix(TItem item, string prefix)
    {
        var text = GetFieldValue(item, TextFieldName);
        if (text.StartsWith(prefix, StringComparison.CurrentCultureIgnoreCase))
            return true;

        var value = GetFieldValue(item, ValueFieldName);
        return !string.Equals(value, text, StringComparison.Ordinal)
            && value.StartsWith(prefix, StringComparison.CurrentCultureIgnoreCase);
    }

    private void ClearTypeSelectBuffer()
    {
        _typeSelectBuffer = "";
        _typeSelectLastInputUtc = DateTime.MinValue;
    }

    private async Task<bool> TryDelegateNavigationKeyAsync(KeyboardEventArgs e)
    {
        if (e.Key != "Tab" || !OnKeyDown.HasDelegate)
            return false;

        await OnKeyDown.InvokeAsync(e);
        return true;
    }

    private async Task PublishEditableTextAsync(string text)
    {
        _editableText = text;
        var newValue = ConvertToValue(text);

        if (object.Equals(Value, newValue))
            return;

        Value = newValue;

        if (ValueChanged.HasDelegate)
            await ValueChanged.InvokeAsync(newValue);

        if (ValueChange.HasDelegate)
            await ValueChange.InvokeAsync(new ChangeEventArgs<TValue, TItem> { Value = newValue });
    }

    private async Task SelectItemAsync(string strVal, TItem item, bool closeAfterSelect = true)
    {
        _suppressNextEditableBlurCommit = false;
        var newValue = ConvertToValue(strVal);
        Value = newValue;
        if (Editable)
            _editableText = GetFieldValue(item, TextFieldName);

        if (closeAfterSelect)
        {
            _isOpen = false;
            ResetDropdownGeometry();
            ClearTypeSelectBuffer();
        }

        if (ValueChanged.HasDelegate)
            await ValueChanged.InvokeAsync(newValue);

        if (ValueChange.HasDelegate)
            await ValueChange.InvokeAsync(new ChangeEventArgs<TValue, TItem> { Value = newValue, ItemData = item });
    }

    private async Task MoveSelectionAsync(int delta)
    {
        var items = GetMaterializedItems();
        if (items.Count == 0)
        {
            OpenDropdown();
            return;
        }

        var currentIndex = FindSelectedIndex(items);
        var nextIndex = currentIndex < 0
            ? (delta >= 0 ? 0 : items.Count - 1)
            : Math.Clamp(currentIndex + delta, 0, items.Count - 1);

        await SelectItemAtAsync(items, nextIndex);
    }

    private Task MoveSelectionToAsync(bool first)
    {
        var items = GetMaterializedItems();
        if (items.Count == 0)
        {
            OpenDropdown();
            return Task.CompletedTask;
        }

        return SelectItemAtAsync(items, first ? 0 : items.Count - 1);
    }

    private async Task SelectItemAtAsync(IReadOnlyList<TItem> items, int index, bool keepOpen = true)
    {
        var item = items[index];
        await SelectItemAsync(GetFieldValue(item, ValueFieldName), item, closeAfterSelect: false);
        if (keepOpen)
            OpenDropdown();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_isOpen || !_needsGeometryRefresh)
            return;

        _needsGeometryRefresh = false;
        try
        {
            var module = await GetDropdownJsModuleAsync();
            if (module == null)
                return;

            var geometry = await module.InvokeAsync<DropdownGeometry>("measureDropdown", _hostRef, 180, 8);
            var changed = !_hasMeasuredGeometry
                || _openUp != geometry.OpenUp
                || Math.Abs((_panelMaxHeight ?? 0) - geometry.MaxHeight) > 0.5
                || Math.Abs((_panelTop ?? 0) - geometry.Top) > 0.5
                || Math.Abs((_panelLeft ?? 0) - geometry.Left) > 0.5
                || Math.Abs((_panelMinWidth ?? 0) - geometry.MinWidth) > 0.5;

            _openUp = geometry.OpenUp;
            _panelMaxHeight = geometry.MaxHeight > 0 ? geometry.MaxHeight : null;
            _panelTop = geometry.Top;
            _panelLeft = geometry.Left;
            _panelMinWidth = geometry.MinWidth > 0 ? geometry.MinWidth : null;
            _hasMeasuredGeometry = true;
            if (changed)
                await InvokeAsync(StateHasChanged);
        }
        catch
        {
            ResetDropdownGeometry();
        }
    }

    private async ValueTask<IJSObjectReference?> GetDropdownJsModuleAsync()
    {
        try
        {
            return _dropdownJsModule ??= await JSRuntime.InvokeAsync<IJSObjectReference>(
                "import", $"./_content/{typeof(DropDownListControl<TValue, TItem>).Assembly.GetName().Name}/dropdown-list-control.js");
        }
        catch
        {
            return null;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_dropdownJsModule is null)
            return;

        try
        {
            await _dropdownJsModule.DisposeAsync();
        }
        catch
        {
        }
    }

    private sealed class DropdownGeometry
    {
        public bool OpenUp { get; set; }
        public double MaxHeight { get; set; }
        public double Top { get; set; }
        public double Left { get; set; }
        public double MinWidth { get; set; }
    }

    private async Task CommitCurrentSelectionAsync()
    {
        var items = GetMaterializedItems();
        if (items.Count == 0)
        {
            await CloseAsync();
            return;
        }

        var index = FindSelectedIndex(items);
        if (index < 0)
            index = 0;

        var item = items[index];
        await SelectItemAsync(GetFieldValue(item, ValueFieldName), item);
    }

    private int FindSelectedIndex(IReadOnlyList<TItem> items)
    {
        for (var i = 0; i < items.Count; i++)
        {
            if (IsSelectedValue(GetFieldValue(items[i], ValueFieldName)))
                return i;
        }

        return -1;
    }

    private List<TItem> GetMaterializedItems() => DataSource?.ToList() ?? new List<TItem>();

    private string GetFieldValue(TItem item, string field)
    {
        if (item == null) return "";
        if (string.IsNullOrWhiteSpace(field))
        {
            if (item is string s) return s;
            return item.ToString() ?? "";
        }
        var prop = typeof(TItem).GetProperty(field);
        return prop?.GetValue(item)?.ToString() ?? "";
    }

    private bool IsSelectedValue(string strVal)
    {
        return HasSelectedValue && string.Equals(Value?.ToString(), strVal, StringComparison.Ordinal);
    }

    private static TValue? ConvertToValue(string strVal)
    {
        try
        {
            var targetType = Nullable.GetUnderlyingType(typeof(TValue)) ?? typeof(TValue);

            if (targetType == typeof(string))
                return (TValue?)(object)strVal;

            if (string.IsNullOrEmpty(strVal) && Nullable.GetUnderlyingType(typeof(TValue)) != null)
                return default;

            if (targetType.IsEnum)
                return (TValue?)Enum.Parse(targetType, strVal, ignoreCase: true);

            var converted = Convert.ChangeType(strVal, targetType, CultureInfo.InvariantCulture);
            return (TValue?)converted;
        }
        catch
        {
            return default;
        }
    }

    public class ChangeEventArgs<TVal, TItm>
    {
        public TVal? Value { get; set; }
        public TItm ItemData { get; set; } = default!;
    }
}
